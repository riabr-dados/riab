---
import Base from "../../layouts/Base.astro";
import CodeSnippet from "../../components/CodeSnippet.astro";
import DataExplorer from "../../components/DataExplorer.astro";
import { getDatasets, getDataset, buildSchemaContext } from "../../lib/catalog.js";
import { duckdbSnippet, pandasSnippet, rSnippet, cliSnippet, cleanedUrl } from "../../lib/hf.js";

export async function getStaticPaths() {
  const datasets = getDatasets();
  return datasets.map((ds) => ({ params: { slug: ds.slug } }));
}

const { slug } = Astro.params;
const ds = getDataset(slug);
if (!ds) return Astro.redirect("/404");

const allDatasets = getDatasets();
const related = (ds.related ?? [])
  .map((r) => allDatasets.find((d) => d.slug === r))
  .filter(Boolean);

const tables = (ds.cleaned?.tables ?? []).map((t) => (typeof t === "string" ? t : t.name));
const primaryTable = tables.find((t) => !t.endsWith("_fontes")) ?? tables[0] ?? null;
const hasCleanedCsv = ds.slug === "brasil-no-mundo";
const rawFolder = (ds.raw?.path ?? `${ds.slug}/`).replace(/^raw\//, "").replace(/\/$/, "");

const COUNTRY_FLAG = { BR: "🇧🇷", FR: "🇫🇷", AR: "🇦🇷", UK: "🇬🇧", UY: "🇺🇾", EU: "🇪🇺" };
const country = ds.source?.country ?? "";
const flag = COUNTRY_FLAG[country] ?? "";

function fmtBytes(b) {
  if (!b) return "";
  if (b < 1048576) return `${Math.round(b / 1024)} KB`;
  return `${(b / 1048576).toFixed(1)} MB`;
}

// Queries padrão por tabela
const DEFAULT_QUERIES = {
  obras: `SELECT
  tipo_obra,
  COUNT(*) AS total,
  COUNT(*) FILTER (WHERE coproducao_internacional = true) AS coproducoes
FROM obras
GROUP BY tipo_obra
ORDER BY total DESC`,

  fomento_fsa: `SELECT
  chamada_publica,
  COUNT(*) AS projetos,
  ROUND(SUM(valor_total_liberado_brl) / 1e6, 2) AS total_liberado_mi_brl
FROM fomento_fsa
WHERE valor_total_liberado_brl > 0
GROUP BY chamada_publica
ORDER BY total_liberado_mi_brl DESC`,

  bilheteria_consolidada_br: `SELECT
  titulo,
  ano_lancamento,
  publico_total,
  fonte
FROM bilheteria_consolidada_br
ORDER BY publico_total DESC
LIMIT 30`,

  bilheteria_por_filme_ano: `SELECT
  titulo_brasil,
  pais_obra,
  ano,
  publico
FROM bilheteria_por_filme_ano
ORDER BY publico DESC NULLS LAST
LIMIT 30`,

  bilheteria_europa: `SELECT
  titulo_original,
  admissoes_1996_2026,
  total_eu27_gb_desde_1996,
  ano_producao
FROM bilheteria_europa
ORDER BY admissoes_1996_2026 DESC NULLS LAST
LIMIT 30`,

  fsa_atas_festivais: `SELECT
  ano_chamada,
  titulo_obra,
  evento,
  pais_evento_extraido,
  tipo_pontuacao,
  pontos_evento,
  source_file
FROM fsa_atas_festivais
WHERE evento_internacional_estimado IS NOT FALSE
ORDER BY ano_chamada DESC, titulo_obra, pontos_evento DESC NULLS LAST
LIMIT 100`,

  fsa_atas_resultados: `SELECT
  ano_chamada,
  posicao,
  beneficiario_indireto,
  titulo_obra,
  pontuacao_final,
  resultado,
  source_file
FROM fsa_atas_resultados
ORDER BY ano_chamada DESC, source_file, posicao
LIMIT 100`,

  brasil_no_mundo_indice: `SELECT
  pais_fonte,
  instituicao,
  tipo_aparicao,
  nivel_evidencia,
  COUNT(*) AS achados
FROM brasil_no_mundo_indice
GROUP BY pais_fonte, instituicao, tipo_aparicao, nivel_evidencia
ORDER BY achados DESC`,

  diretores_obras: `SELECT
  diretor,
  pais_diretor,
  COUNT(DISTINCT cpb) AS obras
FROM diretores_obras
GROUP BY diretor, pais_diretor
ORDER BY obras DESC
LIMIT 30`,

  produtores_obras: `SELECT
  produtor,
  pais_produtor,
  COUNT(DISTINCT cpb) AS obras
FROM produtores_obras
GROUP BY produtor, pais_produtor
ORDER BY obras DESC
LIMIT 30`,
};

// Cruzamentos prontos por tabela
const CROSS_QUERIES = {
  obras: [
    {
      label: "Por UF do requerente",
      sql: `SELECT uf_requerente, COUNT(*) AS obras
FROM obras
WHERE uf_requerente IS NOT NULL
GROUP BY uf_requerente
ORDER BY obras DESC`,
    },
    {
      label: "Por tipo e ano",
      sql: `SELECT ano_arquivo AS ano, tipo_obra, COUNT(*) AS obras
FROM obras
WHERE ano_arquivo >= 2010
GROUP BY ano, tipo_obra
ORDER BY ano DESC, obras DESC`,
    },
    {
      label: "Coproduções internacionais",
      sql: `SELECT ano_arquivo AS ano, COUNT(*) AS total,
  COUNT(*) FILTER (WHERE coproducao_internacional = true) AS coproducoes,
  ROUND(100.0 * COUNT(*) FILTER (WHERE coproducao_internacional = true) / COUNT(*), 1) AS pct_coproducao
FROM obras
WHERE ano_arquivo >= 2010
GROUP BY ano ORDER BY ano DESC`,
    },
    {
      label: "Top produtoras (FSA)",
      sql: `SELECT f.razao_social_produtora AS produtora,
  COUNT(*) AS projetos,
  ROUND(SUM(f.valor_total_liberado_brl)/1e6, 2) AS total_mi_brl
FROM fomento_fsa f
WHERE f.razao_social_produtora IS NOT NULL
  AND f.valor_total_liberado_brl > 0
GROUP BY produtora
ORDER BY total_mi_brl DESC
LIMIT 20`,
    },
  ],
  fomento_fsa: [
    {
      label: "Por ano do edital",
      sql: `SELECT ano_edital,
  COUNT(*) AS projetos,
  ROUND(SUM(valor_total_liberado_brl)/1e6, 2) AS liberado_mi_brl
FROM fomento_fsa
GROUP BY ano_edital
ORDER BY ano_edital`,
    },
    {
      label: "Execucao por chamada",
      sql: `SELECT chamada_publica,
  COUNT(*) AS projetos,
  ROUND(SUM(valor_contrato_brl)/1e6, 2) AS contratado_mi,
  ROUND(SUM(valor_total_liberado_brl)/1e6, 2) AS liberado_mi,
  ROUND(100.0 * SUM(valor_total_liberado_brl) / NULLIF(SUM(valor_contrato_brl),0), 1) AS pct_execucao
FROM fomento_fsa
GROUP BY chamada_publica
ORDER BY liberado_mi DESC`,
    },
    {
      label: "Top produtoras",
      sql: `SELECT razao_social_produtora AS produtora,
  COUNT(*) AS projetos,
  ROUND(SUM(valor_total_liberado_brl)/1e6, 2) AS total_mi_brl
FROM fomento_fsa
WHERE razao_social_produtora IS NOT NULL AND valor_total_liberado_brl > 0
GROUP BY produtora
ORDER BY total_mi_brl DESC
LIMIT 20`,
    },
  ],
  fsa_atas_festivais: [
    {
      label: "Eventos por chamada",
      sql: `SELECT
  ano_chamada,
  COUNT(*) AS registros_evento,
  COUNT(DISTINCT titulo_obra) AS obras,
  ROUND(SUM(pontos_evento), 1) AS pontos
FROM fsa_atas_festivais
GROUP BY ano_chamada
ORDER BY ano_chamada`,
    },
    {
      label: "Obras mais pontuadas",
      sql: `SELECT
  titulo_obra,
  ano_chamada,
  COUNT(*) AS eventos,
  ROUND(SUM(pontos_evento), 1) AS pontos
FROM fsa_atas_festivais
GROUP BY titulo_obra, ano_chamada
ORDER BY pontos DESC NULLS LAST
LIMIT 30`,
    },
    {
      label: "Paises extraidos",
      sql: `SELECT
  pais_evento_extraido AS pais,
  COUNT(*) AS registros,
  COUNT(DISTINCT titulo_obra) AS obras
FROM fsa_atas_festivais
WHERE pais_evento_extraido IS NOT NULL
GROUP BY pais
ORDER BY registros DESC
LIMIT 30`,
    },
    {
      label: "Eventos internacionais",
      sql: `SELECT
  evento,
  pais_evento_extraido,
  COUNT(DISTINCT titulo_obra) AS obras,
  ROUND(SUM(pontos_evento), 1) AS pontos
FROM fsa_atas_festivais
WHERE evento_internacional_estimado IS TRUE
GROUP BY evento, pais_evento_extraido
ORDER BY obras DESC, pontos DESC NULLS LAST
LIMIT 40`,
    },
  ],
  fsa_atas_resultados: [
    {
      label: "Resultados por chamada",
      sql: `SELECT
  ano_chamada,
  chamada,
  COUNT(*) AS obras,
  ROUND(AVG(pontuacao_final), 2) AS media_pontuacao
FROM fsa_atas_resultados
GROUP BY ano_chamada, chamada
ORDER BY ano_chamada`,
    },
    {
      label: "Maiores pontuacoes",
      sql: `SELECT
  ano_chamada,
  posicao,
  titulo_obra,
  beneficiario_indireto,
  pontuacao_final
FROM fsa_atas_resultados
ORDER BY pontuacao_final DESC NULLS LAST
LIMIT 40`,
    },
  ],
  brasil_no_mundo_indice: [
    {
      label: "Titulos com mais presencas VOD",
      sql: `SELECT
  titulo_ou_indicador AS titulo,
  ano,
  linhas_relacionadas AS presencas_vod
FROM brasil_no_mundo_indice
WHERE dataset_derivado = 'brasil_no_mundo_vod_europa'
ORDER BY presencas_vod DESC
LIMIT 25`,
    },
    {
      label: "Obras brasileiras na Franca",
      sql: `SELECT
  ano,
  titulo_ou_indicador AS titulo,
  tipo_aparicao,
  linhas_relacionadas
FROM brasil_no_mundo_indice
WHERE dataset_derivado = 'brasil_no_mundo_obras_franca_cnc'
ORDER BY ano DESC NULLS LAST, titulo
LIMIT 50`,
    },
    {
      label: "Brasil como mercado no BFI",
      sql: `SELECT
  ano,
  titulo_ou_indicador AS indicador,
  descricao_curta
FROM brasil_no_mundo_indice
WHERE dataset_derivado = 'brasil_no_mundo_mercado_bfi'
ORDER BY ano, indicador`,
    },
  ],
};

const defaultQuery = primaryTable
  ? (DEFAULT_QUERIES[primaryTable] ?? `SELECT * FROM ${primaryTable} LIMIT 100`)
  : null;

const crossQueries = primaryTable ? (CROSS_QUERIES[primaryTable] ?? []) : [];
const schemaContext = primaryTable ? buildSchemaContext(primaryTable) : "";
---

<Base title={ds.title} description={ds.description}>
  <div class="ds-page">

    <div class="ds-breadcrumb">
      <a href={`${import.meta.env.BASE_URL}datasets/`}>Datasets</a>
      <span>/</span>
      <span>{ds.slug}</span>
    </div>

    <header class="ds-header">
      <div class="ds-header__left">
        <div class="ds-header__inst">{flag} {ds.source?.name ?? ds.source_id}</div>
        <h1 class="ds-header__title">{ds.title}</h1>
        <p class="ds-header__desc">{ds.description}</p>
        <div class="ds-header__tags">
          {(ds.tags ?? []).map((t) => <span class="tag">{t}</span>)}
        </div>
      </div>
      <div class="ds-header__meta">
        <div class="ds-meta-item">
          <span class="ds-meta-label">Status</span>
          <span class={`dcard__status dcard__status--${ds.status}`}>{ds.status}</span>
        </div>
        <div class="ds-meta-item">
          <span class="ds-meta-label">Cobertura</span>
          <span class="ds-meta-val">{ds.coverage}</span>
        </div>
        <div class="ds-meta-item">
          <span class="ds-meta-label">Formato raw</span>
          <span class="ds-meta-val">{ds.raw?.format?.toUpperCase()}</span>
        </div>
        <div class="ds-meta-item">
          <span class="ds-meta-label">Tamanho</span>
          <span class="ds-meta-val">{fmtBytes(ds.raw?.size_bytes)}</span>
        </div>
        {ds.raw?.files > 1 && (
          <div class="ds-meta-item">
            <span class="ds-meta-label">Arquivos</span>
            <span class="ds-meta-val">{ds.raw.files} arquivos</span>
          </div>
        )}
        {tables.length > 0 && (
          <div class="ds-meta-item">
            <span class="ds-meta-label">Tabelas tratadas</span>
            <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:2px">
              {tables.map((t) => (
                <>
                  <a class="tag dcard__tag--cleaned" href={cleanedUrl(t)} target="_blank"
                   title={`Baixar ${t}.parquet`}>{t} ↓</a>
                  {hasCleanedCsv && (
                    <a class="tag dcard__tag--cleaned" href={cleanedUrl(t, "csv")} target="_blank"
                       title={`Baixar ${t}.csv`} data-force-download download={`${t}.csv`}>{t} csv</a>
                  )}
                </>
              ))}
            </div>
          </div>
        )}
      </div>
    </header>

    {/* EXPLORADOR SQL */}
    {primaryTable && (
      <section class="ds-section">
        <h2 class="ds-section__title">// Explorar e Exportar</h2>
        <p class="ds-section__desc">
          Escreva SQL direto no browser. Os dados vem do Hugging Face em tempo real.
          <kbd>Ctrl+Enter</kbd> para executar.
        </p>
        <DataExplorer
          table={primaryTable}
          defaultQuery={defaultQuery}
          crossQueries={crossQueries}
          schemaContext={schemaContext}
        />
      </section>
    )}

    {/* SEM PARQUET */}
    {!primaryTable && (
      <section class="ds-section">
        <div class="no-explorer">
          <div style="font-size:28px;opacity:.3;margin-bottom:8px">⬜</div>
          <p>Este dataset ainda nao tem tabela Parquet tratada.</p>
          <p style="margin-top:4px">
            Baixe os arquivos brutos abaixo ou
            <a href="https://github.com/riabr-dados/riab/issues/new" target="_blank">
              abra uma issue
            </a>
            para solicitar a transformacao.
          </p>
        </div>
      </section>
    )}

    {/* COMO USAR NO CODIGO */}
    {primaryTable && (
      <section class="ds-section">
        <h2 class="ds-section__title">// Usar no seu codigo</h2>
        <div class="snippets-tabs" id="snippets-tabs">
          <button class="stab stab--active" data-tab="duckdb">DuckDB</button>
          <button class="stab" data-tab="pandas">pandas</button>
          <button class="stab" data-tab="r">R</button>
          <button class="stab" data-tab="cli">CLI</button>
        </div>
        <div id="tab-duckdb"><CodeSnippet code={duckdbSnippet(primaryTable)} lang="python" /></div>
        <div id="tab-pandas" class="hidden"><CodeSnippet code={pandasSnippet(primaryTable)} lang="python" /></div>
        <div id="tab-r" class="hidden"><CodeSnippet code={rSnippet(primaryTable)} lang="r" /></div>
        <div id="tab-cli" class="hidden"><CodeSnippet code={cliSnippet(rawFolder)} lang="bash" /></div>
      </section>
    )}

    {/* DADOS BRUTOS */}
    <section class="ds-section">
      <h2 class="ds-section__title">// Dados Brutos</h2>
      <p class="ds-section__desc">
        Arquivos originais intocados, hospedados no Hugging Face.
      </p>
      <div class="raw-info">
        <div class="raw-info__item">
          <span class="raw-info__label">Formato</span>
          <span>{ds.raw?.format?.toUpperCase()}</span>
        </div>
        {ds.raw?.encoding && (
          <div class="raw-info__item">
            <span class="raw-info__label">Encoding</span>
            <span>{ds.raw.encoding}</span>
          </div>
        )}
        {ds.raw?.delimiter && (
          <div class="raw-info__item">
            <span class="raw-info__label">Delimitador</span>
            <code>{ds.raw.delimiter}</code>
          </div>
        )}
        <div class="raw-info__item">
          <span class="raw-info__label">Pasta no HF</span>
          <code>raw/{rawFolder}/</code>
        </div>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:12px">
        <a class="btn-outline btn-sm"
           href={`https://huggingface.co/datasets/riabr-dados/riab/tree/main/raw/${rawFolder}`}
           target="_blank" rel="noopener">
          Ver arquivos no HF
        </a>
        {ds.source?.url && (
          <a class="btn-outline btn-sm"
             href={ds.source?.data_portal ?? ds.source?.url}
             target="_blank" rel="noopener">
            Fonte oficial
          </a>
        )}
      </div>
    </section>

    {/* RELACIONADOS */}
    {related.length > 0 && (
      <section class="ds-section">
        <h2 class="ds-section__title">// Datasets Relacionados</h2>
        <div class="related-list">
          {related.map((r) => (
            <a class="related-item" href={`${import.meta.env.BASE_URL}datasets/${r.slug}/`}>
              <span class="related-item__title">{r.title}</span>
              <span class="related-item__source">{r.source?.name?.split(" - ")[0] ?? r.source_id}</span>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</Base>

<style>
.no-explorer {
  padding: 32px 20px;
  text-align: center;
  border: 1px dashed var(--border2);
  border-radius: var(--radius);
  font-size: 11px;
  color: var(--muted);
  line-height: 1.8;
}
kbd {
  font-family: var(--font-m);
  font-size: 9px;
  padding: 1px 5px;
  border: 1px solid var(--border2);
  border-radius: 2px;
  background: var(--surface2);
  color: var(--muted);
}
</style>

<script>
  const tabs = document.querySelectorAll(".stab");
  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      tabs.forEach((t) => t.classList.remove("stab--active"));
      tab.classList.add("stab--active");
      const name = (tab as HTMLElement).dataset.tab;
      document.querySelectorAll("[id^='tab-']").forEach((el) => {
        (el as HTMLElement).classList.toggle("hidden", el.id !== `tab-${name}`);
      });
    });
  });
</script>
