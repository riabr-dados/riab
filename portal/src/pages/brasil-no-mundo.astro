---
import Base from "../layouts/Base.astro";
import CodeSnippet from "../components/CodeSnippet.astro";
import { cleanedUrl } from "../lib/hf.js";

const base = import.meta.env.BASE_URL;

const tables = [
  {
    table: "brasil_no_mundo_indice",
    label: "Indice unificado",
    rows: "717",
    desc: "Uma linha por achado, com tipo de aparicao, nivel de evidencia e tabela de detalhe.",
  },
  {
    table: "brasil_no_mundo_obras_franca_cnc",
    label: "Obras na Franca",
    rows: "185",
    desc: "Visas e agrements do CNC com nacionalidade ou coproducao brasileira.",
  },
  {
    table: "brasil_no_mundo_bilheteria_europa",
    label: "Bilheteria Europa",
    rows: "200",
    desc: "Filmes com producao BR e admissoes acumuladas em salas europeias.",
  },
  {
    table: "brasil_no_mundo_vod_europa",
    label: "VOD Europa",
    rows: "320",
    desc: "Presenca agregada por titulo em catalogos europeus de VOD.",
  },
  {
    table: "brasil_no_mundo_mercado_bfi",
    label: "Mercado BFI",
    rows: "14",
    desc: "Indicadores em que o Brasil aparece como mercado ou territorio.",
  },
  {
    table: "brasil_no_mundo_mencoes_outros_paises",
    label: "Mencoes pontuais",
    rows: "1",
    desc: "Mencoes textuais que nao comprovam origem brasileira da obra.",
  },
];

const evidence = [
  {
    key: "forte",
    title: "Obra brasileira explicita",
    desc: "Campos de nacionalidade, pais de producao ou flag de Brasil indicam participacao brasileira.",
    count: "705 achados",
  },
  {
    key: "coprod",
    title: "Coproducao brasileira",
    desc: "A fonte informa composicao de nacionalidade e, quando possivel, percentual brasileiro.",
    count: "39 no CNC",
  },
  {
    key: "mercado",
    title: "Mercado Brasil",
    desc: "Brasil aparece como territorio economico, nao como origem de obra.",
    count: "14 indicadores",
  },
  {
    key: "fraco",
    title: "Mencao textual",
    desc: "Brasil aparece em titulo ou texto, mas a linha exige leitura humana.",
    count: "1 registro",
  },
];

const sql = `SELECT
  pais_fonte,
  instituicao,
  tipo_aparicao,
  nivel_evidencia,
  COUNT(*) AS achados
FROM 'hf://datasets/riabr-dados/riab/cleaned/brasil_no_mundo_indice.parquet'
GROUP BY 1, 2, 3, 4
ORDER BY achados DESC;`;
---

<Base
  title="Brasil no Mundo"
  description="Secao derivada do RIDAB sobre aparicoes do audiovisual brasileiro em bases internacionais."
>
  <div class="bnm-page">
    <section class="bnm-hero">
      <div class="bnm-hero__copy">
        <p class="sec-label">Brasil no Mundo</p>
        <h1>O Brasil visto pelos dados do mundo.</h1>
        <p>
          Uma camada derivada e auditavel que separa filmes brasileiros,
          coproducoes, mercado Brasil e simples mencoes textuais em bases
          internacionais.
        </p>
        <div class="bnm-actions">
          <a class="btn-primary" href={`${base}datasets/brasil-no-mundo/`}>Explorar dataset</a>
          <a class="btn-ghost" href={cleanedUrl("brasil_no_mundo_indice", "csv")} target="_blank" rel="noopener">Baixar indice CSV</a>
          <a class="btn-ghost" href={cleanedUrl("brasil_no_mundo_indice")} target="_blank" rel="noopener">Baixar indice Parquet</a>
        </div>
      </div>
      <div class="bnm-hero__panel">
        <div class="bnm-stat">
          <span>717</span>
          <strong>achados indexados</strong>
        </div>
        <div class="bnm-stat">
          <span>185</span>
          <strong>linhas CNC Franca</strong>
        </div>
        <div class="bnm-stat">
          <span>520</span>
          <strong>registros Europa</strong>
        </div>
        <div class="bnm-stat">
          <span>14</span>
          <strong>indicadores BFI</strong>
        </div>
      </div>
    </section>

    <section class="bnm-section">
      <div class="sec-label">Mapa de evidencia</div>
      <h2 class="sec-title">Nem toda aparicao significa a mesma coisa.</h2>
      <p class="sec-sub">
        A secao usa categorias explicitas para evitar misturar obra brasileira,
        coproducao, mercado consumidor e mencao casual.
      </p>

      <div class="bnm-evidence">
        {evidence.map((item) => (
          <article class={`bnm-evidence__item bnm-evidence__item--${item.key}`}>
            <span>{item.count}</span>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="bnm-section bnm-section--tight">
      <div class="sec-label">Tabelas derivadas</div>
      <h2 class="sec-title">Pequenas por desenho.</h2>
      <p class="sec-sub">
        Cada tabela preserva a origem e o nivel de evidencia, para que a leitura
        seja transparente e reprodutivel.
      </p>

      <div class="bnm-table-grid">
        {tables.map((item) => (
          <article class="bnm-table">
            <div class="bnm-table__head">
              <span>{item.rows} linhas</span>
              <strong>{item.label}</strong>
            </div>
            <p>{item.desc}</p>
            <div class="bnm-table__footer">
              <code>{item.table}</code>
              <div class="bnm-table__downloads" aria-label={`Baixar ${item.label}`}>
                <a href={cleanedUrl(item.table, "csv")} target="_blank" rel="noopener" title={`Baixar ${item.table}.csv`}>CSV</a>
                <a href={cleanedUrl(item.table)} target="_blank" rel="noopener" title={`Baixar ${item.table}.parquet`}>Parquet</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="bnm-section">
      <div class="bnm-split">
        <div>
          <div class="sec-label">Consulta pronta</div>
          <h2 class="sec-title">Comece pelo indice.</h2>
          <p class="sec-sub">
            O indice e a porta de entrada: conte por fonte, filtre por tipo de
            aparicao e depois abra a tabela detalhada.
          </p>
        </div>
        <CodeSnippet code={sql} lang="sql" label="DuckDB / SQL" />
      </div>
    </section>
  </div>
</Base>

<style>
  .bnm-page {
    padding-bottom: 84px;
  }

  .bnm-hero {
    min-height: calc(100vh - 84px);
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, .75fr);
    gap: clamp(28px, 6vw, 92px);
    align-items: center;
    border-bottom: 1px solid var(--border);
  }

  .bnm-hero h1 {
    font-family: var(--font-d);
    font-variation-settings: 'opsz' 16,'wdth' 88,'wght' 760;
    font-size: clamp(48px, 8vw, 112px);
    line-height: .9;
    letter-spacing: -.02em;
    max-width: 900px;
    margin-bottom: 26px;
  }

  .bnm-hero__copy > p:not(.sec-label) {
    max-width: 680px;
    color: var(--muted);
    font-size: clamp(16px, 2vw, 21px);
    line-height: 1.45;
  }

  .bnm-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 30px;
  }

  .bnm-hero__panel {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border: 1px solid var(--border2);
    background: var(--surface);
    box-shadow: var(--sh-lg);
  }

  .bnm-stat {
    min-height: 150px;
    padding: 24px;
    border-bottom: 1px solid var(--border);
  }

  .bnm-stat:nth-child(odd) {
    border-right: 1px solid var(--border);
  }

  .bnm-stat:nth-child(n + 3) {
    border-bottom: 0;
  }

  .bnm-stat span {
    display: block;
    font-family: var(--font-d);
    font-variation-settings: 'opsz' 14,'wdth' 90,'wght' 760;
    font-size: clamp(34px, 5vw, 62px);
    line-height: 1;
    color: var(--br);
  }

  .bnm-stat strong {
    display: block;
    margin-top: 12px;
    color: var(--muted);
    font-family: var(--font-m);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .bnm-section {
    padding: 82px 0;
    border-bottom: 1px solid var(--border);
  }

  .bnm-section--tight {
    padding-top: 68px;
  }

  .bnm-evidence,
  .bnm-table-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .bnm-evidence__item,
  .bnm-table {
    background: var(--surface);
    min-height: 210px;
    padding: 24px;
    color: var(--text);
  }

  .bnm-evidence__item span,
  .bnm-table__head span {
    display: block;
    font-family: var(--font-m);
    font-size: 10px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--br);
    margin-bottom: 18px;
  }

  .bnm-evidence__item h3,
  .bnm-table__head strong {
    display: block;
    font-family: var(--font-d);
    font-variation-settings: 'opsz' 14,'wdth' 92,'wght' 700;
    font-size: 22px;
    line-height: 1.05;
    margin-bottom: 14px;
  }

  .bnm-evidence__item p,
  .bnm-table p {
    color: var(--muted);
    font-size: 13px;
    line-height: 1.55;
  }

  .bnm-table {
    min-height: 238px;
    display: flex;
    flex-direction: column;
    transition: background .15s, transform .15s;
  }

  .bnm-table:hover {
    background: var(--surface2);
    transform: translateY(-2px);
  }

  .bnm-table__footer {
    margin-top: auto;
    padding-top: 24px;
  }

  .bnm-table code {
    display: block;
    color: var(--dim);
    font-family: var(--font-m);
    font-size: 10px;
    overflow-wrap: anywhere;
  }

  .bnm-table__downloads {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }

  .bnm-table__downloads a {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0 10px;
    border: 1px solid var(--border2);
    color: var(--text);
    background: var(--paper);
    font-family: var(--font-m);
    font-size: 10px;
    letter-spacing: .08em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .bnm-table__downloads a:hover {
    border-color: var(--br);
    color: var(--br);
    text-decoration: none;
  }

  .bnm-table-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .bnm-split {
    display: grid;
    grid-template-columns: minmax(280px, .7fr) minmax(0, 1fr);
    gap: 42px;
    align-items: start;
  }

  .bnm-split :global(.snippet) {
    margin: 0;
  }

  @media (max-width: 980px) {
    .bnm-hero,
    .bnm-split {
      grid-template-columns: 1fr;
    }

    .bnm-hero {
      padding: 64px 0;
      min-height: auto;
    }

    .bnm-evidence,
    .bnm-table-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .bnm-hero h1 {
      font-size: 52px;
    }

    .bnm-hero__panel,
    .bnm-evidence,
    .bnm-table-grid {
      grid-template-columns: 1fr;
    }

    .bnm-stat,
    .bnm-stat:nth-child(odd),
    .bnm-stat:nth-child(n + 3) {
      border-right: 0;
      border-bottom: 1px solid var(--border);
    }

    .bnm-stat:last-child {
      border-bottom: 0;
    }
  }
</style>
