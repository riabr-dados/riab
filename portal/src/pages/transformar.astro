// ── BUILD BUILDER SQL ───────────────────────────────────────────
async function buildBuilderSQL() {
  if (builderTables.length === 0) return null;

  const aliasFor_ = (table) => builderTables.find(t => t.table === table)?.alias || aliasFor(table);
  const qualify = (ref) => {
    // ref is "table.col" → "alias.col"
    const [tb, col] = ref.split('.');
    return `${aliasFor_(tb)}.${col}`;
  };

  // Pick alias for each chosen column — dedupe across tables so headers stay unique.
  // e.g. obras.cpb + diretores_obras.cpb → "cpb" and "cpb_dob"
  const usedAliases = new Set();
  const colAliases = builderGroupBys.map(ref => {
    const [tb, col] = ref.split('.');
    let a = col;
    if (usedAliases.has(a)) a = `${col}_${aliasFor_(tb)}`;
    let n = 2;
    while (usedAliases.has(a)) a = `${col}_${aliasFor_(tb)}${n++}`;
    usedAliases.add(a);
    return a;
  });

  // SELECT clause
  const selectParts = [];
  const hasMetrics = builderMetrics.length > 0;
  const hasCols = builderGroupBys.length > 0;
  builderGroupBys.forEach((ref, i) => {
    selectParts.push(`${qualify(ref)} AS "${colAliases[i]}"`);
  });
  if (hasMetrics) {
    for (const m of builderMetrics) {
      const colExpr = m.col === '*' ? '*' : (m.col ? qualify(m.col) : '*');
      const op = m.op === 'COUNT_DISTINCT' ? `COUNT(DISTINCT ${colExpr})` : `${m.op}(${colExpr})`;
      const alias = (m.op + '_' + (m.col || 'all')).toLowerCase().replace(/[^a-z0-9_]+/g,'_');
      selectParts.push(`${op} AS ${alias}`);
    }
  } else if (!hasCols) {
    // nothing chosen at all → sensible default
    selectParts.push('COUNT(*) AS registros');
  }

  // FROM + JOINs
  const first = builderTables[0];
  let fromClause = `FROM ${first.table} ${first.alias}`;
  const inPlan = new Set([first.table]);
  for (let i = 1; i < builderTables.length; i++) {
    const t = builderTables[i];
    // find best bridge to anything in plan
    let best = null;
    for (const prev of inPlan) {
      const b = bridgeBetween(t.table, prev);
      if (b && (!best || (b.weight ?? 0) > (best.b.weight ?? 0))) best = { b, prev };
    }
    if (!best) {
      // unreachable → CROSS JOIN with a warning baked in
      fromClause += `\nCROSS JOIN ${t.table} ${t.alias}  -- ! sem ponte com o anterior — produto cartesiano`;
      inPlan.add(t.table);
      continue;
    }
    // pick first strong key in via_keys
    const joinKey = best.b.via_keys.find(k => STRONG_KEYS_SET.has(k)) || best.b.via_keys[0];
    // find concrete columns on both sides exposing that key
    const tMeta = BUILDER_DATA.catalog.find(c => c.table === t.table);
    const pMeta = BUILDER_DATA.catalog.find(c => c.table === best.prev);
    const tCols = tMeta?.key_cols?.[joinKey] || [];
    const pCols = pMeta?.key_cols?.[joinKey] || [];
    if (!tCols.length || !pCols.length) {
      fromClause += `\nCROSS JOIN ${t.table} ${t.alias}  -- ! chave ${joinKey} sem coluna concreta`;
      inPlan.add(t.table);
      continue;
    }
    // simple equality join on the first column of each side (with normalization if applicable)
    const lc = tCols[0]; const rc = pCols[0];
    const norm = lc.normalize === 'titulo_norm' || rc.normalize === 'titulo_norm';
    let cond;
    if (norm) {
      cond = `lower(regexp_replace(${t.alias}.${lc.col},'[^a-zA-Z0-9 ]','','g')) = lower(regexp_replace(${aliasFor_(best.prev)}.${rc.col},'[^a-zA-Z0-9 ]','','g'))`;
    } else if (joinKey === 'CNPJ') {
      cond = `regexp_replace(${t.alias}.${lc.col},'[^0-9]','','g') = regexp_replace(${aliasFor_(best.prev)}.${rc.col},'[^0-9]','','g')`;
    } else {
      cond = `${t.alias}.${lc.col} = ${aliasFor_(best.prev)}.${rc.col}`;
    }
    fromClause += `\nLEFT JOIN ${t.table} ${t.alias} ON ${cond}`;
    inPlan.add(t.table);
  }

  // WHERE clauses
  const whereClauses = builderFilters.map(f => {
    if (!f.col) return null;
    const c = qualify(f.col);
    if (f.op === 'IS NOT NULL') return `${c} IS NOT NULL`;
    if (f.op === 'IS NULL') return `${c} IS NULL`;
    const isNum = f.val !== '' && !Number.isNaN(Number(f.val));
    const v = isNum ? f.val : `'${esc(f.val)}'`;
    if (f.op === 'ILIKE') return `${c} ILIKE '%${esc(f.val)}%'`;
    return `${c} ${f.op} ${v}`;
  }).filter(Boolean);
  // exclude null on group keys only when actually aggregating (raw SELECT can keep nulls)
  if (hasCols && hasMetrics) {
    builderGroupBys.forEach(ref => whereClauses.unshift(`${qualify(ref)} IS NOT NULL`));
  }
  const where = whereClauses.length ? `WHERE ${whereClauses.join('\n  AND ')}` : '';

  // GROUP BY / ORDER BY / LIMIT
  // - cols + metrics: GROUP BY all chosen cols, order by first metric DESC
  // - cols only (no metrics): raw SELECT, no GROUP BY, order by first col ASC
  // - metrics only / nothing: single-row aggregate, no GROUP BY / ORDER BY
  let groupBy = '', orderBy = '';
  if (hasCols && hasMetrics) {
    const idxs = builderGroupBys.map((_, i) => i + 1).join(', ');
    groupBy = `GROUP BY ${idxs}`;
    orderBy = `ORDER BY ${builderGroupBys.length + 1} DESC NULLS LAST`;
  } else if (hasCols && !hasMetrics) {
    orderBy = `ORDER BY 1`;
  }
  const limitClause = builderLimit > 0 ? `LIMIT ${builderLimit}` : '';

  return [
    `SELECT ${selectParts.join(',\n       ')}`,
    fromClause,
    where,
    groupBy,
    orderBy,
    limitClause,
  ].filter(Boolean).join('\n');
}
