---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL;
const HF = "https://huggingface.co/datasets/riabr-dados/riab/resolve/main/cleaned";
---

<Base
  title="Transformar · Cruzar bases"
  description="Conecte as bases do audiovisual brasileiro e explore os dados — sem código."
>

<div class="tf">

  <!-- STATUS BAR -->
  <div class="tf-bar">
    <span class="tf-ey">RIDAB · TRANSFORMAR</span>
    <div class="tf-status-row">
      <span class="tdot" id="tf-dot"></span>
      <span id="tf-status">Iniciando DuckDB…</span>
    </div>
  </div>

  <!-- DOCS LINK -->
  <a class="tf-doclink" href={`${base}consulta/#metodologia`}>
    <span class="tf-doclink-text">Como as bases são conectadas: normalização de título, joins em cascata e deflação IPCA</span>
    <span class="tf-doclink-arr">Ler documentação →</span>
  </a>

  <!-- MODE TABS -->
  <div class="mode-tabs">
    <button class="mtab mtab--active" id="mtab-conexoes">⊞ Conexões</button>
    <button class="mtab" id="mtab-campos">⊕ Campos livres</button>
  </div>

  <!-- ── PANEL: CONEXÕES ─────────────────────────────────────── -->
  <div id="panel-conexoes">
    <div class="cr-section">
      <div class="cr-intro">
        <h2 class="cr-h">Escolha uma conexão para explorar</h2>
        <p class="cr-sub">Cada card liga duas ou mais bases. Clique para ver os dados imediatamente.</p>
      </div>
      <div class="cr-grid" id="cr-grid"></div>
    </div>
  </div>

  <!-- ── PANEL: CAMPOS LIVRES ───────────────────────────────── -->
  <div id="panel-campos" style="display:none">
    <div class="fl-wrap">

      <!-- Table selector -->
      <div class="fl-section">
        <div class="fl-section-label">Tabelas <span class="fl-hint">selecione uma ou mais</span></div>
        <div class="fl-table-pills" id="fl-table-pills"></div>
      </div>

      <!-- Available + chosen columns -->
      <div class="fl-cols-area" id="fl-cols-area" style="display:none">
        <div class="fl-available">
          <div class="fl-section-label">Colunas disponíveis <span class="fl-hint">clique para adicionar</span></div>
          <div class="fl-col-list" id="fl-col-list"></div>
        </div>
        <div class="fl-chosen-area">
          <div class="fl-section-label">Selecionadas</div>
          <div class="fl-chosen" id="fl-chosen"></div>
        </div>
      </div>

      <!-- Filters -->
      <div class="fl-filters-area" id="fl-filters-area" style="display:none">
        <div class="fl-section-label">
          Filtros
          <button class="fl-add-filter" id="fl-add-filter">+ adicionar</button>
        </div>
        <div id="fl-filter-rows"></div>
      </div>

      <!-- Limit + Run -->
      <div class="fl-controls" id="fl-controls" style="display:none">
        <div class="fl-limit-group">
          <span class="fl-section-label">Limite</span>
          <div class="fl-limit-chips" id="fl-limit-chips">
            <button class="lchip" data-n="25">25</button>
            <button class="lchip lchip--active" data-n="50">50</button>
            <button class="lchip" data-n="100">100</button>
            <button class="lchip" data-n="250">250</button>
            <button class="lchip" data-n="500">500</button>
          </div>
        </div>
        <button class="fl-run-btn" id="fl-run">▶ Executar</button>
      </div>

    </div>
  </div>

  <!-- ── SHARED RESULT AREA ─────────────────────────────────── -->
  <div class="res-area" id="res-area" style="display:none">

    <!-- Refinement bar (conexoes mode only) -->
    <div class="ref-bar" id="ref-bar">
      <div class="ref-group">
        <label class="ref-label" for="ref-dim">Agrupar por</label>
        <select class="ref-select" id="ref-dim"></select>
      </div>
      <div class="ref-group" id="ref-metric-group">
        <label class="ref-label" for="ref-metric">Mostrar</label>
        <select class="ref-select" id="ref-metric"></select>
      </div>
      <div class="ref-group ref-group--search">
        <label class="ref-label" for="ref-search">Buscar</label>
        <input class="ref-input" id="ref-search" type="text" placeholder="filtrar resultados…">
      </div>
      <button class="ref-run-btn" id="btn-rerun">↻ Atualizar</button>
    </div>

    <!-- Result toolbar -->
    <div class="res-toolbar">
      <span class="res-info" id="res-info"></span>
      <div class="res-btns">
        <button class="res-btn res-btn--active" id="btn-chart">◫ Gráfico</button>
        <button class="res-btn" id="btn-table">⊞ Tabela</button>
        <button class="res-btn" id="btn-sql">‹/› SQL</button>
        <button class="res-btn" id="btn-csv">↓ CSV</button>
      </div>
    </div>

    <!-- SQL panel -->
    <div class="sql-panel" id="sql-panel" style="display:none">
      <div class="sql-head">
        <span class="sql-label">SQL · DuckDB</span>
        <span class="sql-note">reutilizável em Python, R, MotherDuck</span>
        <button class="sql-copy" id="btn-copy-sql">Copiar</button>
      </div>
      <pre class="sql-pre" id="sql-pre"></pre>
    </div>

    <!-- Chart type sub-bar -->
    <div class="chart-type-bar" id="chart-type-bar" style="display:none">
      <button class="ct-btn ct-btn--active" data-type="bh">≡ Barras H</button>
      <button class="ct-btn" data-type="bv">∥ Barras V</button>
      <button class="ct-btn" data-type="ln">↗ Linha</button>
    </div>

    <!-- Chart view -->
    <div id="view-chart" class="chart-view"></div>

    <!-- Table view -->
    <div id="view-table" class="table-view" style="display:none"></div>

  </div><!-- /res-area -->

  <!-- Loading overlay -->
  <div class="res-loading" id="res-loading" style="display:none">
    <div class="spinner"></div>
    <span id="loading-msg">Carregando…</span>
  </div>

</div><!-- /tf -->
</Base>

<script define:vars={{ HF }}>
  window.__RIDAB_HF__ = HF;
</script>

<script type="module">
import * as duckdb from "https://cdn.jsdelivr.net/npm/@duckdb/duckdb-wasm@1.29.0/+esm";

const HF = window.__RIDAB_HF__;

// ── TABLE META (for campos livres) ─────────────────────────────
const TABLE_META = [
  { id: 'obras',                    alias: 'o', label: 'Obras ANCINE',      color: '#007a3c' },
  { id: 'bilheteria_por_filme_ano', alias: 'b', label: 'Bilheteria BR',     color: '#007a3c' },
  { id: 'diretores_obras',          alias: 'd', label: 'Diretores',         color: '#007a3c' },
  { id: 'produtores_obras',         alias: 'p', label: 'Produtores',        color: '#007a3c' },
  { id: 'fomento_fsa',              alias: 'f', label: 'Fomento FSA',       color: '#c8920a' },
  { id: 'condecine_arrecadacao',    alias: 'cx', label: 'CONDECINE',        color: '#c8920a' },
  { id: 'fomento_fluxos_financeiros', alias: 'ff', label: 'Fluxos Fomento', color: '#c8920a' },
  { id: 'fsa_atas_festivais',       alias: 'af', label: 'Festivais FSA',    color: '#c8920a' },
  { id: 'fsa_atas_resultados',      alias: 'ar', label: 'Atas FSA',         color: '#c8920a' },
  { id: 'renuncia_fiscal',          alias: 'r', label: 'Renúncia Fiscal',   color: '#1f3bb8' },
  { id: 'embrafilme_exibicao_territorio_ano', alias: 'em', label: 'Embrafilme', color: '#007a3c' },
  { id: 'pib_audiovisual_fontes',   alias: 'pb', label: 'Fontes PIB AV',    color: '#5a6f2b' },
  { id: 'rais_emprego_audiovisual_fontes', alias: 'rs', label: 'Fontes RAIS AV', color: '#5a6f2b' },
  { id: 'comercio_exterior_servicos_audiovisuais_fontes', alias: 'sv', label: 'Fontes Serviços', color: '#5a6f2b' },
  { id: 'comex_bens_audiovisuais_fontes', alias: 'cb', label: 'Fonte Comex Bens', color: '#5a6f2b' },
  { id: 'diversidade_audiovisual_fontes', alias: 'dv', label: 'Fontes Diversidade', color: '#5a6f2b' },
  { id: 'bilheteria_europa',        alias: 'l', label: 'Bilheteria Europa', color: '#1f3bb8' },
];

// ── CRUZAMENTOS ────────────────────────────────────────────────
const CRZ = [
  {
    id: 'obras-ano',
    label: 'Produção por ano',
    desc: 'Como evoluiu o número de obras registradas na ANCINE desde 2000',
    tables: [{ name: 'obras-nao-pub', color: '#007a3c' }],
    join: null, icon: '📅',
    dims: [
      { label: 'Ano de produção',   col: 'ano_producao_inicial' },
      { label: 'Tipo de obra',      col: 'tipo_obra' },
      { label: 'Estado (UF)',       col: 'uf_requerente' },
      { label: 'Janela de destino', col: 'segmento_destinacao_inicial' },
    ],
    metrics: [
      { label: 'Nº de obras', expr: 'COUNT(*)', alias: 'obras' },
    ],
    buildSQL: (dim, metric, search) => {
      const isYear = dim.col === 'ano_producao_inicial';
      const where = buildWhere([
        `${dim.col} IS NOT NULL`,
        isYear ? `${dim.col} >= 2000` : null,
        search ? `CAST(${dim.col} AS VARCHAR) ILIKE '%${esc(search)}%'` : null,
      ]);
      return `SELECT ${dim.col} AS dim, ${metric.expr} AS valor
FROM obras
${where}
GROUP BY 1 ORDER BY 1 ${isYear ? 'ASC' : 'DESC'}
LIMIT 60`;
    },
  },
  {
    id: 'obras-bilheteria',
    label: 'Obras + bilheteria',
    desc: 'Liga registro ANCINE ao público real no cinema via CPB',
    tables: [
      { name: 'obras-nao-pub',       color: '#007a3c' },
      { name: 'bilheteria-agregada', color: '#007a3c' },
    ],
    join: { type: 'exact', label: 'CPB exato' }, icon: '🎟',
    dims: [
      { label: 'Obra (título)',    col: 'o.titulo_original' },
      { label: 'Tipo de obra',    col: 'o.tipo_obra' },
      { label: 'Estado (UF)',     col: 'o.uf_requerente' },
      { label: 'Ano de exibição', col: 'b.ano' },
    ],
    metrics: [
      { label: 'Espectadores', expr: 'SUM(b.publico)',         alias: 'espectadores' },
      { label: 'Nº de obras',  expr: 'COUNT(DISTINCT o.cpb)', alias: 'obras' },
    ],
    buildSQL: (dim, metric, search) => {
      const where = buildWhere([
        `${dim.col} IS NOT NULL`,
        search ? `CAST(${dim.col} AS VARCHAR) ILIKE '%${esc(search)}%'` : null,
      ]);
      return `SELECT ${dim.col} AS dim, ${metric.expr} AS valor
FROM obras o
INNER JOIN bilheteria_por_filme_ano b
  ON b.cpb_roe = o.cpb AND b.cpb_roe LIKE 'B%'
${where}
GROUP BY 1 ORDER BY 2 DESC LIMIT 40`;
    },
  },
  {
    id: 'ficha-tecnica',
    label: 'Ficha técnica',
    desc: 'Obras com diretor(es) e produtora(s) — tudo via CPB exato',
    tables: [
      { name: 'obras-nao-pub',    color: '#007a3c' },
      { name: 'diretores-obras',  color: '#007a3c' },
      { name: 'produtores-obras', color: '#007a3c' },
    ],
    join: { type: 'exact', label: 'CPB exato' }, icon: '🎬',
    dims: [
      { label: 'Diretor',      col: 'd.diretor' },
      { label: 'Produtora',    col: 'p.produtor' },
      { label: 'Estado (UF)', col: 'o.uf_requerente' },
      { label: 'Tipo de obra', col: 'o.tipo_obra' },
    ],
    metrics: [
      { label: 'Nº de obras', expr: 'COUNT(DISTINCT o.cpb)', alias: 'obras' },
    ],
    buildSQL: (dim, metric, search) => {
      const where = buildWhere([
        `${dim.col} IS NOT NULL`,
        search ? `CAST(${dim.col} AS VARCHAR) ILIKE '%${esc(search)}%'` : null,
      ]);
      return `SELECT ${dim.col} AS dim, ${metric.expr} AS valor
FROM obras o
LEFT JOIN diretores_obras d ON d.cpb = o.cpb
LEFT JOIN produtores_obras p ON p.cpb = o.cpb
${where}
GROUP BY 1 ORDER BY 2 DESC LIMIT 40`;
    },
  },
  {
    id: 'obras-fsa',
    label: 'Obras + fomento FSA',
    desc: 'Liga obras ANCINE a projetos do Fundo Setorial via título normalizado',
    tables: [
      { name: 'obras-nao-pub', color: '#007a3c' },
      { name: 'fsa-projetos',  color: '#c8920a' },
    ],
    join: { type: 'proxy', label: 'proxy título' }, icon: '💰',
    dims: [
      { label: 'Chamada FSA',     col: 'f.chamada_publica' },
      { label: 'Tipo de obra',    col: 'o.tipo_obra' },
      { label: 'Produtora (FSA)', col: 'f.razao_social_produtora' },
      { label: 'Estado (UF)',     col: 'o.uf_requerente' },
    ],
    metrics: [
      { label: 'Total investido (R$)', expr: 'SUM(f.valor_contrato_brl)', alias: 'total_reais' },
      { label: 'Nº de projetos',       expr: 'COUNT(*)',                  alias: 'projetos' },
    ],
    buildSQL: (dim, metric, search) => {
      const where = buildWhere([
        `${dim.col} IS NOT NULL`,
        search ? `CAST(${dim.col} AS VARCHAR) ILIKE '%${esc(search)}%'` : null,
      ]);
      return `WITH o_n AS (
  SELECT *, lower(regexp_replace(titulo_original,'[^a-zA-Z0-9 ]','','g')) AS _tn
  FROM obras
),
f_n AS (
  SELECT *, lower(regexp_replace(titulo_projeto,'[^a-zA-Z0-9 ]','','g')) AS _tn
  FROM fomento_fsa
)
SELECT ${dim.col} AS dim, ${metric.expr} AS valor
FROM o_n o
INNER JOIN f_n f ON f._tn = o._tn
${where}
GROUP BY 1 ORDER BY 2 DESC NULLS LAST LIMIT 40`;
    },
  },
  {
    id: 'festivais-fsa',
    label: 'Festivais FSA',
    desc: 'Participações e premiações registradas nas atas de desempenho artístico',
    tables: [
      { name: 'atas-fsa-festivais', color: '#c8920a' },
    ],
    join: null, icon: '★',
    dims: [
      { label: 'Ano da chamada', col: 'ano_chamada' },
      { label: 'Evento',         col: 'evento' },
      { label: 'País extraído',  col: 'pais_evento_extraido' },
      { label: 'Tipo pontuação', col: 'tipo_pontuacao' },
      { label: 'Obra',           col: 'titulo_obra' },
    ],
    metrics: [
      { label: 'Registros',      expr: 'COUNT(*)',                    alias: 'registros' },
      { label: 'Nº de obras',    expr: 'COUNT(DISTINCT titulo_obra)', alias: 'obras' },
      { label: 'Pontos somados', expr: 'SUM(pontos_evento)',          alias: 'pontos' },
    ],
    buildSQL: (dim, metric, search) => {
      const where = buildWhere([
        `${dim.col} IS NOT NULL`,
        `evento_internacional_estimado IS NOT FALSE`,
        search ? `CAST(${dim.col} AS VARCHAR) ILIKE '%${esc(search)}%'` : null,
      ]);
      return `SELECT ${dim.col} AS dim, ${metric.expr} AS valor
FROM fsa_atas_festivais
${where}
GROUP BY 1 ORDER BY 2 DESC NULLS LAST LIMIT 40`;
    },
  },
  {
    id: 'condecine-arrecadacao',
    label: 'Arrecadação CONDECINE',
    desc: 'Série anual e mensal da CONDECINE consolidada a partir do OCA',
    tables: [
      { name: 'condecine-arrecadacao', color: '#c8920a' },
    ],
    join: null, icon: 'R$',
    dims: [
      { label: 'Ano',             col: 'ano' },
      { label: 'Mês',             col: 'mes' },
      { label: 'Tipo CONDECINE',  col: 'recorte_nome' },
      { label: 'Periodicidade',   col: 'periodicidade' },
    ],
    metrics: [
      { label: 'Valor nominal (R$)', expr: 'SUM(valor_brl_nominal)', alias: 'valor_brl' },
      { label: 'Registros',          expr: 'COUNT(*)',               alias: 'registros' },
    ],
    buildSQL: (dim, metric, search) => {
      const where = buildWhere([
        `${dim.col} IS NOT NULL`,
        search ? `CAST(${dim.col} AS VARCHAR) ILIKE '%${esc(search)}%'` : null,
      ]);
      return `SELECT ${dim.col} AS dim, ${metric.expr} AS valor
FROM condecine_arrecadacao
${where}
GROUP BY 1 ORDER BY 2 DESC NULLS LAST LIMIT 60`;
    },
  },
  {
    id: 'fluxos-fomento',
    label: 'Fluxos de fomento',
    desc: 'Captacao, recolhimento, liberacao, FSA, editais, premios e coproducao',
    tables: [
      { name: 'fluxos-fomento', color: '#c8920a' },
    ],
    join: null, icon: '$',
    dims: [
      { label: 'Ano',           col: 'ano' },
      { label: 'Tipo de fluxo', col: 'tipo_fluxo' },
      { label: 'Mecanismo',     col: 'mecanismo' },
      { label: 'Moeda',         col: 'moeda_original' },
      { label: 'Fonte',         col: 'titulo_publicacao' },
    ],
    metrics: [
      { label: 'Valor BRL nominal', expr: 'SUM(valor_brl_nominal)', alias: 'valor_brl' },
      { label: 'Valor original',    expr: 'SUM(valor_original)',    alias: 'valor_original' },
      { label: 'Registros',         expr: 'COUNT(*)',               alias: 'registros' },
    ],
    buildSQL: (dim, metric, search) => {
      const where = buildWhere([
        `${dim.col} IS NOT NULL`,
        search ? `CAST(${dim.col} AS VARCHAR) ILIKE '%${esc(search)}%'` : null,
      ]);
      return `SELECT ${dim.col} AS dim, ${metric.expr} AS valor
FROM fomento_fluxos_financeiros
${where}
GROUP BY 1 ORDER BY 2 DESC NULLS LAST LIMIT 60`;
    },
  },
  {
    id: 'embrafilme-historico',
    label: 'Histórico Embrafilme',
    desc: 'Público, renda e lugares oferecidos em PDFs históricos do OCA',
    tables: [
      { name: 'embrafilme-historico', color: '#007a3c' },
    ],
    join: null, icon: '1980',
    dims: [
      { label: 'Ano',       col: 'ano' },
      { label: 'Indicador', col: 'indicador' },
      { label: 'Território', col: 'territorio_nome' },
      { label: 'Tipo território', col: 'territorio_tipo' },
      { label: 'Documento', col: 'titulo_publicacao' },
    ],
    metrics: [
      { label: 'Valor',     expr: 'SUM(valor)', alias: 'valor' },
      { label: 'Registros', expr: 'COUNT(*)',   alias: 'registros' },
    ],
    buildSQL: (dim, metric, search) => {
      const where = buildWhere([
        `${dim.col} IS NOT NULL`,
        search ? `CAST(${dim.col} AS VARCHAR) ILIKE '%${esc(search)}%'` : null,
      ]);
      return `SELECT ${dim.col} AS dim, ${metric.expr} AS valor
FROM embrafilme_exibicao_territorio_ano
${where}
GROUP BY 1 ORDER BY 2 DESC NULLS LAST LIMIT 60`;
    },
  },
  {
    id: 'obras-renuncia',
    label: 'Obras + renúncia fiscal',
    desc: 'Obras que captaram via Lei do Audiovisual — ligação por título',
    tables: [
      { name: 'obras-nao-pub',   color: '#007a3c' },
      { name: 'renuncia-fiscal', color: '#1f3bb8' },
    ],
    join: { type: 'proxy', label: 'proxy título' }, icon: '📋',
    dims: [
      { label: 'Obra (título)', col: 'o.titulo_original' },
      { label: 'Tipo de obra',  col: 'o.tipo_obra' },
      { label: 'Estado (UF)',   col: 'o.uf_requerente' },
    ],
    metrics: [
      { label: 'Total captado (R$)', expr: 'SUM(r.total_captado)', alias: 'total_captado' },
      { label: 'Nº de projetos',     expr: 'COUNT(*)',              alias: 'projetos' },
    ],
    buildSQL: (dim, metric, search) => {
      const where = buildWhere([
        `${dim.col} IS NOT NULL`,
        search ? `CAST(${dim.col} AS VARCHAR) ILIKE '%${esc(search)}%'` : null,
      ]);
      return `WITH o_n AS (
  SELECT *, lower(regexp_replace(titulo_original,'[^a-zA-Z0-9 ]','','g')) AS _tn
  FROM obras
),
r_n AS (
  SELECT *, lower(regexp_replace(titulo_projeto,'[^a-zA-Z0-9 ]','','g')) AS _tn
  FROM renuncia_fiscal
)
SELECT ${dim.col} AS dim, ${metric.expr} AS valor
FROM o_n o
INNER JOIN r_n r ON r._tn = o._tn
${where}
GROUP BY 1 ORDER BY 2 DESC NULLS LAST LIMIT 40`;
    },
  },
  {
    id: 'br-eu',
    label: 'Brasil ↔ Europa',
    desc: 'Filmes brasileiros com mais espectadores em salas europeias (Lumière)',
    tables: [
      { name: 'lumiere-cinemas-europa', color: '#1f3bb8' },
    ],
    join: null, icon: '🌍',
    dims: [
      { label: 'Filme (título)',     col: 'titulo_original' },
      { label: 'País(es) produção',  col: 'paises_producao' },
      { label: 'Ano de produção',    col: 'ano_producao' },
    ],
    metrics: [
      { label: 'Admissões (Europa)', expr: 'SUM(admissoes_1996_2026)', alias: 'admissoes_europa' },
      { label: 'Nº de filmes',       expr: 'COUNT(*)',                  alias: 'filmes' },
    ],
    buildSQL: (dim, metric, search) => {
      const where = buildWhere([
        `${dim.col} IS NOT NULL`,
        `tem_brasil = TRUE`,
        search ? `CAST(${dim.col} AS VARCHAR) ILIKE '%${esc(search)}%'` : null,
      ]);
      return `SELECT ${dim.col} AS dim, ${metric.expr} AS valor
FROM bilheteria_europa
${where}
GROUP BY 1 ORDER BY 2 DESC NULLS LAST LIMIT 40`;
    },
  },
];

// ── HELPERS ────────────────────────────────────────────────────
function buildWhere(clauses) {
  const valid = clauses.filter(Boolean);
  return valid.length ? `WHERE ${valid.join('\n  AND ')}` : '';
}
function esc(s) { return String(s ?? '').replace(/'/g, "''"); }
function fmtNum(n) {
  if (!Number.isFinite(n)) return '—';
  return Number.isInteger(n)
    ? n.toLocaleString('pt-BR')
    : n.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

const JOIN_COLOR = { exact: '#007a3c', proxy: '#c8920a' };

// ── STATE ──────────────────────────────────────────────────────
let db, conn, ready = false;
let appMode = 'conexoes'; // 'conexoes' | 'campos'
let activeCrz = null;
let lastSQL = '', lastRows = [], lastCols = [];
let viewMode = 'chart';   // 'chart' | 'table'
let chartType = 'bh';     // 'bh' | 'bv' | 'ln'
let sortCol = null, sortAsc = true;

// Campos livres state
let flTables = new Set();
let flTableCols = {};     // { tableId: [{name,type}] }
let flChosen = [];        // [{tableId, alias, col}]
let flFilters = [];       // [{col, op, val}]
let flLimit = 50;

// ── DOM ────────────────────────────────────────────────────────
