function stripLimit(sql) {
  return sql.replace(/\s+LIMIT\s+\d+\s*$/i, '');
}

function makeCsvBlob(rows, cols) {
  const sep = ';';
  const header = cols.join(sep);
  const body = rows.map(r =>
    cols.map(c => {
      const v = r[c]; if (v == null) return '';
      const s = String(v);
      return (s.includes(sep) || s.includes('"') || s.includes('\n'))
        ? `"${s.replace(/"/g, '""')}"` : s;
    }).join(sep)
  ).join('\n');
  return new Blob(['﻿' + header + '\n' + body], { type: 'text/csv;charset=utf-8;' });
}

btnCsv.addEventListener('click', async () => {
  if (!lastSQL || !lastCols.length) return;
  const sqlAll = stripLimit(lastSQL);
  const orig = btnCsv.textContent;
  btnCsv.textContent = '⏳…';
  btnCsv.disabled = true;
  try {
    const res  = await conn.query(sqlAll);
    const rows = res.toArray();
    const cols = res.schema.fields.map(f => f.name);
    const blob = makeCsvBlob(rows, cols);
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `ridab_${activeCrz?.id ?? 'export'}_${new Date().toISOString().slice(0, 10)}.csv`;
    a.click();
    resInfo.textContent = `${lastRows.length} exibidas · ${rows.length} exportadas`;
  } catch (e) {
    statusEl.textContent = 'Erro ao exportar: ' + e.message;
  } finally {
    btnCsv.textContent = orig;
    btnCsv.disabled = false;
  }
});

// ── REPORT BUILDER ─────────────────────────────────────────────
//  Three-column UI: catalog (left) · trail (center) · aggregation (right)
//  Driven by BUILDER_DATA (loaded from joins.yaml at build time).

const BUILDER_KEY_COLORS = {
  CPB:'#dc2626',CRT:'#ea580c',ROE:'#f59e0b',SALIC:'#7c3aed',CONTRATO:'#9333ea',
  PROCESSO:'#a855f7',REG_ANCINE:'#0891b2',CNPJ:'#0284c7',CPF:'#0ea5e9',
  CNAE:'#14b8a6',GRUPO_ECON:'#10b981',PRODUTORA:'#84cc16',DISTRIBUIDORA:'#65a30d',
  EXIBIDORA:'#4d7c0f',TITULO_OBRA:'#e11d48',MUNICIPIO:'#94a3b8',UF:'#64748b',
  GENERO:'#a78bfa',CLASSIFICACAO:'#8b5cf6',PAIS:'#cbd5e1',ANO:'#94a3b8',
};

function bridgeBetween(a, b) {
  if (!a || !b) return null;
  return BUILDER_DATA.bridges.find(br =>
    (br.tables[0] === a && br.tables[1] === b) ||
    (br.tables[0] === b && br.tables[1] === a)
  ) || null;
}

function renderBuilder() {
  renderBuilderKeyFilters();
  renderBuilderCountryFilters();
  renderBuilderCatalog();
  renderBuilderTrail();
}

function renderBuilderKeyFilters() {
  const root = document.getElementById('bldr-key-filters');
  if (!root) return;
  const allKeys = Array.from(new Set(BUILDER_DATA.catalog.flatMap(d => d.keys)));
  const strongFirst = allKeys.filter(k => STRONG_KEYS_SET.has(k)).sort();
  const weakAfter   = allKeys.filter(k => !STRONG_KEYS_SET.has(k)).sort();
  const all = ['all', ...strongFirst, ...weakAfter];
  root.innerHTML = all.map(k => {
    const label = k === 'all' ? 'todas' : k;
    const active = (builderActiveKey === null && k === 'all') || builderActiveKey === k;
    const color = k === 'all' ? '#999' : (BUILDER_KEY_COLORS[k] || '#999');
    return `<button class="bldr-chip${active ? ' bldr-chip--on' : ''}" data-key="${k}"><span class="bldr-dot" style="background:${color}"></span>${label}</button>`;
  }).join('');
  root.querySelectorAll('.bldr-chip').forEach(b => b.onclick = () => {
    const k = b.dataset.key;
    builderActiveKey = k === 'all' ? null : k;
    renderBuilderKeyFilters();
    renderBuilderCatalog();
  });
}

function renderBuilderCountryFilters() {
  const root = document.getElementById('bldr-country-filters');
  if (!root) return;
  const countries = ['all','BR','AR','UY','FR','UK','EU'];
  const FILL = { BR:'#007a3c', AR:'#2d70c4', UY:'#b07d0a', FR:'#1f3bb8', UK:'#5a2244', EU:'#1f3bb8' };
  root.innerHTML = countries.map(c => {
    const active = (builderActiveCountry === null && c === 'all') || builderActiveCountry === c;
    const color = c === 'all' ? '#999' : FILL[c];
    return `<button class="bldr-chip${active ? ' bldr-chip--on' : ''}" data-country="${c}"><span class="bldr-dot" style="background:${color}"></span>${c === 'all' ? 'todos' : c}</button>`;
  }).join('');
  root.querySelectorAll('.bldr-chip').forEach(b => b.onclick = () => {
    const c = b.dataset.country;
    builderActiveCountry = c === 'all' ? null : c;
    renderBuilderCountryFilters();
    renderBuilderCatalog();
  });
}

function renderBuilderCatalog() {
  const root = document.getElementById('bldr-cat-list');
  if (!root) return;
  const q = builderSearch.toLowerCase();
  const filtered = BUILDER_DATA.catalog.filter(d => {
    if (builderActiveKey && !d.keys.includes(builderActiveKey)) return false;
    if (builderActiveCountry && d.country !== builderActiveCountry) return false;
    if (q && !d.title.toLowerCase().includes(q) && !d.table.toLowerCase().includes(q) && !d.slug.toLowerCase().includes(q)) return false;
    return true;
  });
  // group by country
  const byCountry = {};
  for (const d of filtered) (byCountry[d.country] ??= []).push(d);
  const COUNTRY_NAMES = { BR:'Brasil', AR:'Argentina', UY:'Uruguai', FR:'França', UK:'Reino Unido', EU:'Europa' };
  const FILL = { BR:'#007a3c', AR:'#2d70c4', UY:'#b07d0a', FR:'#1f3bb8', UK:'#5a2244', EU:'#1f3bb8' };
  const COUNTRY_ORDER = ['BR','AR','UY','FR','UK','EU'];
  let html = '';
  for (const c of COUNTRY_ORDER) {
    const items = byCountry[c];
    if (!items?.length) continue;
    html += `<div class="bldr-cat-group">
      <div class="bldr-cat-grouphead" style="border-left-color:${FILL[c]}">${COUNTRY_NAMES[c]} <span class="bldr-cat-count">${items.length}</span></div>`;
    items.sort((a,b)=>a.title.localeCompare(b.title)).forEach(d => {
      const inTrail = builderTables.some(t => t.table === d.table);
      const keysHtml = d.keys.slice(0,5).map(k =>
        `<span class="bldr-keypill" style="border-color:${BUILDER_KEY_COLORS[k] || '#999'};color:${BUILDER_KEY_COLORS[k] || '#999'}">${k}</span>`
      ).join('');
      html += `<button class="bldr-cat-item${inTrail ? ' bldr-cat-item--in' : ''}" data-table="${d.table}" title="${d.slug}">
        <div class="bldr-cat-title">${d.title}</div>
        <div class="bldr-cat-keys">${keysHtml || '<span class="bldr-cat-nokeys">— sem chaves de junção</span>'}</div>
      </button>`;
    });
    html += `</div>`;
  }
  if (!html) html = '<p class="bldr-empty">Nenhum dataset com esses filtros.</p>';
  root.innerHTML = html;
  root.querySelectorAll('.bldr-cat-item').forEach(b => b.onclick = () => addToTrail(b.dataset.table));
}

async function addToTrail(table) {
  if (builderTables.some(t => t.table === table)) return; // already in
  const alias = aliasFor(table);
  builderTables.push({ table, alias });
  // ensure DuckDB view for it
  if (ready && !registeredViews.has(table)) {
    try {
      await conn.query(`CREATE OR REPLACE VIEW ${table} AS SELECT * FROM '${HF}/${table}.parquet'`);
      registeredViews.add(table);
    } catch (e) {
      console.warn('view register failed for', table, e);
    }
  }
  // fetch columns once
  if (!builderColCache[table] && ready) {
    try {
      const res = await conn.query(`DESCRIBE SELECT * FROM ${table}`);
      builderColCache[table] = res.toArray().map(r => ({ name: String(r.column_name), type: String(r.column_type) }));
    } catch (e) {
      builderColCache[table] = [];
    }
  }
  renderBuilder();
  renderAggPane();
}

function removeFromTrail(table) {
  builderTables = builderTables.filter(t => t.table !== table);
  // clean group-by / metrics / filters that referenced this table
  builderGroupBys = builderGroupBys.filter(ref => !ref.startsWith(table + '.'));
  builderMetrics = builderMetrics.filter(m => !m.col || m.col === '*' || !m.col.startsWith(table + '.'));
  builderFilters = builderFilters.filter(f => !f.col?.startsWith(table + '.'));
  renderBuilder();
  renderAggPane();
}

function renderBuilderTrail() {
  const root = document.getElementById('bldr-trail-list');
  const warn = document.getElementById('bldr-trail-warnings');
  if (!root) return;
  if (builderTables.length === 0) {
    root.innerHTML = '<p class="bldr-empty">Clique num dataset à esquerda para começar.</p>';
    warn.innerHTML = '';
    return;
  }
  let html = '';
  let unreachable = [];
  for (let i = 0; i < builderTables.length; i++) {
    const t = builderTables[i];
    const meta = BUILDER_DATA.catalog.find(c => c.table === t.table);
    let bridgeHtml = '';
    if (i > 0) {
      // find best bridge with any prior
      let best = null;
      for (let j = 0; j < i; j++) {
        const b = bridgeBetween(t.table, builderTables[j].table);
        if (b && (!best || (b.weight ?? 0) > (best.b.weight ?? 0))) best = { b, prev: builderTables[j].table };
      }
      if (!best) {
        unreachable.push(t.table);
        bridgeHtml = `<div class="bldr-bridge bldr-bridge--err">⚠ sem ponte direta com os datasets anteriores</div>`;
      } else {
        const keys = best.b.via_keys.map(k =>
          `<span class="bldr-keypill" style="border-color:${BUILDER_KEY_COLORS[k]||'#999'};color:${BUILDER_KEY_COLORS[k]||'#999'}">${k}</span>`
        ).join('');
        bridgeHtml = `<div class="bldr-bridge">↑ junta com <strong>${best.prev}</strong> via ${keys}</div>`;
      }
    }
    html += `${bridgeHtml}
      <div class="bldr-trail-item">
        <span class="bldr-trail-alias">${t.alias}</span>
        <span class="bldr-trail-name">${meta?.title || t.table}</span>
        <button class="bldr-trail-rm" data-table="${t.table}" title="remover">×</button>
      </div>`;
  }
  root.innerHTML = html;
  root.querySelectorAll('.bldr-trail-rm').forEach(b => b.onclick = () => removeFromTrail(b.dataset.table));
  warn.innerHTML = unreachable.length
    ? `<div class="bldr-warn">⚠ Os datasets <strong>${unreachable.join(', ')}</strong> não têm chave em comum com os anteriores. O SQL gerado vai produzir produto cartesiano — adicione um dataset-ponte ou remova-os.</div>`
    : '';
}

function renderAggPane() {
  const pane = document.getElementById('bldr-agg-pane');
  if (!pane) return;
  pane.style.display = builderTables.length > 0 ? 'flex' : 'none';
  if (!builderTables.length) return;

  // drop group-by entries whose table is no longer in the trail
  const validTables = new Set(builderTables.map(t => t.table));
  builderGroupBys = builderGroupBys.filter(ref => validTables.has(ref.split('.')[0]));

  // chips of selected columns
  const chips = document.getElementById('bldr-gb-chips');
  if (builderGroupBys.length === 0) {
    chips.innerHTML = '<p class="bldr-empty">Nenhuma coluna escolhida. Sem coluna nem métrica, sai <code>COUNT(*)</code>.</p>';
  } else {
    chips.innerHTML = builderGroupBys.map((ref, i) => {
      const [tb, col] = ref.split('.');
      const alias = builderTables.find(t => t.table === tb)?.alias || tb;
      return `<span class="bldr-gb-chip"><span class="bldr-gb-chip-alias">${alias}.</span>${col}<button data-i="${i}" title="remover">×</button></span>`;
    }).join('');
    chips.querySelectorAll('button').forEach(b => b.onclick = () => {
      builderGroupBys.splice(+b.dataset.i, 1); renderAggPane();
    });
  }

  // dropdown to add a column (excludes already-chosen)
  const add = document.getElementById('bldr-gb-add');
  const chosen = new Set(builderGroupBys);
  let opts = '<option value="">+ adicionar coluna</option>';
  for (const t of builderTables) {
    const cols = (builderColCache[t.table] || []).filter(c => !chosen.has(`${t.table}.${c.name}`));
    if (cols.length === 0) continue;
    opts += `<optgroup label="${t.alias} · ${t.table}">`;
    for (const c of cols) {
      opts += `<option value="${t.table}.${c.name}">${c.name}  ·  ${c.type}</option>`;
    }
    opts += '</optgroup>';
  }
  add.innerHTML = opts;
  add.value = '';
  add.onchange = () => {
    if (add.value) { builderGroupBys.push(add.value); renderAggPane(); }
  };

  // metrics
  renderBuilderMetrics();
  renderBuilderFilters();
}

// Categorize a DuckDB type so we know which operators make sense
function colKind(type){
  const t = String(type || '').toLowerCase();
  if (/int|bigint|double|float|decimal|numeric|hugeint|tinyint|smallint|real/.test(t)) return 'num';
  if (/date|time|timestamp/.test(t)) return 'date';
  if (/bool/.test(t)) return 'bool';
  return 'cat'; // varchar, text, etc.
}
// Operators available per kind. COUNT(*) is always usable via the "*" column.
const OPS_BY_KIND = {
  num:  ['SUM','AVG','MIN','MAX','COUNT','COUNT_DISTINCT'],
  cat:  ['COUNT','COUNT_DISTINCT','MIN','MAX'],
  date: ['MIN','MAX','COUNT','COUNT_DISTINCT'],
  bool: ['COUNT','COUNT_DISTINCT','SUM'], // SUM(bool) = true-count
};
const OP_LABEL = {
  SUM:'soma', AVG:'média', MIN:'mínimo', MAX:'máximo',
  COUNT:'contar', COUNT_DISTINCT:'contar únicos',
};

function renderBuilderMetrics() {
  const root = document.getElementById('bldr-metrics');
  if (!root) return;
  if (builderMetrics.length === 0) {
    root.innerHTML = '<p class="bldr-empty">Nenhuma métrica. Clique em "+ adicionar métrica" — ou execute como está pra ver COUNT(*).</p>';
    return;
  }
  // all columns across selected tables, with their type
  const allCols = builderTables.flatMap(t =>
    (builderColCache[t.table] || []).map(c => ({
      ref: `${t.table}.${c.name}`, type: c.type, kind: colKind(c.type),
    }))
  );
  // synthetic "* (todas as linhas)" so user can pick COUNT(*) explicitly
  const colsWithStar = [{ ref:'*', type:'', kind:'any', label:'*  ·  todas as linhas' }, ...allCols.map(c => ({...c, label:`${c.ref}  ·  ${c.type}`}))];

  root.innerHTML = builderMetrics.map((m, i) => {
    const colMeta = m.col === '*' ? { kind: 'any' } : (allCols.find(c => c.ref === m.col) || { kind: 'cat' });
    // ops valid for the chosen column kind (COUNT/COUNT_DISTINCT always work)
    const opsAllowed = m.col === '*'
      ? ['COUNT']
      : (OPS_BY_KIND[colMeta.kind] || ['COUNT','COUNT_DISTINCT']);
    const opOpts = opsAllowed.map(op =>
      `<option value="${op}"${op === m.op ? ' selected' : ''}>${OP_LABEL[op]||op}</option>`
    ).join('');
    const colOpts = colsWithStar.map(c =>
      `<option value="${c.ref}"${c.ref === m.col ? ' selected' : ''}>${c.label}</option>`
    ).join('');
    return `<div class="bldr-metric-row">
      <select class="bldr-mselect bldr-mselect--op" data-i="${i}" data-f="op">${opOpts}</select>
      <select class="bldr-mselect" data-i="${i}" data-f="col">${colOpts}</select>
      <button class="bldr-trail-rm" data-i="${i}" data-rm="m">×</button>
    </div>`;
  }).join('');
  root.querySelectorAll('.bldr-mselect').forEach(el => el.onchange = () => {
    const m = builderMetrics[+el.dataset.i];
    m[el.dataset.f] = el.value;
    if (el.dataset.f === 'col') {
      // when column changes, snap op to one valid for the new kind
      const meta = m.col === '*' ? { kind: 'any' } : (allCols.find(c => c.ref === m.col) || { kind: 'cat' });
      const allowed = m.col === '*' ? ['COUNT'] : (OPS_BY_KIND[meta.kind] || ['COUNT','COUNT_DISTINCT']);
      if (!allowed.includes(m.op)) m.op = allowed[0];
    }
    if (el.dataset.f === 'op' && m.op === 'COUNT' && !m.col) m.col = '*';
    renderBuilderMetrics();
  });
  root.querySelectorAll('[data-rm="m"]').forEach(el => el.onclick = () => {
    builderMetrics.splice(+el.dataset.i, 1); renderBuilderMetrics();
  });
}

function renderBuilderFilters() {
  const root = document.getElementById('bldr-filter-rows');
  if (!root) return;
  if (builderFilters.length === 0) { root.innerHTML = ''; return; }
  const allCols = builderTables.flatMap(t => (builderColCache[t.table] || []).map(c => `${t.table}.${c.name}`));
  root.innerHTML = builderFilters.map((f, i) => {
    const colOpts = allCols.map(c => `<option value="${c}"${c === f.col ? ' selected' : ''}>${c}</option>`).join('');
    const needsVal = f.op !== 'IS NOT NULL' && f.op !== 'IS NULL';
    return `<div class="bldr-metric-row">
      <select class="bldr-mselect" data-i="${i}" data-f="col">${colOpts}</select>
      <select class="bldr-mselect bldr-mselect--op" data-i="${i}" data-f="op">
        ${[['=','='],['!=','≠'],['ILIKE','contém'],['>','>'],['<','<'],['IS NOT NULL','não nulo']].map(([v,l])=>`<option value="${v}"${v===f.op?' selected':''}>${l}</option>`).join('')}
      </select>
      ${needsVal ? `<input class="bldr-finput" data-i="${i}" value="${esc(f.val ?? '')}" placeholder="valor">` : ''}
      <button class="bldr-trail-rm" data-i="${i}" data-rm="f">×</button>
    </div>`;
  }).join('');
  root.querySelectorAll('.bldr-mselect').forEach(el => el.onchange = () => {
    builderFilters[+el.dataset.i][el.dataset.f] = el.value; renderBuilderFilters();
  });
  root.querySelectorAll('.bldr-finput').forEach(el => el.oninput = () => {
    builderFilters[+el.dataset.i].val = el.value;
  });
  root.querySelectorAll('[data-rm="f"]').forEach(el => el.onclick = () => {
    builderFilters.splice(+el.dataset.i, 1); renderBuilderFilters();
  });
}

