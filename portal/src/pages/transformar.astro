async function flToggleTable(tableId) {
  if (flTables.has(tableId)) {
    flTables.delete(tableId);
    flChosen = flChosen.filter(c => c.tableId !== tableId);
  } else {
    flTables.add(tableId);
    if (!flTableCols[tableId] && ready) {
      try {
        const res = await conn.query(`DESCRIBE SELECT * FROM ${tableId}`);
        flTableCols[tableId] = res.toArray().map(r => ({
          name: String(r.column_name),
          type: String(r.column_type),
        }));
      } catch (e) {
        console.warn('DESCRIBE failed for', tableId, e);
        flTableCols[tableId] = [];
      }
    }
  }
  renderFlPanel();
}

function renderFlPanel() {
  // Toggle pill active state
  document.querySelectorAll('.fl-tbl-pill').forEach(p => {
    p.classList.toggle('fl-tbl-pill--active', flTables.has(p.dataset.id));
  });

  const hasTables  = flTables.size > 0;
  const hasChosen  = flChosen.length > 0;
  document.getElementById('fl-cols-area').style.display    = hasTables ? 'grid' : 'none';
  document.getElementById('fl-filters-area').style.display = hasChosen ? 'block' : 'none';
  document.getElementById('fl-controls').style.display     = hasChosen ? 'flex'  : 'none';

  if (!hasTables) return;

  // Available columns
  const colList = document.getElementById('fl-col-list');
  colList.innerHTML = '';
  for (const tid of flTables) {
    const meta = TABLE_META.find(m => m.id === tid);
    const cols = flTableCols[tid] || [];
    cols.forEach(c => {
      const active = flChosen.some(x => x.tableId === tid && x.col === c.name);
      const btn = document.createElement('button');
      btn.className = 'fl-col-chip' + (active ? ' fl-col-chip--active' : '');
      btn.title = `${c.name} · ${c.type}`;
      btn.innerHTML = `<span class="fl-col-alias" style="color:${meta.color}">${meta.alias}.</span>${c.name}`;
      btn.addEventListener('click', () => {
        if (active) {
          flChosen = flChosen.filter(x => !(x.tableId === tid && x.col === c.name));
        } else {
          flChosen.push({ tableId: tid, alias: meta.alias, col: c.name });
        }
        renderFlPanel();
      });
      colList.appendChild(btn);
    });
  }

  // Chosen columns
  const chosenEl = document.getElementById('fl-chosen');
  if (flChosen.length) {
    chosenEl.innerHTML = flChosen.map((c, i) =>
      `<div class="fl-sel-chip">
