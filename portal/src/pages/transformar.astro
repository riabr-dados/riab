---
import Base from "../layouts/Base.astro";
const HF = "https://huggingface.co/datasets/riabr-dados/riab/resolve/main/cleaned";
---

<Base
  title="Transformar · Cruzar bases"
  description="Conecte as bases do audiovisual brasileiro e explore os dados — sem código."
>

<div class="tf">

  <!-- STATUS BAR -->
  <div class="tf-bar">
    <span class="tf-ey">RIDAB · TRANSFORMAR</span>
    <div class="tf-status-row">
      <span class="tdot" id="tf-dot"></span>
      <span id="tf-status">Iniciando DuckDB…</span>
    </div>
  </div>

  <!-- CRUZAMENTO CARDS -->
  <div class="cr-section">
    <div class="cr-intro">
      <h2 class="cr-h">Escolha uma conexão para explorar</h2>
      <p class="cr-sub">Cada card liga duas ou mais bases. Clique para ver os dados imediatamente.</p>
    </div>
    <div class="cr-grid" id="cr-grid">
      <!-- rendered by JS -->
    </div>
  </div>

  <!-- RESULT AREA (hidden until a cruzamento is selected) -->
  <div class="res-area" id="res-area" style="display:none">

    <!-- REFINEMENT BAR -->
    <div class="ref-bar">
      <div class="ref-group">
        <label class="ref-label" for="ref-dim">Agrupar por</label>
        <select class="ref-select" id="ref-dim"></select>
      </div>
      <div class="ref-group" id="ref-metric-group">
        <label class="ref-label" for="ref-metric">Mostrar</label>
        <select class="ref-select" id="ref-metric"></select>
      </div>
      <div class="ref-group ref-group--search">
        <label class="ref-label" for="ref-search">Buscar</label>
        <input class="ref-input" id="ref-search" type="text" placeholder="filtrar resultados…">
      </div>
      <button class="ref-run-btn" id="btn-rerun">↻ Atualizar</button>
    </div>

    <!-- RESULT TOOLBAR -->
    <div class="res-toolbar">
      <span class="res-info" id="res-info"></span>
      <div class="res-btns">
        <button class="res-btn res-btn--active" id="btn-chart">◫ Gráfico</button>
        <button class="res-btn" id="btn-table">⊞ Tabela</button>
        <button class="res-btn" id="btn-sql">‹/› SQL</button>
        <button class="res-btn" id="btn-csv">↓ CSV</button>
      </div>
    </div>

    <!-- SQL PANEL -->
    <div class="sql-panel" id="sql-panel" style="display:none">
      <div class="sql-head">
        <span class="sql-label">SQL · DuckDB</span>
        <span class="sql-note">reutilizável em Python, R, MotherDuck</span>
        <button class="sql-copy" id="btn-copy-sql">Copiar</button>
      </div>
      <pre class="sql-pre" id="sql-pre"></pre>
    </div>

    <!-- CHART VIEW -->
    <div id="view-chart" class="chart-view"></div>

    <!-- TABLE VIEW -->
    <div id="view-table" class="table-view" style="display:none"></div>

  </div><!-- /res-area -->

  <!-- LOADING OVERLAY -->
  <div class="res-loading" id="res-loading" style="display:none">
    <div class="spinner"></div>
    <span id="loading-msg">Carregando…</span>
  </div>

</div><!-- /tf -->

</Base>

<script define:vars={{ HF }}>
  window.__RIDAB_HF__ = HF;
</script>

<script type="module">
import * as duckdb from "https://cdn.jsdelivr.net/npm/@duckdb/duckdb-wasm@1.29.0/+esm";

const HF = window.__RIDAB_HF__;

// ── CRUZAMENTOS ────────────────────────────────────────────────────────────
const CRZ = [
  {
    id: 'obras-ano',
    label: 'Produção por ano',
    desc: 'Como evoluiu o número de obras registradas na ANCINE desde 2000',
    tables: [{ name: 'obras-nao-pub', color: '#007a3c' }],
    join: null,
    icon: '📅',
    dims: [
      { label: 'Ano de produção',  col: 'ANO_PRODUCAO_INICIAL' },
      { label: 'Tipo de obra',     col: 'TIPO_OBRA' },
      { label: 'Estado (UF)',      col: 'UF_REQUERENTE' },
      { label: 'Janela de destino',col: 'SEGMENTO_DESTINACAO_INICIAL' },
    ],
    metrics: [
      { label: 'Nº de obras', expr: 'COUNT(*)', alias: 'obras' },
    ],
    buildSQL: (dim, metric, search) => {
      const where = buildWhere([
        `${dim.col} IS NOT NULL`,
        dim.col === 'ANO_PRODUCAO_INICIAL' ? `${dim.col} >= 2000` : null,
        search ? `CAST(${dim.col} AS VARCHAR) ILIKE '%${esc(search)}%'` : null,
      ]);
      return `SELECT ${dim.col} AS dim, ${metric.expr} AS valor
FROM obras
${where}
GROUP BY 1 ORDER BY 1 ${dim.col === 'ANO_PRODUCAO_INICIAL' ? 'ASC' : ''}
LIMIT 60`;
    },
  },
  {
    id: 'obras-bilheteria',
    label: 'Obras + bilheteria',
    desc: 'Liga registro ANCINE ao público real no cinema via CPB',
    tables: [
      { name: 'obras-nao-pub',       color: '#007a3c' },
      { name: 'bilheteria-agregada', color: '#007a3c' },
    ],
    join: { type: 'exact', label: 'CPB exato' },
    icon: '🎟',
    dims: [
      { label: 'Obra (título)',   col: 'o.TITULO_ORIGINAL' },
      { label: 'Tipo de obra',   col: 'o.TIPO_OBRA' },
      { label: 'Estado (UF)',    col: 'o.UF_REQUERENTE' },
      { label: 'Ano de exibição',col: 'b.ANO' },
    ],
    metrics: [
      { label: 'Espectadores',  expr: 'SUM(b.PUBLICO)',         alias: 'espectadores' },
      { label: 'Renda (R$)',    expr: 'SUM(b.RENDA)',           alias: 'renda_reais' },
      { label: 'Nº de obras',   expr: 'COUNT(DISTINCT o.CPB)',  alias: 'obras' },
    ],
    buildSQL: (dim, metric, search) => {
      const where = buildWhere([
        `${dim.col} IS NOT NULL`,
        search ? `CAST(${dim.col} AS VARCHAR) ILIKE '%${esc(search)}%'` : null,
      ]);
      return `SELECT ${dim.col} AS dim, ${metric.expr} AS valor
FROM obras o
INNER JOIN bilheteria_por_filme_ano b
  ON b.CPB_ROE = o.CPB AND b.CPB_ROE LIKE 'B%'
${where}
GROUP BY 1 ORDER BY 2 DESC LIMIT 40`;
    },
  },
  {
    id: 'ficha-tecnica',
    label: 'Ficha técnica',
    desc: 'Obras com diretor(es) e produtora(s) — tudo via CPB exato',
    tables: [
      { name: 'obras-nao-pub',      color: '#007a3c' },
      { name: 'diretores-obras',    color: '#007a3c' },
      { name: 'produtores-obras',   color: '#007a3c' },
    ],
    join: { type: 'exact', label: 'CPB exato' },
    icon: '🎬',
    dims: [
      { label: 'Diretor',          col: 'd.DIRETOR' },
      { label: 'Produtora',        col: 'p.PRODUTOR' },
      { label: 'Estado (UF)',      col: 'o.UF_REQUERENTE' },
      { label: 'Tipo de obra',     col: 'o.TIPO_OBRA' },
    ],
    metrics: [
      { label: 'Nº de obras', expr: 'COUNT(DISTINCT o.CPB)', alias: 'obras' },
    ],
    buildSQL: (dim, metric, search) => {
      const where = buildWhere([
        `${dim.col} IS NOT NULL`,
        search ? `CAST(${dim.col} AS VARCHAR) ILIKE '%${esc(search)}%'` : null,
      ]);
      return `SELECT ${dim.col} AS dim, ${metric.expr} AS valor
FROM obras o
LEFT JOIN diretores_obras d ON d.CPB = o.CPB
LEFT JOIN produtores_obras p ON p.CPB = o.CPB
${where}
GROUP BY 1 ORDER BY 2 DESC LIMIT 40`;
    },
  },
  {
    id: 'obras-fsa',
    label: 'Obras + fomento FSA',
    desc: 'Liga obras ANCINE a projetos do Fundo Setorial via título normalizado',
    tables: [
      { name: 'obras-nao-pub', color: '#007a3c' },
      { name: 'fsa-projetos',  color: '#c8920a' },
    ],
    join: { type: 'proxy', label: 'proxy título' },
    icon: '💰',
    dims: [
      { label: 'Chamada FSA',      col: 'f.CHAMADA_PUBLICA' },
      { label: 'Tipo de obra',     col: 'o.TIPO_OBRA' },
      { label: 'Produtora (FSA)',  col: 'f.RAZAO_SOCIAL_PRODUTORA' },
      { label: 'Estado (UF)',      col: 'o.UF_REQUERENTE' },
    ],
    metrics: [
      { label: 'Total investido (R$)', expr: 'SUM(f.VALOR_CONTRATO_DOU)', alias: 'total_reais' },
      { label: 'Nº de projetos',       expr: 'COUNT(*)',                   alias: 'projetos' },
    ],
    buildSQL: (dim, metric, search) => {
      const where = buildWhere([
        `${dim.col} IS NOT NULL`,
        search ? `CAST(${dim.col} AS VARCHAR) ILIKE '%${esc(search)}%'` : null,
      ]);
      return `WITH o_n AS (
  SELECT *, lower(regexp_replace(TITULO_ORIGINAL,'[^a-zA-Z0-9 ]','','g')) AS _tn
  FROM obras
),
f_n AS (
  SELECT *, lower(regexp_replace(TITULO_PROJETO,'[^a-zA-Z0-9 ]','','g')) AS _tn
  FROM fomento_fsa
)
SELECT ${dim.col} AS dim, ${metric.expr} AS valor
FROM o_n o
INNER JOIN f_n f ON f._tn = o._tn
${where}
GROUP BY 1 ORDER BY 2 DESC NULLS LAST LIMIT 40`;
    },
  },
  {
    id: 'obras-renuncia',
    label: 'Obras + renúncia fiscal',
    desc: 'Obras que captaram via Lei do Audiovisual — ligação por título',
    tables: [
      { name: 'obras-nao-pub',   color: '#007a3c' },
      { name: 'renuncia-fiscal', color: '#1f3bb8' },
    ],
    join: { type: 'proxy', label: 'proxy título' },
    icon: '📋',
    dims: [
      { label: 'Obra (título)',    col: 'o.TITULO_ORIGINAL' },
      { label: 'Tipo de obra',    col: 'o.TIPO_OBRA' },
      { label: 'Estado (UF)',     col: 'o.UF_REQUERENTE' },
    ],
    metrics: [
      { label: 'Total captado (R$)', expr: 'SUM(r.TOTAL_CAPTADO)', alias: 'total_captado' },
      { label: 'Nº de projetos',     expr: 'COUNT(*)',              alias: 'projetos' },
    ],
    buildSQL: (dim, metric, search) => {
      const where = buildWhere([
        `${dim.col} IS NOT NULL`,
        search ? `CAST(${dim.col} AS VARCHAR) ILIKE '%${esc(search)}%'` : null,
      ]);
      return `WITH o_n AS (
  SELECT *, lower(regexp_replace(TITULO_ORIGINAL,'[^a-zA-Z0-9 ]','','g')) AS _tn
  FROM obras
),
r_n AS (
  SELECT *, lower(regexp_replace(TITULO_PROJETO,'[^a-zA-Z0-9 ]','','g')) AS _tn
  FROM renuncia_fiscal
)
SELECT ${dim.col} AS dim, ${metric.expr} AS valor
FROM o_n o
INNER JOIN r_n r ON r._tn = o._tn
${where}
GROUP BY 1 ORDER BY 2 DESC NULLS LAST LIMIT 40`;
    },
  },
  {
    id: 'br-eu',
    label: 'Brasil ↔ Europa',
    desc: 'Filmes brasileiros com mais espectadores em salas europeias (Lumière)',
    tables: [
      { name: 'bilheteria-agregada',    color: '#007a3c' },
      { name: 'lumiere-cinemas-europa', color: '#1f3bb8' },
    ],
    join: { type: 'proxy', label: 'proxy título' },
    icon: '🌍',
    dims: [
      { label: 'Filme (título)',   col: 'l."Original title"' },
    ],
    metrics: [
      { label: 'Admissões (Europa)', expr: 'SUM(l."Admissions")', alias: 'admissoes_europa' },
    ],
    buildSQL: (dim, metric, search) => {
      const where = buildWhere([
        `l."Original title" IS NOT NULL`,
        search ? `l."Original title" ILIKE '%${esc(search)}%'` : null,
      ]);
      return `SELECT l."Original title" AS dim, ${metric.expr} AS valor
FROM bilheteria_europa l
${where}
GROUP BY 1 ORDER BY 2 DESC NULLS LAST LIMIT 40`;
    },
  },
];

// ── HELPERS ────────────────────────────────────────────────────────────────
function buildWhere(clauses) {
  const valid = clauses.filter(Boolean);
  return valid.length ? `WHERE ${valid.join('\n  AND ')}` : '';
}
function esc(s) { return String(s).replace(/'/g, "''"); }

const JOIN_COLOR = { exact: '#007a3c', proxy: '#c8920a' };

// ── STATE ──────────────────────────────────────────────────────────────────
let db, conn, ready = false;
let activeCrz = null;
let lastSQL = '', lastRows = [], lastCols = [];
let viewMode = 'chart'; // 'chart' | 'table'

// ── DOM ────────────────────────────────────────────────────────────────────
const dot      = document.getElementById('tf-dot');
const statusEl = document.getElementById('tf-status');
const crGrid   = document.getElementById('cr-grid');
const resArea  = document.getElementById('res-area');
const resLoading = document.getElementById('res-loading');
const loadingMsg = document.getElementById('loading-msg');
const refDim   = document.getElementById('ref-dim');
const refMetric= document.getElementById('ref-metric');
const refMetricGroup = document.getElementById('ref-metric-group');
const refSearch= document.getElementById('ref-search');
const btnRerun = document.getElementById('btn-rerun');
const resInfo  = document.getElementById('res-info');
const btnChart = document.getElementById('btn-chart');
const btnTable = document.getElementById('btn-table');
const btnSql   = document.getElementById('btn-sql');
const btnCsv   = document.getElementById('btn-csv');
const sqlPanel = document.getElementById('sql-panel');
const sqlPre   = document.getElementById('sql-pre');
const btnCopySql = document.getElementById('btn-copy-sql');
const viewChart= document.getElementById('view-chart');
const viewTable= document.getElementById('view-table');

// ── INIT ───────────────────────────────────────────────────────────────────
(async () => {
  try {
    const bundles = duckdb.getJsDelivrBundles();
    const bundle  = await duckdb.selectBundle(bundles);
    const wUrl = URL.createObjectURL(
      new Blob([`importScripts("${bundle.mainWorker}");`], {type:'text/javascript'})
    );
    db = new duckdb.AsyncDuckDB(new duckdb.ConsoleLogger(), new Worker(wUrl));
    await db.instantiate(bundle.mainModule, bundle.pthreadWorker);
    conn = await db.connect();
    await conn.query("INSTALL httpfs; LOAD httpfs; SET s3_region='us-east-1';");

    // Register views
    const views = {
      obras:                    `${HF}/obras.parquet`,
      diretores_obras:          `${HF}/diretores_obras.parquet`,
      produtores_obras:         `${HF}/produtores_obras.parquet`,
      bilheteria_por_filme_ano: `${HF}/bilheteria_por_filme_ano.parquet`,
      fomento_fsa:              `${HF}/fomento_fsa.parquet`,
      renuncia_fiscal:          `${HF}/renuncia_fiscal.parquet`,
      bilheteria_europa:        `${HF}/bilheteria_europa.parquet`,
    };
    for (const [name, url] of Object.entries(views)) {
      await conn.query(`CREATE OR REPLACE VIEW ${name} AS SELECT * FROM '${url}'`);
    }

    dot.className = 'tdot tdot--ok';
    statusEl.textContent = `${Object.keys(views).length} tabelas prontas`;
    ready = true;
    renderCards();
  } catch(e) {
    dot.className = 'tdot tdot--err';
    statusEl.textContent = 'Erro ao iniciar: ' + e.message;
  }
})();

// ── RENDER CARDS ───────────────────────────────────────────────────────────
function renderCards() {
  crGrid.innerHTML = CRZ.map(c => {
    const tablePills = c.tables.map(t =>
      `<span class="cr-tbl-pill" style="border-color:${t.color};color:${t.color}">${t.name}</span>`
    ).join('<span class="cr-plus">+</span>');

    const joinBadge = c.join
      ? `<span class="cr-join-badge" style="color:${JOIN_COLOR[c.join.type]};border-color:${JOIN_COLOR[c.join.type]}20;background:${JOIN_COLOR[c.join.type]}10">${c.join.label}</span>`
      : '';

    return `<button class="cr-card" data-id="${c.id}" ${!ready ? 'disabled' : ''}>
      <div class="cr-card-top">
        <div class="cr-tables">${tablePills}</div>
        ${joinBadge}
      </div>
      <div class="cr-card-icon">${c.icon}</div>
      <div class="cr-card-label">${c.label}</div>
      <div class="cr-card-desc">${c.desc}</div>
      <div class="cr-card-cta">Explorar →</div>
    </button>`;
  }).join('');

  crGrid.querySelectorAll('.cr-card').forEach(btn => {
    btn.addEventListener('click', () => selectCrz(btn.dataset.id));
  });
}

// ── SELECT CRUZAMENTO ──────────────────────────────────────────────────────
function selectCrz(id) {
  activeCrz = CRZ.find(c => c.id === id);
  if (!activeCrz) return;

  // Mark active card
  crGrid.querySelectorAll('.cr-card').forEach(b => {
    b.classList.toggle('cr-card--active', b.dataset.id === id);
  });

  // Populate dropdowns
  refDim.innerHTML = activeCrz.dims.map((d, i) =>
    `<option value="${i}">${d.label}</option>`).join('');

  refMetric.innerHTML = activeCrz.metrics.map((m, i) =>
    `<option value="${i}">${m.label}</option>`).join('');

  refMetricGroup.style.display = activeCrz.metrics.length > 1 ? 'flex' : 'none';

  refSearch.value = '';

  resArea.style.display = 'block';
  sqlPanel.style.display = 'none';
  btnSql.classList.remove('res-btn--active');

  runQuery();
}

// ── RUN QUERY ──────────────────────────────────────────────────────────────
async function runQuery() {
  if (!ready || !activeCrz) return;

  const dim    = activeCrz.dims[+refDim.value];
  const metric = activeCrz.metrics[+refMetric.value];
  const search = refSearch.value.trim();
  const sql    = activeCrz.buildSQL(dim, metric, search);

  lastSQL = sql;
  sqlPre.textContent = sql;

  resLoading.style.display = 'flex';
  loadingMsg.textContent   = `Consultando ${activeCrz.label}…`;
  viewChart.innerHTML = '';
  viewTable.innerHTML = '';

  try {
    const t0  = Date.now();
    const res = await conn.query(sql);
    const ms  = Date.now() - t0;
    lastRows  = res.toArray();
    lastCols  = res.schema.fields.map(f => f.name);

    resInfo.textContent = `${lastRows.length} linhas · ${ms}ms`;
    statusEl.textContent = `${activeCrz.label} · ${lastRows.length} linhas · ${ms}ms`;
    renderView();
  } catch(e) {
    statusEl.textContent = 'Erro: ' + e.message;
    viewChart.innerHTML = `<div class="qerr">${e.message}</div>`;
    viewTable.innerHTML = '';
  } finally {
    resLoading.style.display = 'none';
  }
}

btnRerun.addEventListener('click', runQuery);
refDim.addEventListener('change', runQuery);
refMetric.addEventListener('change', runQuery);
refSearch.addEventListener('keydown', e => { if (e.key === 'Enter') runQuery(); });

// ── RENDER VIEW ────────────────────────────────────────────────────────────
function renderView() {
  if (viewMode === 'chart') { renderChart(); viewChart.style.display='block'; viewTable.style.display='none'; }
  else                      { renderTable(); viewChart.style.display='none';  viewTable.style.display='block'; }
}

function renderChart() {
  if (!lastRows.length) { viewChart.innerHTML = '<div class="qerr">Nenhum resultado.</div>'; return; }
  const dimCol = 'dim', valCol = 'valor';
  const top    = lastRows.slice(0, 40);
  const vals   = top.map(r => Number(r[valCol]) || 0);
  const maxVal = Math.max(...vals, 1);
  const metric = activeCrz?.metrics[+refMetric.value];
  const dim    = activeCrz?.dims[+refDim.value];

  const bars = top.map(r => {
    const v   = Number(r[valCol]) || 0;
    const lbl = String(r[dimCol] ?? '—');
    const pct = (v / maxVal) * 100;
    const fmt = fmtNum(v);
    return `<div class="cbar">
      <div class="cbar-lbl" title="${lbl}">${lbl}</div>
      <div class="cbar-track"><div class="cbar-fill" style="width:${pct.toFixed(1)}%"></div></div>
      <div class="cbar-val">${fmt}</div>
    </div>`;
  }).join('');

  viewChart.innerHTML = `
    <div class="chart-legend">
      <span class="chart-x">${dim?.label ?? 'Dimensão'}</span>
      <span class="chart-m">${metric?.label ?? 'Valor'}</span>
    </div>
    <div class="chart-bars">${bars}</div>`;
}

function renderTable() {
  if (!lastRows.length) { viewTable.innerHTML = '<div class="qerr">Nenhum resultado.</div>'; return; }
  const metricCol = lastCols[lastCols.length - 1];
  const vals      = lastRows.map(r => Number(r[metricCol]) || 0);
  const maxVal    = Math.max(...vals, 1);

  let h = `<table class="dtbl"><thead><tr>`;
  // friendly headers
  const friendlyHeaders = lastCols.map((c, i) => {
    if (c === 'dim')   return activeCrz?.dims[+refDim.value]?.label    ?? c;
    if (c === 'valor') return activeCrz?.metrics[+refMetric.value]?.label ?? c;
    return c;
  });
  friendlyHeaders.forEach(c => { h += `<th>${c}</th>`; });
  h += `</tr></thead><tbody>`;
  lastRows.forEach(row => {
    h += `<tr>`;
    lastCols.forEach((col, i) => {
      const v = row[col];
      const disp = v == null ? '—' : String(v);
      if (i === lastCols.length - 1 && maxVal > 0) {
        const pct = Math.round((Number(v) / maxVal) * 100);
        h += `<td class="td-metric">
          <div class="td-bar-wrap">
            <div class="td-bar" style="width:${pct}%"></div>
            <span>${fmtNum(Number(v))}</span>
          </div></td>`;
      } else {
        h += `<td title="${disp}">${disp}</td>`;
      }
    });
    h += `</tr>`;
  });
  h += `</tbody></table>`;
  viewTable.innerHTML = h;
}

function fmtNum(n) {
  if (!Number.isFinite(n)) return '—';
  return Number.isInteger(n)
    ? n.toLocaleString('pt-BR')
    : n.toLocaleString('pt-BR', {minimumFractionDigits:2,maximumFractionDigits:2});
}

// ── TOOLBAR ────────────────────────────────────────────────────────────────
btnChart.addEventListener('click', () => {
  viewMode = 'chart';
  btnChart.classList.add('res-btn--active');
  btnTable.classList.remove('res-btn--active');
  renderView();
});
btnTable.addEventListener('click', () => {
  viewMode = 'table';
  btnTable.classList.add('res-btn--active');
  btnChart.classList.remove('res-btn--active');
  renderView();
});
btnSql.addEventListener('click', () => {
  const vis = sqlPanel.style.display !== 'none';
  sqlPanel.style.display = vis ? 'none' : 'block';
  btnSql.classList.toggle('res-btn--active', !vis);
});
btnCopySql.addEventListener('click', async () => {
  await navigator.clipboard.writeText(sqlPre.textContent);
  btnCopySql.textContent = 'Copiado!';
  setTimeout(() => { btnCopySql.textContent = 'Copiar'; }, 1500);
});
btnCsv.addEventListener('click', () => {
  if (!lastRows.length) return;
  const sep = ';';
  const header = lastCols.join(sep);
  const rows = lastRows.map(r =>
    lastCols.map(c => {
      const v = r[c]; if (v == null) return '';
      const s = String(v);
      return (s.includes(sep)||s.includes('"')||s.includes('\n')) ? `"${s.replace(/"/g,'""')}"` : s;
    }).join(sep)
  ).join('\n');
  const blob = new Blob(['﻿'+header+'\n'+rows], {type:'text/csv;charset=utf-8;'});
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
