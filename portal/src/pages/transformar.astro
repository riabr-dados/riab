function getChartData() {
  const dimCol = lastCols[0];
  const valCol = lastCols[lastCols.length - 1];
  const rows   = lastRows.slice(0, 40);
  const vals   = rows.map(r => Number(r[valCol]) || 0);
  const maxVal = Math.max(...vals, 1);
  return { dimCol, valCol, rows, vals, maxVal };
}

function renderChart() {
  if (!lastRows.length) {
    viewChart.innerHTML = '<div class="qerr">Nenhum resultado.</div>';
    return;
  }
  const { dimCol, valCol, rows, vals, maxVal } = getChartData();
  const dimLabel = appMode === 'conexoes' ? (activeCrz?.dims[+refDim.value]?.label ?? dimCol) : dimCol;
  const valLabel = appMode === 'conexoes' ? (activeCrz?.metrics[+refMetric.value]?.label ?? valCol) : valCol;

  const legend = `<div class="chart-legend">
    <span class="chart-x">${dimLabel}</span>
    <span class="chart-m">${valLabel}</span>
  </div>`;

  if (chartType === 'bh') {
    const bars = rows.map(r => {
      const v   = Number(r[valCol]) || 0;
      const lbl = String(r[dimCol] ?? '—');
      const pct = (v / maxVal) * 100;
      return `<div class="cbar">
        <div class="cbar-lbl" title="${lbl}">${lbl}</div>
        <div class="cbar-track"><div class="cbar-fill" style="width:${pct.toFixed(1)}%"></div></div>
        <div class="cbar-val">${fmtNum(v)}</div>
      </div>`;
    }).join('');
    viewChart.innerHTML = `${legend}<div class="chart-bars">${bars}</div>`;

  } else if (chartType === 'bv') {
    const bars = rows.map(r => {
      const v   = Number(r[valCol]) || 0;
      const lbl = String(r[dimCol] ?? '—');
      const pct = (v / maxVal) * 100;
      return `<div class="cbv-col">
        <div class="cbv-val">${fmtNum(v)}</div>
        <div class="cbv-track"><div class="cbv-fill" style="height:${pct.toFixed(1)}%"></div></div>
        <div class="cbv-lbl" title="${lbl}">${lbl}</div>
      </div>`;
    }).join('');
    viewChart.innerHTML = `${legend}<div class="chart-bars-v">${bars}</div>`;

  } else { // ln
    const W = 800, H = 180, PAD = 10, BOTTOM = 60;
    const n   = rows.length;
    const xStep = n > 1 ? (W - PAD * 2) / (n - 1) : 0;
    const points = rows.map((r, i) => {
      const v = Number(r[valCol]) || 0;
      const x = PAD + i * xStep;
      const y = H - PAD - ((v / maxVal) * (H - PAD * 2 - BOTTOM));
      return { x, y, v, lbl: String(r[dimCol] ?? '—') };
    });
    const polyline = points.map(p => `${p.x},${p.y}`).join(' ');
    const dots = points.map(p =>
      `<circle cx="${p.x}" cy="${p.y}" r="3.5" fill="var(--br)">
        <title>${p.lbl}: ${fmtNum(p.v)}</title>
      </circle>`
    ).join('');
    // X-axis labels: show max 10 evenly
    const step = Math.max(1, Math.ceil(n / 10));
    const labels = points.filter((_, i) => i % step === 0 || i === n - 1).map(p =>
      `<text x="${p.x}" y="${H + 14}" text-anchor="middle" font-size="9" fill="var(--muted)"
        transform="rotate(-35,${p.x},${H + 14})">${p.lbl.slice(0, 20)}</text>`
    ).join('');
    const area = points.map((p, i) => (i === 0 ? `M${p.x},${H - PAD - BOTTOM + BOTTOM}` : ``) + '').join('');
    viewChart.innerHTML = `${legend}<div class="chart-svg-wrap">
      <svg viewBox="0 0 ${W} ${H + BOTTOM}" preserveAspectRatio="xMidYMid meet" class="chart-svg">
        <polyline points="${polyline}" fill="none" stroke="var(--br)" stroke-width="2" stroke-linejoin="round"/>
        ${dots}
        ${labels}
      </svg>
    </div>`;
  }
}

// ── SORTABLE TABLE ─────────────────────────────────────────────
function sortedRows() {
  if (!sortCol) return lastRows;
  return [...lastRows].sort((a, b) => {
    const av = a[sortCol], bv = b[sortCol];
    const an = Number(av), bn = Number(bv);
    const cmp = Number.isFinite(an) && Number.isFinite(bn)
      ? an - bn
      : String(av ?? '').localeCompare(String(bv ?? ''), 'pt-BR');
    return sortAsc ? cmp : -cmp;
  });
}

function renderTable() {
  if (!lastRows.length) { viewTable.innerHTML = '<div class="qerr">Nenhum resultado.</div>'; return; }

  const rows    = sortedRows();
  const metricCol = lastCols[lastCols.length - 1];
  const metricVals = rows.map(r => Number(r[metricCol]) || 0);
  const maxVal  = Math.max(...metricVals, 1);

  const friendlyHdr = (c, i) => {
    if (appMode === 'conexoes') {
      if (c === 'dim')   return activeCrz?.dims[+refDim.value]?.label    ?? c;
      if (c === 'valor') return activeCrz?.metrics[+refMetric.value]?.label ?? c;
    }
    return c;
  };

  let h = `<table class="dtbl"><thead><tr>`;
  lastCols.forEach((c, i) => {
    const dir  = sortCol === c ? (sortAsc ? ' ↑' : ' ↓') : '';
    const cls  = `th-sort${sortCol === c ? ' th-sort--active' : ''}`;
    h += `<th class="${cls}" data-col="${c}">${friendlyHdr(c, i)}${dir}</th>`;
  });
  h += `</tr></thead><tbody>`;

  rows.forEach(row => {
    h += `<tr>`;
    lastCols.forEach((col, i) => {
      const v    = row[col];
      const disp = v == null ? '—' : String(v);
      if (i === lastCols.length - 1 && maxVal > 0 && Number.isFinite(Number(v))) {
        const pct = Math.round((Number(v) / maxVal) * 100);
        h += `<td class="td-metric"><div class="td-bar-wrap">
          <div class="td-bar" style="width:${pct}%"></div>
          <span>${fmtNum(Number(v))}</span>
        </div></td>`;
      } else {
        h += `<td title="${disp}">${disp}</td>`;
      }
    });
    h += `</tr>`;
  });
  h += `</tbody></table>`;
  viewTable.innerHTML = h;

  viewTable.querySelectorAll('.th-sort').forEach(th => {
    th.addEventListener('click', () => {
      const col = th.dataset.col;
      if (sortCol === col) sortAsc = !sortAsc;
      else { sortCol = col; sortAsc = true; }
      renderTable();
    });
  });
}

