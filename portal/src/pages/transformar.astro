  setTimeout(() => { btnCopySql.textContent = 'Copiar'; }, 1500);
});
function stripLimit(sql) {
  return sql.replace(/\s+LIMIT\s+\d+\s*$/i, '');
}

function makeCsvBlob(rows, cols) {
  const sep = ';';
  const header = cols.join(sep);
  const body = rows.map(r =>
    cols.map(c => {
      const v = r[c]; if (v == null) return '';
      const s = String(v);
      return (s.includes(sep) || s.includes('"') || s.includes('\n'))
        ? `"${s.replace(/"/g, '""')}"` : s;
    }).join(sep)
  ).join('\n');
  return new Blob(['﻿' + header + '\n' + body], { type: 'text/csv;charset=utf-8;' });
}

btnCsv.addEventListener('click', async () => {
  if (!lastSQL || !lastCols.length) return;
  const sqlAll = stripLimit(lastSQL);
  const orig = btnCsv.textContent;
  btnCsv.textContent = '⏳…';
  btnCsv.disabled = true;
  try {
    const res  = await conn.query(sqlAll);
    const rows = res.toArray();
    const cols = res.schema.fields.map(f => f.name);
    const blob = makeCsvBlob(rows, cols);
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `ridab_${activeCrz?.id ?? 'export'}_${new Date().toISOString().slice(0, 10)}.csv`;
    a.click();
    resInfo.textContent = `${lastRows.length} exibidas · ${rows.length} exportadas`;
  } catch (e) {
    statusEl.textContent = 'Erro ao exportar: ' + e.message;
  } finally {
    btnCsv.textContent = orig;
    btnCsv.disabled = false;
  }
});

// ── CAMPOS LIVRES ──────────────────────────────────────────────
function renderFlTablePills() {
  const container = document.getElementById('fl-table-pills');
  container.innerHTML = TABLE_META.map(m =>
    `<button class="fl-tbl-pill" data-id="${m.id}" style="border-color:${m.color};color:${m.color}">${m.label}</button>`
  ).join('');
  container.querySelectorAll('.fl-tbl-pill').forEach(btn => {
    btn.addEventListener('click', () => flToggleTable(btn.dataset.id));
  });
}

async function flToggleTable(tableId) {
  if (flTables.has(tableId)) {
    flTables.delete(tableId);
    flChosen = flChosen.filter(c => c.tableId !== tableId);
  } else {
    flTables.add(tableId);
    if (!flTableCols[tableId] && ready) {
      try {
        const res = await conn.query(`DESCRIBE SELECT * FROM ${tableId}`);
        flTableCols[tableId] = res.toArray().map(r => ({
          name: String(r.column_name),
          type: String(r.column_type),
        }));
      } catch (e) {
        console.warn('DESCRIBE failed for', tableId, e);
        flTableCols[tableId] = [];
      }
    }
  }
  renderFlPanel();
}

function renderFlPanel() {
  // Toggle pill active state
  document.querySelectorAll('.fl-tbl-pill').forEach(p => {
    p.classList.toggle('fl-tbl-pill--active', flTables.has(p.dataset.id));
  });

  const hasTables  = flTables.size > 0;
  const hasChosen  = flChosen.length > 0;
  document.getElementById('fl-cols-area').style.display    = hasTables ? 'grid' : 'none';
  document.getElementById('fl-filters-area').style.display = hasChosen ? 'block' : 'none';
  document.getElementById('fl-controls').style.display     = hasChosen ? 'flex'  : 'none';

  if (!hasTables) return;

  // Available columns
  const colList = document.getElementById('fl-col-list');
  colList.innerHTML = '';
  for (const tid of flTables) {
    const meta = TABLE_META.find(m => m.id === tid);
    const cols = flTableCols[tid] || [];
    cols.forEach(c => {
      const active = flChosen.some(x => x.tableId === tid && x.col === c.name);
      const btn = document.createElement('button');
      btn.className = 'fl-col-chip' + (active ? ' fl-col-chip--active' : '');
      btn.title = `${c.name} · ${c.type}`;
      btn.innerHTML = `<span class="fl-col-alias" style="color:${meta.color}">${meta.alias}.</span>${c.name}`;
      btn.addEventListener('click', () => {
        if (active) {
          flChosen = flChosen.filter(x => !(x.tableId === tid && x.col === c.name));
        } else {
          flChosen.push({ tableId: tid, alias: meta.alias, col: c.name });
        }
        renderFlPanel();
      });
      colList.appendChild(btn);
    });
  }

  // Chosen columns
  const chosenEl = document.getElementById('fl-chosen');
  if (flChosen.length) {
    chosenEl.innerHTML = flChosen.map((c, i) =>
      `<div class="fl-sel-chip">
        <span class="fl-col-alias">${c.alias}.</span>${c.col}
        <button class="fl-sel-rm" data-i="${i}">×</button>
      </div>`
    ).join('');
    chosenEl.querySelectorAll('.fl-sel-rm').forEach(btn => {
      btn.addEventListener('click', () => {
        flChosen.splice(+btn.dataset.i, 1);
        renderFlPanel();
      });
    });
  } else {
    chosenEl.innerHTML = '<span class="fl-empty">Nenhuma coluna adicionada</span>';
  }

  renderFlFilters();
}

function allFlColKeys() {
  const keys = [];
  for (const tid of flTables) {
    const meta = TABLE_META.find(m => m.id === tid);
    (flTableCols[tid] || []).forEach(c => keys.push(`${meta.alias}.${c.name}`));
  }
  return keys;
}

function renderFlFilters() {
  const area = document.getElementById('fl-filter-rows');
  if (!area) return;
  const cols = allFlColKeys();
  area.innerHTML = flFilters.map((f, i) => {
    const colOpts = cols.map(c =>
      `<option value="${c}"${f.col === c ? ' selected' : ''}>${c}</option>`
    ).join('');
    const needsVal = f.op !== 'IS NOT NULL' && f.op !== 'IS NULL';
    return `<div class="fl-filter-row">
      <select class="fl-f-col" data-i="${i}">${colOpts}</select>
      <select class="fl-f-op" data-i="${i}">
        <option value="="${f.op==='='?' selected':''}>= igual</option>
        <option value="!="${f.op==='!='?' selected':''}>≠ diferente</option>
        <option value="ILIKE"${f.op==='ILIKE'?' selected':''}>contém</option>
        <option value=">"${f.op==='>'?' selected':''}>&gt; maior</option>
        <option value="<"${f.op==='<'?' selected':''}>&lt; menor</option>
        <option value="IS NOT NULL"${f.op==='IS NOT NULL'?' selected':''}>não nulo</option>
      </select>
      ${needsVal ? `<input class="fl-f-val" data-i="${i}" value="${esc(f.val ?? '')}" placeholder="valor">` : ''}
      <button class="fl-f-rm" data-i="${i}">×</button>
    </div>`;
  }).join('');

  area.querySelectorAll('.fl-f-col').forEach(el => el.addEventListener('change', () => {
    flFilters[+el.dataset.i].col = el.value; renderFlFilters();
  }));
  area.querySelectorAll('.fl-f-op').forEach(el => el.addEventListener('change', () => {
    flFilters[+el.dataset.i].op = el.value; renderFlFilters();
  }));
  area.querySelectorAll('.fl-f-val').forEach(el => el.addEventListener('input', () => {
    flFilters[+el.dataset.i].val = el.value;
  }));
  area.querySelectorAll('.fl-f-rm').forEach(btn => btn.addEventListener('click', () => {
    flFilters.splice(+btn.dataset.i, 1); renderFlFilters();
  }));
}

document.getElementById('fl-add-filter').addEventListener('click', () => {
  const cols = allFlColKeys();
  flFilters.push({ col: cols[0] ?? '', op: 'IS NOT NULL', val: '' });
  renderFlFilters();
});

// Limit chips
document.getElementById('fl-limit-chips').addEventListener('click', e => {
  const btn = e.target.closest('.lchip');
  if (!btn) return;
  flLimit = +btn.dataset.n;
  document.querySelectorAll('.lchip').forEach(b => b.classList.remove('lchip--active'));
  btn.classList.add('lchip--active');
});

document.getElementById('fl-run').addEventListener('click', () => {
  if (!ready) return;
  refBar.style.display = 'none';
  resArea.style.display = 'block';
  runQuery();
});

// ── BUILD CAMPOS SQL ───────────────────────────────────────────
function buildCamposSQL() {
  if (!flChosen.length) return null;
  const tables = [...flTables];

  const selectCols = flChosen.map(c => `${c.alias}.${c.col}`).join(',\n  ');
  const { from, ctes } = buildFromClause(tables);

  const filterClauses = flFilters.map(f => {
    if (!f.col) return null;
    if (f.op === 'IS NOT NULL') return `${f.col} IS NOT NULL`;
    if (f.op === 'IS NULL')     return `${f.col} IS NULL`;
    const isNum = !isNaN(f.val) && f.val !== '';
    const valExpr = isNum ? f.val : `'${esc(f.val)}'`;
    if (f.op === 'ILIKE') return `${f.col} ILIKE '%${esc(f.val)}%'`;
    return `${f.col} ${f.op} ${valExpr}`;
  }).filter(Boolean);

  const whereClause = filterClauses.length ? `WHERE ${filterClauses.join('\n  AND ')}` : '';
  const ctePrefix   = ctes ? `${ctes}\n` : '';

  return `${ctePrefix}SELECT\n  ${selectCols}\n${from}\n${whereClause}\nLIMIT ${flLimit}`;
}

function buildFromClause(tables) {
  if (tables.length === 0) return { from: '', ctes: null };

  if (tables.length === 1) {
    const meta = TABLE_META.find(m => m.id === tables[0]);
    return { from: `FROM ${tables[0]} ${meta.alias}`, ctes: null };
  }

  const hasObras     = tables.includes('obras');
  const hasBilh      = tables.includes('bilheteria_por_filme_ano');
  const hasDir       = tables.includes('diretores_obras');
  const hasProd      = tables.includes('produtores_obras');
  const hasFSA       = tables.includes('fomento_fsa');
  const hasRen       = tables.includes('renuncia_fiscal');
  const hasAtasFest  = tables.includes('fsa_atas_festivais');
  const hasAtasRes   = tables.includes('fsa_atas_resultados');

  const joins = [];
  let ctes    = null;
  let from    = 'FROM obras o';

  if ((hasAtasFest || hasAtasRes) && !hasObras && !hasBilh && !hasDir && !hasProd && !hasFSA && !hasRen) {
    if (hasAtasFest && hasAtasRes) {
      return {
        from: `FROM fsa_atas_festivais af
LEFT JOIN fsa_atas_resultados ar
  ON COALESCE(af.cpb, '') = COALESCE(ar.cpb, '')
  AND af.chave_titulo = ar.chave_titulo
  AND af.ano_chamada = ar.ano_chamada`,
        ctes: null,
      };
    }
    return { from: hasAtasFest ? 'FROM fsa_atas_festivais af' : 'FROM fsa_atas_resultados ar', ctes: null };
  }

  // Direct CPB joins
  if (hasBilh)  joins.push(`INNER JOIN bilheteria_por_filme_ano b ON b.cpb_roe = o.cpb AND b.cpb_roe LIKE 'B%'`);
  if (hasDir)   joins.push(`LEFT JOIN diretores_obras d ON d.cpb = o.cpb`);
  if (hasProd)  joins.push(`LEFT JOIN produtores_obras p ON p.cpb = o.cpb`);

  // Proxy title joins
  if (hasFSA || hasRen) {
    let cteStr = `WITH o_n AS (\n  SELECT *, lower(regexp_replace(titulo_original,'[^a-zA-Z0-9 ]','','g')) AS _tn\n  FROM obras\n)`;
    if (hasFSA) {
      cteStr += `,\nf_n AS (\n  SELECT *, lower(regexp_replace(titulo_projeto,'[^a-zA-Z0-9 ]','','g')) AS _tn\n  FROM fomento_fsa\n)`;
      joins.push(`INNER JOIN f_n f ON f._tn = o._tn`);
    }
    if (hasRen) {
      cteStr += `,\nr_n AS (\n  SELECT *, lower(regexp_replace(titulo_projeto,'[^a-zA-Z0-9 ]','','g')) AS _tn\n  FROM renuncia_fiscal\n)`;
      joins.push(`INNER JOIN r_n r ON r._tn = o._tn`);
    }
    ctes = cteStr;
    from = `FROM o_n o`;
  }

  if (joins.length) from += '\n' + joins.join('\n');
  return { from, ctes };
}
</script>

