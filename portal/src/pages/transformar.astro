---
import Base from "../layouts/Base.astro";
const HF = "https://huggingface.co/datasets/riabr-dados/riab/resolve/main/cleaned";
---

<Base
  title="Transformar · Construtor"
  description="Monte tabelas cruzadas com os dados do audiovisual brasileiro — sem código, no browser."
>

<div class="tf">

  <!-- STATUS BAR -->
  <div class="tf-bar">
    <span class="tf-eyebrow">RIDAB · TRANSFORMAR</span>
    <div class="tf-status-row">
      <span class="tdot" id="tf-dot"></span>
      <span id="tf-status">Iniciando DuckDB…</span>
    </div>
    <button class="tf-clear-btn" id="btn-clear" disabled>↺ Limpar</button>
  </div>

  <!-- 3-PANEL LAYOUT -->
  <div class="tf-panels">

    <!-- LEFT: FIELD PICKER -->
    <aside class="tf-panel tf-panel--left" id="panel-fields">
      <div class="tfp-head">Campos</div>
      <div class="tf-tables" id="tf-tables">
        <div class="tf-skeleton">
          <div class="skel-row"></div><div class="skel-row skel-row--sm"></div>
          <div class="skel-row skel-row--sm"></div><div class="skel-row skel-row--sm"></div>
          <div class="skel-row" style="margin-top:12px"></div>
          <div class="skel-row skel-row--sm"></div><div class="skel-row skel-row--sm"></div>
        </div>
      </div>
    </aside>

    <!-- MIDDLE: CONFIG -->
    <div class="tf-panel tf-panel--mid" id="panel-config">
      <div class="tfp-head">Configuração</div>

      <div class="cfg-block">
        <div class="cfg-label">Agrupar por</div>
        <div class="cfg-dims" id="cfg-dims">
          <div class="cfg-hint" id="cfg-dims-hint">← Marque campos ao lado</div>
        </div>
      </div>

      <div class="cfg-block">
        <div class="cfg-label">Medir</div>
        <select class="cfg-select" id="cfg-fn">
          <option value="COUNT_STAR">COUNT — total de registros</option>
          <option value="SUM">SUM — soma</option>
          <option value="AVG">AVG — média</option>
          <option value="MAX">MAX — máximo</option>
          <option value="MIN">MIN — mínimo</option>
        </select>
        <select class="cfg-select cfg-select--col" id="cfg-col" style="display:none">
          <option value="">— escolha uma coluna numérica —</option>
        </select>
      </div>

      <div class="cfg-block">
        <div class="cfg-label-row">
          <span class="cfg-label">Filtros</span>
          <button class="cfg-add-btn" id="btn-add-filter" disabled>+ adicionar</button>
        </div>
        <div id="cfg-filters">
          <div class="cfg-hint">Nenhum — todos os registros</div>
        </div>
      </div>

      <div class="cfg-block cfg-block--join" id="cfg-join" style="display:none">
        <div class="cfg-label">Ligação detectada</div>
        <div id="cfg-join-info"></div>
      </div>

      <div class="cfg-run-wrap">
        <button class="cfg-run-btn" id="btn-run" disabled>
          <span id="run-icon">▶</span> Gerar tabela
        </button>
      </div>
    </div>

    <!-- RIGHT: RESULTS -->
    <div class="tf-panel tf-panel--right" id="panel-results">
      <div class="tfp-head tfp-head--results" id="results-head" style="display:none">
        <span class="res-count" id="res-count"></span>
        <div class="res-actions">
          <button class="res-btn" id="btn-toggle-chart">◫ Gráfico</button>
          <button class="res-btn" id="btn-csv">↓ CSV</button>
          <button class="res-btn" id="btn-sql">‹/› SQL</button>
        </div>
      </div>
      <div class="res-empty" id="res-empty">
        <div class="re-icon">⊞</div>
        <p class="re-text">Selecione campos e clique em <strong>Gerar tabela</strong></p>
      </div>
      <div class="sql-panel" id="sql-panel" style="display:none">
        <div class="sql-head">
          <span>SQL gerado · DuckDB</span>
          <button class="sql-copy" id="btn-copy-sql">Copiar</button>
        </div>
        <pre class="sql-pre" id="sql-pre"></pre>
      </div>
      <div class="chart-wrap" id="chart-wrap" style="display:none"></div>
      <div class="table-wrap" id="table-wrap"></div>
    </div>

  </div><!-- /tf-panels -->
</div><!-- /tf -->

</Base>

<!-- pass server var to client -->
<script define:vars={{ HF }}>
  window.__RIDAB_HF__ = HF;
</script>

<script type="module">
import * as duckdb from "https://cdn.jsdelivr.net/npm/@duckdb/duckdb-wasm@1.29.0/+esm";

const HF = window.__RIDAB_HF__;

// ── TABLE DEFINITIONS ──────────────────────────────────────────────────────
const TBLS = {
  obras: {
    label: 'Obras não-pub', src: 'ANCINE / SAV', alias: 'o', color: '#007a3c',
    view: 'obras', url: `${HF}/obras.parquet`,
    titleExpr: `lower(regexp_replace(TITULO_ORIGINAL,'[^a-zA-Z0-9 ]','','g'))`,
  },
  diretores: {
    label: 'Diretores de obras', src: 'ANCINE / SAV', alias: 'd', color: '#007a3c',
    view: 'diretores_obras', url: `${HF}/diretores_obras.parquet`,
  },
  produtores: {
    label: 'Produtores de obras', src: 'ANCINE / SAV', alias: 'p', color: '#007a3c',
    view: 'produtores_obras', url: `${HF}/produtores_obras.parquet`,
  },
  bilheteria: {
    label: 'Bilheteria agregada', src: 'ANCINE / OCA', alias: 'b', color: '#007a3c',
    view: 'bilheteria_por_filme_ano', url: `${HF}/bilheteria_por_filme_ano.parquet`,
    titleExpr: `lower(regexp_replace(TITULO_BRASIL,'[^a-zA-Z0-9 ]','','g'))`,
  },
  fsa: {
    label: 'Projetos FSA', src: 'ANCINE / FSA', alias: 'f', color: '#c8920a',
    view: 'fomento_fsa', url: `${HF}/fomento_fsa.parquet`,
    titleExpr: `lower(regexp_replace(TITULO_PROJETO,'[^a-zA-Z0-9 ]','','g'))`,
  },
  renuncia: {
    label: 'Renúncia fiscal', src: 'ANCINE', alias: 'r', color: '#1f3bb8',
    view: 'renuncia_fiscal', url: `${HF}/renuncia_fiscal.parquet`,
    titleExpr: `lower(regexp_replace(TITULO_PROJETO,'[^a-zA-Z0-9 ]','','g'))`,
  },
  lumiere: {
    label: 'Lumière Europa', src: 'Obs. Europeu', alias: 'l', color: '#1f3bb8',
    view: 'bilheteria_europa', url: `${HF}/bilheteria_europa.parquet`,
    titleExpr: `lower(regexp_replace("Original title",'[^a-zA-Z0-9 ]','','g'))`,
  },
};

// ── JOIN GRAPH (canonical key = sorted alphabetically) ─────────────────────
const JGRAPH = {
  'diretores-obras':  { type:'exact', conf:3, label:'CPB exato',
    join: (a) => `LEFT JOIN diretores_obras ${a.diretores} ON ${a.diretores}.CPB = ${a.obras}.CPB` },
  'obras-produtores': { type:'exact', conf:3, label:'CPB exato',
    join: (a) => `LEFT JOIN produtores_obras ${a.produtores} ON ${a.produtores}.CPB = ${a.obras}.CPB` },
  'bilheteria-obras': { type:'exact', conf:3, label:'CPB exato',
    join: (a) => `LEFT JOIN bilheteria_por_filme_ano ${a.bilheteria} ON ${a.bilheteria}.CPB_ROE = ${a.obras}.CPB AND ${a.bilheteria}.CPB_ROE LIKE 'B%'` },
  'fsa-obras':        { type:'proxy', conf:2, label:'proxy título', cteA:'obras', cteB:'fsa' },
  'obras-renuncia':   { type:'proxy', conf:2, label:'proxy título', cteA:'obras', cteB:'renuncia' },
  'lumiere-obras':    { type:'proxy', conf:2, label:'proxy título', cteA:'obras', cteB:'lumiere' },
  'agentes-produtores': { type:'exact', conf:3, label:'CNPJ exato',
    join: (a) => `LEFT JOIN agentes_economicos ${a.agentes} ON ${a.agentes}.CNPJ = ${a.produtores}.CNPJ_PRODUTOR` },
  'bilheteria-lumiere': { type:'proxy', conf:2, label:'proxy título', cteA:'bilheteria', cteB:'lumiere' },
};

const JTYPE_COLOR = { exact:'#007a3c', proxy:'#c8920a' };
const JTYPE_LABEL = { exact:'join exato', proxy:'proxy título' };

// ── STATE ──────────────────────────────────────────────────────────────────
let db, conn, ready = false;
let selectedCols = [];   // {tbl, col, isNum, qualified, displayLabel}
let allNumCols   = [];
let filterCount  = 0;
let lastSQL = '', lastRows = [], lastColNames = [];
let showChart = false;

// ── DOM ────────────────────────────────────────────────────────────────────
const dot      = document.getElementById('tf-dot');
const statusEl = document.getElementById('tf-status');
const btnClear = document.getElementById('btn-clear');
const cfgDims  = document.getElementById('cfg-dims');
const cfgDimsHint = document.getElementById('cfg-dims-hint');
const cfgFn    = document.getElementById('cfg-fn');
const cfgCol   = document.getElementById('cfg-col');
const cfgJoin  = document.getElementById('cfg-join');
const cfgJoinInfo = document.getElementById('cfg-join-info');
const cfgFilters  = document.getElementById('cfg-filters');
const btnAddFilter = document.getElementById('btn-add-filter');
const btnRun   = document.getElementById('btn-run');
const runIcon  = document.getElementById('run-icon');
const resEmpty = document.getElementById('res-empty');
const resHead  = document.getElementById('results-head');
const resCount = document.getElementById('res-count');
const tableWrap= document.getElementById('table-wrap');
const chartWrap= document.getElementById('chart-wrap');
const sqlPanel = document.getElementById('sql-panel');
const sqlPre   = document.getElementById('sql-pre');
const btnToggleChart = document.getElementById('btn-toggle-chart');
const btnCsv   = document.getElementById('btn-csv');
const btnSql   = document.getElementById('btn-sql');
const btnCopySql = document.getElementById('btn-copy-sql');

// ── INIT DUCKDB ────────────────────────────────────────────────────────────
(async () => {
  try {
    const bundles = duckdb.getJsDelivrBundles();
    const bundle  = await duckdb.selectBundle(bundles);
    const workerUrl = URL.createObjectURL(
      new Blob([`importScripts("${bundle.mainWorker}");`], {type:'text/javascript'})
    );
    db = new duckdb.AsyncDuckDB(new duckdb.ConsoleLogger(), new Worker(workerUrl));
    await db.instantiate(bundle.mainModule, bundle.pthreadWorker);
    conn = await db.connect();
    await conn.query("INSTALL httpfs; LOAD httpfs; SET s3_region='us-east-1';");

    statusEl.textContent = `Registrando ${Object.keys(TBLS).length} tabelas…`;

    // Create views + DESCRIBE
    for (const [id, t] of Object.entries(TBLS)) {
      try {
        await conn.query(`CREATE OR REPLACE VIEW ${t.view} AS SELECT * FROM '${t.url}'`);
        const desc = await conn.query(`DESCRIBE ${t.view}`);
        t.cols = desc.toArray().map(r => ({
          name: r.column_name,
          isNum: /int|float|double|decimal|hugeint|bigint|real/i.test(r.column_type),
        }));
        t.ok = true;
      } catch(e) {
        t.ok = false; t.cols = [];
        console.warn(`[RIDAB] ${id}: ${e.message}`);
      }
    }

    dot.className = 'tdot tdot--ok';
    statusEl.textContent = `${Object.values(TBLS).filter(t=>t.ok).length} tabelas prontas`;
    ready = true;
    btnAddFilter.disabled = false;
    btnClear.disabled = false;
    renderFieldPicker();
  } catch(e) {
    dot.className = 'tdot tdot--err';
    statusEl.textContent = 'Erro ao iniciar: ' + e.message;
  }
})();

// ── FIELD PICKER ───────────────────────────────────────────────────────────
function renderFieldPicker() {
  const wrap = document.getElementById('tf-tables');
  wrap.innerHTML = Object.entries(TBLS).map(([id, t]) => {
    if (!t.ok) return '';
    return `
    <div class="t-card" data-tid="${id}">
      <button class="t-card-head" data-tid="${id}">
        <span class="t-dot" style="background:${t.color}"></span>
        <span class="t-label">${t.label}</span>
        <span class="t-src">${t.src}</span>
        <span class="t-chevron">›</span>
      </button>
      <div class="t-fields" id="fields-${id}" style="display:none">
        ${t.cols.map(c => `
          <label class="t-field" data-tid="${id}" data-col="${c.name}">
            <input type="checkbox" class="t-cb" data-tid="${id}" data-col="${c.name}" data-num="${c.isNum}">
            <span class="t-col-name">${c.name}</span>
            ${c.isNum ? '<span class="t-num-badge">num</span>' : ''}
          </label>`).join('')}
      </div>
    </div>`;
  }).join('');

  // Accordion toggle
  wrap.querySelectorAll('.t-card-head').forEach(btn => {
    btn.addEventListener('click', () => {
      const tid = btn.dataset.tid;
      const fields = document.getElementById(`fields-${tid}`);
      const chevron = btn.querySelector('.t-chevron');
      const open = fields.style.display !== 'none';
      fields.style.display = open ? 'none' : 'block';
      chevron.textContent = open ? '›' : '⌄';
      btn.classList.toggle('t-card-head--open', !open);
    });
  });

  // Checkbox selection
  wrap.querySelectorAll('.t-cb').forEach(cb => {
    cb.addEventListener('change', () => {
      const {tid, col, num} = cb.dataset;
      if (cb.checked) {
        if (!selectedCols.find(x => x.tbl===tid && x.col===col)) {
          selectedCols.push({
            tbl: tid, col, isNum: num==='true',
            qualified: `${TBLS[tid].alias}."${col}"`,
            displayLabel: `${col}`,
            tableLabel: TBLS[tid].label,
          });
        }
      } else {
        selectedCols = selectedCols.filter(x => !(x.tbl===tid && x.col===col));
      }
      syncState();
    });
  });
}

// ── SYNC STATE (called on any change) ─────────────────────────────────────
function syncState() {
  // Update dims pills
  if (selectedCols.length === 0) {
    cfgDims.innerHTML = '<div class="cfg-hint" id="cfg-dims-hint">← Marque campos ao lado</div>';
  } else {
    cfgDims.innerHTML = selectedCols.map((c, i) => `
      <div class="dim-pill" data-i="${i}">
        <span class="dim-pill-tbl" style="color:${TBLS[c.tbl].color}">${TBLS[c.tbl].alias}.</span><span>${c.col}</span>
        <button class="dim-pill-rm" data-i="${i}">×</button>
      </div>`).join('');
    cfgDims.querySelectorAll('.dim-pill-rm').forEach(btn => {
      btn.addEventListener('click', () => {
        const i = +btn.dataset.i;
        const removed = selectedCols[i];
        selectedCols.splice(i, 1);
        // uncheck the checkbox
        const cb = document.querySelector(`.t-cb[data-tid="${removed.tbl}"][data-col="${removed.col}"]`);
        if (cb) cb.checked = false;
        syncState();
      });
    });
  }

  // Update numeric column select
  allNumCols = selectedCols.filter(c => c.isNum);
  const needsCol = cfgFn.value !== 'COUNT_STAR';
  cfgCol.style.display = needsCol ? 'block' : 'none';
  if (needsCol) {
    const prev = cfgCol.value;
    cfgCol.innerHTML = `<option value="">— coluna numérica —</option>` +
      allNumCols.map(c => `<option value="${c.qualified}" ${c.qualified===prev?'selected':''}>${c.tableLabel} · ${c.col}</option>`).join('');
  }

  // Update join status
  const activeTbls = [...new Set(selectedCols.map(c => c.tbl))];
  if (activeTbls.length > 1) {
    const jinfo = detectJoins(activeTbls);
    cfgJoin.style.display = 'block';
    cfgJoinInfo.innerHTML = renderJoinInfo(jinfo);
  } else {
    cfgJoin.style.display = 'none';
  }

  // Enable run button
  const canRun = ready && selectedCols.length > 0 &&
    (cfgFn.value === 'COUNT_STAR' || cfgCol.value !== '');
  btnRun.disabled = !canRun;
}

// ── JOIN DETECTION ─────────────────────────────────────────────────────────
function edgeKey(a, b) { return [a,b].sort().join('-'); }

function detectJoins(activeTbls) {
  if (activeTbls.length <= 1) return { ok:true, edges:[], unresolved:[] };

  const connected = new Set([activeTbls[0]]);
  const edges = [];
  const remaining = new Set(activeTbls.slice(1));

  let progress = true;
  while (progress && remaining.size > 0) {
    progress = false;
    for (const t of [...remaining]) {
      for (const c of [...connected]) {
        const key = edgeKey(c, t);
        const edge = JGRAPH[key];
        if (edge) {
          edges.push({ from:c, to:t, key, ...edge });
          connected.add(t);
          remaining.delete(t);
          progress = true;
          break;
        }
      }
      if (progress) break;
    }
  }

  return { ok: remaining.size === 0, edges, unresolved: [...remaining] };
}

function renderJoinInfo(jinfo) {
  if (!jinfo.ok) {
    return `<div class="join-err">⚠ Sem ligação direta: ${jinfo.unresolved.map(t=>TBLS[t]?.label||t).join(', ')}</div>`;
  }
  return jinfo.edges.map(e => {
    const col = JTYPE_COLOR[e.type];
    return `<div class="join-row">
      <span class="join-from">${TBLS[e.from]?.label}</span>
      <span class="join-arrow" style="color:${col}">→</span>
      <span class="join-to">${TBLS[e.to]?.label}</span>
      <span class="join-type-badge" style="color:${col}">${e.label}</span>
    </div>`;
  }).join('');
}

// ── SQL BUILDER ────────────────────────────────────────────────────────────
function buildSQL() {
  const activeTbls = [...new Set(selectedCols.map(c => c.tbl))];
  const jinfo = detectJoins(activeTbls);
  if (!jinfo.ok) return null;

  const a = Object.fromEntries(Object.entries(TBLS).map(([id,t]) => [id, t.alias]));

  // Determine if any proxy joins are needed
  const proxyEdges = jinfo.edges.filter(e => e.type === 'proxy');
  const cteTbls = new Set(proxyEdges.flatMap(e => [e.cteA, e.cteB]));

  // CTEs for proxy joins
  const ctes = [...cteTbls].map(tid => {
    const t = TBLS[tid];
    return `${tid}_n AS (\n  SELECT *, ${t.titleExpr} AS _tn\n  FROM ${t.view}\n)`;
  });

  // Primary table (anchor — prefer obras)
  const primary = activeTbls.includes('obras') ? 'obras'
    : activeTbls.includes('produtores') ? 'produtores'
    : activeTbls.includes('bilheteria') ? 'bilheteria'
    : activeTbls[0];

  const primaryRef = cteTbls.has(primary)
    ? `${primary}_n ${a[primary]}`
    : `${TBLS[primary].view} ${a[primary]}`;

  // JOIN clauses
  const joinClauses = jinfo.edges.map(e => {
    if (e.type === 'exact' && e.join) return e.join(a);
    // proxy
    const toRef = cteTbls.has(e.to) ? `${e.to}_n` : TBLS[e.to].view;
    const fromAlias = cteTbls.has(e.from) ? a[e.from] : a[e.from];
    return `LEFT JOIN ${toRef} ${a[e.to]} ON ${a[e.to]}._tn = ${fromAlias}._tn`;
  });

  // SELECT
  const selectDims = selectedCols.map(c => {
    const ref = cteTbls.has(c.tbl) ? a[c.tbl] : a[c.tbl];
    return `  ${ref}."${c.col}" AS "${c.tableLabel} · ${c.col}"`;
  }).join(',\n');

  const fn = cfgFn.value;
  const metricExpr = fn === 'COUNT_STAR'
    ? '  COUNT(*) AS _total'
    : `  ${fn}(${cfgCol.value}) AS _valor`;

  // WHERE (filters)
  const whereClauses = collectFilterClauses();
  const whereSQL = whereClauses.length
    ? `\nWHERE\n  ${whereClauses.join('\n  AND ')}` : '';

  // GROUP BY (1-based positions)
  const groupBy = selectedCols.map((_, i) => i + 1).join(', ');
  const orderMetric = fn === 'COUNT_STAR' ? '_total' : '_valor';

  const withSQL = ctes.length ? `WITH\n${ctes.join(',\n')}\n` : '';
  const fromSQL = [primaryRef, ...joinClauses].join('\n');

  return `${withSQL}SELECT\n${selectDims},\n${metricExpr}\nFROM ${fromSQL}${whereSQL}\nGROUP BY ${groupBy}\nORDER BY ${orderMetric} DESC\nLIMIT 500;`;
}

// ── FILTERS ────────────────────────────────────────────────────────────────
cfgFn.addEventListener('change', () => {
  syncState();
});
cfgCol.addEventListener('change', syncState);

btnAddFilter.addEventListener('click', () => {
  if (!ready || selectedCols.length === 0) return;
  const id = ++filterCount;
  const colOpts = selectedCols.map(c =>
    `<option value="${c.qualified}">${c.tableLabel} · ${c.col}</option>`).join('');

  // remove hint
  const hint = cfgFilters.querySelector('.cfg-hint');
  if (hint) hint.remove();

  const row = document.createElement('div');
  row.className = 'filter-row';
  row.dataset.fid = id;
  row.innerHTML = `
    <select class="f-col">${colOpts}</select>
    <select class="f-op">
      <option value="=">=</option><option value="!=">≠</option>
      <option value="CONTAINS">contém</option>
      <option value=">">&gt;</option><option value=">=">&gt;=</option>
      <option value="<">&lt;</option><option value="<=">&lt;=</option>
      <option value="IS NULL">é nulo</option><option value="IS NOT NULL">não é nulo</option>
    </select>
    <input class="f-val" type="text" placeholder="valor">
    <button class="f-rm">×</button>`;

  row.querySelector('.f-op').addEventListener('change', e => {
    row.querySelector('.f-val').style.display =
      ['IS NULL','IS NOT NULL'].includes(e.target.value) ? 'none' : '';
  });
  row.querySelector('.f-rm').addEventListener('click', () => {
    row.remove();
    if (!cfgFilters.querySelector('.filter-row'))
      cfgFilters.innerHTML = '<div class="cfg-hint">Nenhum — todos os registros</div>';
  });
  cfgFilters.appendChild(row);
});

function collectFilterClauses() {
  return [...cfgFilters.querySelectorAll('.filter-row')].map(row => {
    const col = row.querySelector('.f-col').value;
    const op  = row.querySelector('.f-op').value;
    const val = row.querySelector('.f-val').value.trim();
    if (!col) return null;
    if (op === 'IS NULL' || op === 'IS NOT NULL') return `${col} ${op}`;
    if (op === 'CONTAINS') return `${col} ILIKE '%${val.replace(/'/g,"''")}%'`;
    const quoted = isNaN(val) || val==='' ? `'${val.replace(/'/g,"''")}'` : val;
    return `${col} ${op} ${quoted}`;
  }).filter(Boolean);
}

// ── RUN ────────────────────────────────────────────────────────────────────
btnRun.addEventListener('click', run);

async function run() {
  if (!ready || selectedCols.length === 0) return;
  const sql = buildSQL();
  if (!sql) { statusEl.textContent = 'Sem ligação válida entre as tabelas selecionadas.'; return; }

  lastSQL = sql;
  btnRun.disabled = true;
  runIcon.textContent = '◌';
  statusEl.textContent = 'Executando…';
  resEmpty.style.display = 'none';
  sqlPanel.style.display = 'none';
  chartWrap.style.display = 'none';
  tableWrap.innerHTML = '';

  try {
    const t0  = Date.now();
    const res = await conn.query(sql);
    const ms  = Date.now() - t0;
    lastRows     = res.toArray();
    lastColNames = res.schema.fields.map(f => f.name);

    sqlPre.textContent = sql;
    renderResults();
    statusEl.textContent = `${lastRows.length} linhas · ${ms}ms`;
    resHead.style.display = 'flex';
    resCount.textContent = `${lastRows.length} linhas · ${ms}ms`;
  } catch(e) {
    statusEl.textContent = 'Erro: ' + e.message;
    tableWrap.innerHTML = `<div class="query-err">${e.message}</div>`;
    resEmpty.style.display = 'none';
    resHead.style.display = 'none';
  } finally {
    btnRun.disabled = selectedCols.length === 0;
    runIcon.textContent = '▶';
  }
}

// ── RENDER RESULTS ─────────────────────────────────────────────────────────
function renderResults() {
  if (showChart) renderChart();
  else renderTable();
}

function renderTable() {
  if (!lastRows.length) {
    tableWrap.innerHTML = '<div class="query-err">Nenhum resultado.</div>';
    return;
  }
  const metricCol = lastColNames[lastColNames.length - 1];
  const vals = lastRows.map(r => Number(r[metricCol]) || 0);
  const maxVal = Math.max(...vals, 1);

  let html = `<table class="res-tbl"><thead><tr>`;
  lastColNames.forEach(c => { html += `<th>${c}</th>`; });
  html += `</tr></thead><tbody>`;
  lastRows.forEach(row => {
    html += `<tr>`;
    lastColNames.forEach((col, i) => {
      const v = row[col];
      const disp = v == null ? '—' : String(v);
      if (i === lastColNames.length - 1 && maxVal > 0) {
        const pct = Math.round((Number(v) / maxVal) * 100);
        html += `<td class="res-metric">
          <div class="res-bar-wrap">
            <div class="res-bar" style="width:${pct}%"></div>
            <span>${Number.isInteger(Number(v))
              ? Number(v).toLocaleString('pt-BR')
              : Number(v).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2})
            }</span>
          </div></td>`;
      } else {
        html += `<td title="${disp}">${disp}</td>`;
      }
    });
    html += `</tr>`;
  });
  html += `</tbody></table>`;
  tableWrap.innerHTML = html;
  chartWrap.style.display = 'none';
  tableWrap.style.display = '';
}

function renderChart() {
  if (!lastRows.length) return;
  const metricCol = lastColNames[lastColNames.length - 1];
  const labelCol  = lastColNames[0];
  const top = lastRows.slice(0, 30);
  const vals = top.map(r => Number(r[metricCol]) || 0);
  const maxVal = Math.max(...vals, 1);

  const bars = top.map(r => {
    const v   = Number(r[metricCol]) || 0;
    const lbl = String(r[labelCol] ?? '—');
    const pct = (v / maxVal) * 100;
    const fmt = Number.isInteger(v) ? v.toLocaleString('pt-BR') : v.toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2});
    return `<div class="cbar-row">
      <div class="cbar-label" title="${lbl}">${lbl}</div>
      <div class="cbar-track">
        <div class="cbar-fill" style="width:${pct}%"></div>
      </div>
      <div class="cbar-val">${fmt}</div>
    </div>`;
  }).join('');

  chartWrap.innerHTML = `<div class="chart-inner">${bars}</div>`;
  chartWrap.style.display = 'block';
  tableWrap.style.display = 'none';
}

// ── TOOLBAR EVENTS ─────────────────────────────────────────────────────────
btnToggleChart.addEventListener('click', () => {
  showChart = !showChart;
  btnToggleChart.classList.toggle('res-btn--active', showChart);
  renderResults();
});

btnSql.addEventListener('click', () => {
  const vis = sqlPanel.style.display !== 'none';
  sqlPanel.style.display = vis ? 'none' : 'block';
  btnSql.classList.toggle('res-btn--active', !vis);
});

btnCopySql.addEventListener('click', async () => {
  await navigator.clipboard.writeText(sqlPre.textContent);
  btnCopySql.textContent = 'Copiado!';
  setTimeout(() => { btnCopySql.textContent = 'Copiar'; }, 1500);
});

btnCsv.addEventListener('click', () => {
  if (!lastRows.length) return;
  const sep = ';';
  const header = lastColNames.join(sep);
  const rows = lastRows.map(r =>
    lastColNames.map(c => {
      const v = r[c];
      if (v == null) return '';
      const s = String(v);
      return s.includes(sep) || s.includes('"') || s.includes('\n')
        ? `"${s.replace(/"/g,'""')}"` : s;
    }).join(sep)
  ).join('\n');
  const blob = new Blob(['﻿' + header + '\n' + rows], {type:'text/csv;charset=utf-8;'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `ridab_${Date.now()}.csv`;
  a.click();
});

btnClear.addEventListener('click', () => {
  selectedCols = [];
  document.querySelectorAll('.t-cb').forEach(cb => { cb.checked = false; });
  cfgFilters.innerHTML = '<div class="cfg-hint">Nenhum — todos os registros</div>';
  resEmpty.style.display = 'flex';
  resHead.style.display = 'none';
  tableWrap.innerHTML = '';
  chartWrap.innerHTML = '';
  chartWrap.style.display = 'none';
  sqlPanel.style.display = 'none';
  showChart = false;
  btnToggleChart.classList.remove('res-btn--active');
  btnSql.classList.remove('res-btn--active');
  syncState();
});
</script>

