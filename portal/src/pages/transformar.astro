const statusEl   = document.getElementById('tf-status');
const crGrid     = document.getElementById('cr-grid');
const resArea    = document.getElementById('res-area');
const resLoading = document.getElementById('res-loading');
const loadingMsg = document.getElementById('loading-msg');
const refBar     = document.getElementById('ref-bar');
const refDim     = document.getElementById('ref-dim');
const refMetric  = document.getElementById('ref-metric');
const refMetricGroup = document.getElementById('ref-metric-group');
const refSearch  = document.getElementById('ref-search');
const btnRerun   = document.getElementById('btn-rerun');
const resInfo    = document.getElementById('res-info');
const btnChart   = document.getElementById('btn-chart');
const btnTable   = document.getElementById('btn-table');
const btnSql     = document.getElementById('btn-sql');
const btnCsv     = document.getElementById('btn-csv');
const sqlPanel   = document.getElementById('sql-panel');
const sqlPre     = document.getElementById('sql-pre');
const btnCopySql = document.getElementById('btn-copy-sql');
const ctBar      = document.getElementById('chart-type-bar');
const viewChart  = document.getElementById('view-chart');
const viewTable  = document.getElementById('view-table');

// ── INIT ───────────────────────────────────────────────────────
(async () => {
  try {
    const bundles = duckdb.getJsDelivrBundles();
    const bundle  = await duckdb.selectBundle(bundles);
    const wUrl = URL.createObjectURL(
      new Blob([`importScripts("${bundle.mainWorker}");`], { type: 'text/javascript' })
    );
    db = new duckdb.AsyncDuckDB(new duckdb.ConsoleLogger(), new Worker(wUrl));
    await db.instantiate(bundle.mainModule, bundle.pthreadWorker);
    conn = await db.connect();
    await conn.query("INSTALL httpfs; LOAD httpfs; SET s3_region='us-east-1';");

    const views = {
      obras:                    `${HF}/obras.parquet`,
      diretores_obras:          `${HF}/diretores_obras.parquet`,
      produtores_obras:         `${HF}/produtores_obras.parquet`,
      bilheteria_por_filme_ano: `${HF}/bilheteria_por_filme_ano.parquet`,
      fomento_fsa:              `${HF}/fomento_fsa.parquet`,
      condecine_arrecadacao:    `${HF}/condecine_arrecadacao.parquet`,
      fomento_fluxos_financeiros: `${HF}/fomento_fluxos_financeiros.parquet`,
      renuncia_fiscal:          `${HF}/renuncia_fiscal.parquet`,
      fsa_atas_festivais:       `${HF}/fsa_atas_festivais.parquet`,
      fsa_atas_resultados:      `${HF}/fsa_atas_resultados.parquet`,
      embrafilme_exibicao_territorio_ano: `${HF}/embrafilme_exibicao_territorio_ano.parquet`,
      pib_audiovisual_fontes:   `${HF}/pib_audiovisual_fontes.parquet`,
      rais_emprego_audiovisual_fontes: `${HF}/rais_emprego_audiovisual_fontes.parquet`,
      comercio_exterior_servicos_audiovisuais_fontes: `${HF}/comercio_exterior_servicos_audiovisuais_fontes.parquet`,
      comex_bens_audiovisuais_fontes: `${HF}/comex_bens_audiovisuais_fontes.parquet`,
      diversidade_audiovisual_fontes: `${HF}/diversidade_audiovisual_fontes.parquet`,
      bilheteria_europa:        `${HF}/bilheteria_europa.parquet`,
    };
    for (const [name, url] of Object.entries(views)) {
      await conn.query(`CREATE OR REPLACE VIEW ${name} AS SELECT * FROM '${url}'`);
    }

    dot.className = 'tdot tdot--ok';
    statusEl.textContent = `${Object.keys(views).length} tabelas prontas`;
    ready = true;
    renderCards();
    renderFlTablePills();
  } catch (e) {
    dot.className = 'tdot tdot--err';
    statusEl.textContent = 'Erro ao iniciar: ' + e.message;
  }
})();

// ── MODE TABS ──────────────────────────────────────────────────
document.getElementById('mtab-conexoes').addEventListener('click', () => switchMode('conexoes'));
document.getElementById('mtab-campos').addEventListener('click',   () => switchMode('campos'));

function switchMode(mode) {
  appMode = mode;
  document.getElementById('mtab-conexoes').classList.toggle('mtab--active', mode === 'conexoes');
  document.getElementById('mtab-campos').classList.toggle('mtab--active', mode === 'campos');
  document.getElementById('panel-conexoes').style.display = mode === 'conexoes' ? 'block' : 'none';
  document.getElementById('panel-campos').style.display   = mode === 'campos'   ? 'block' : 'none';
  refBar.style.display = mode === 'conexoes' ? 'flex' : 'none';
  resArea.style.display = 'none';
  sqlPanel.style.display = 'none';
  btnSql.classList.remove('res-btn--active');
}

// ── RENDER CARDS ───────────────────────────────────────────────
function renderCards() {
  crGrid.innerHTML = CRZ.map(c => {
    const tablePills = c.tables.map(t =>
      `<span class="cr-tbl-pill" style="border-color:${t.color};color:${t.color}">${t.name}</span>`
    ).join('<span class="cr-plus">+</span>');
    const joinBadge = c.join
      ? `<span class="cr-join-badge" style="color:${JOIN_COLOR[c.join.type]};border-color:${JOIN_COLOR[c.join.type]}20;background:${JOIN_COLOR[c.join.type]}10">${c.join.label}</span>`
      : '';
    return `<button class="cr-card" data-id="${c.id}" ${!ready ? 'disabled' : ''}>
      <div class="cr-card-top"><div class="cr-tables">${tablePills}</div>${joinBadge}</div>
      <div class="cr-card-icon">${c.icon}</div>
      <div class="cr-card-label">${c.label}</div>
      <div class="cr-card-desc">${c.desc}</div>
      <div class="cr-card-cta">Explorar →</div>
    </button>`;
  }).join('');
  crGrid.querySelectorAll('.cr-card').forEach(btn => {
    btn.addEventListener('click', () => selectCrz(btn.dataset.id));
  });
}

// ── SELECT CRUZAMENTO ──────────────────────────────────────────
function selectCrz(id) {
  activeCrz = CRZ.find(c => c.id === id);
  if (!activeCrz) return;
  crGrid.querySelectorAll('.cr-card').forEach(b =>
    b.classList.toggle('cr-card--active', b.dataset.id === id)
  );
  refDim.innerHTML = activeCrz.dims.map((d, i) =>
    `<option value="${i}">${d.label}</option>`).join('');
  refMetric.innerHTML = activeCrz.metrics.map((m, i) =>
    `<option value="${i}">${m.label}</option>`).join('');
  refMetricGroup.style.display = activeCrz.metrics.length > 1 ? 'flex' : 'none';
  refSearch.value = '';
  refBar.style.display = 'flex';
  resArea.style.display = 'block';
  sqlPanel.style.display = 'none';
  btnSql.classList.remove('res-btn--active');
  runQuery();
}

// ── RUN QUERY ──────────────────────────────────────────────────
async function runQuery() {
  if (!ready) return;

  let sql;
  if (appMode === 'conexoes') {
    if (!activeCrz) return;
    const dim    = activeCrz.dims[+refDim.value];
    const metric = activeCrz.metrics[+refMetric.value];
    const search = refSearch.value.trim();
    sql = activeCrz.buildSQL(dim, metric, search);
  } else {
    sql = buildCamposSQL();
    if (!sql) return;
  }

  lastSQL = sql;
  sqlPre.textContent = sql;
  sortCol = null; sortAsc = true;

  resLoading.style.display = 'flex';
  loadingMsg.textContent   = 'Consultando…';
  viewChart.innerHTML = '';
  viewTable.innerHTML = '';

  try {
    const t0  = Date.now();
    const res = await conn.query(sql);
    const ms  = Date.now() - t0;
    lastRows  = res.toArray();
    lastCols  = res.schema.fields.map(f => f.name);

    resArea.style.display = 'block';
    resInfo.textContent = `${lastRows.length} linhas · ${ms}ms`;
    statusEl.textContent = `${lastRows.length} linhas · ${ms}ms`;
    renderView();
  } catch (e) {
    resArea.style.display = 'block';
    statusEl.textContent = 'Erro: ' + e.message;
    viewChart.innerHTML = `<div class="qerr">${e.message}</div>`;
    viewTable.innerHTML = '';
  } finally {
    resLoading.style.display = 'none';
  }
}

btnRerun.addEventListener('click', runQuery);
refDim.addEventListener('change', runQuery);
refMetric.addEventListener('change', runQuery);
refSearch.addEventListener('keydown', e => { if (e.key === 'Enter') runQuery(); });

// ── RENDER VIEW ────────────────────────────────────────────────
function renderView() {
  if (viewMode === 'chart') {
    viewChart.style.display = 'block';
    viewTable.style.display = 'none';
    ctBar.style.display     = 'flex';
    renderChart();
  } else {
    viewChart.style.display = 'none';
    viewTable.style.display = 'block';
    ctBar.style.display     = 'none';
    renderTable();
  }
}

// ── CHART TYPES ────────────────────────────────────────────────
ctBar.querySelectorAll('.ct-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    chartType = btn.dataset.type;
    ctBar.querySelectorAll('.ct-btn').forEach(b => b.classList.remove('ct-btn--active'));
    btn.classList.add('ct-btn--active');
    renderChart();
  });
});

function getChartData() {
  const dimCol = lastCols[0];
  const valCol = lastCols[lastCols.length - 1];
  const rows   = lastRows.slice(0, 40);
  const vals   = rows.map(r => Number(r[valCol]) || 0);
  const maxVal = Math.max(...vals, 1);
  return { dimCol, valCol, rows, vals, maxVal };
}

function renderChart() {
  if (!lastRows.length) {
    viewChart.innerHTML = '<div class="qerr">Nenhum resultado.</div>';
    return;
  }
  const { dimCol, valCol, rows, vals, maxVal } = getChartData();
  const dimLabel = appMode === 'conexoes' ? (activeCrz?.dims[+refDim.value]?.label ?? dimCol) : dimCol;
  const valLabel = appMode === 'conexoes' ? (activeCrz?.metrics[+refMetric.value]?.label ?? valCol) : valCol;

  const legend = `<div class="chart-legend">
    <span class="chart-x">${dimLabel}</span>
    <span class="chart-m">${valLabel}</span>
  </div>`;

  if (chartType === 'bh') {
    const bars = rows.map(r => {
      const v   = Number(r[valCol]) || 0;
      const lbl = String(r[dimCol] ?? '—');
      const pct = (v / maxVal) * 100;
      return `<div class="cbar">
        <div class="cbar-lbl" title="${lbl}">${lbl}</div>
        <div class="cbar-track"><div class="cbar-fill" style="width:${pct.toFixed(1)}%"></div></div>
        <div class="cbar-val">${fmtNum(v)}</div>
      </div>`;
    }).join('');
    viewChart.innerHTML = `${legend}<div class="chart-bars">${bars}</div>`;

  } else if (chartType === 'bv') {
    const bars = rows.map(r => {
      const v   = Number(r[valCol]) || 0;
      const lbl = String(r[dimCol] ?? '—');
      const pct = (v / maxVal) * 100;
      return `<div class="cbv-col">
        <div class="cbv-val">${fmtNum(v)}</div>
        <div class="cbv-track"><div class="cbv-fill" style="height:${pct.toFixed(1)}%"></div></div>
        <div class="cbv-lbl" title="${lbl}">${lbl}</div>
      </div>`;
    }).join('');
    viewChart.innerHTML = `${legend}<div class="chart-bars-v">${bars}</div>`;

  } else { // ln
    const W = 800, H = 180, PAD = 10, BOTTOM = 60;
    const n   = rows.length;
    const xStep = n > 1 ? (W - PAD * 2) / (n - 1) : 0;
    const points = rows.map((r, i) => {
      const v = Number(r[valCol]) || 0;
      const x = PAD + i * xStep;
      const y = H - PAD - ((v / maxVal) * (H - PAD * 2 - BOTTOM));
      return { x, y, v, lbl: String(r[dimCol] ?? '—') };
    });
    const polyline = points.map(p => `${p.x},${p.y}`).join(' ');
    const dots = points.map(p =>
      `<circle cx="${p.x}" cy="${p.y}" r="3.5" fill="var(--br)">
        <title>${p.lbl}: ${fmtNum(p.v)}</title>
      </circle>`
    ).join('');
    // X-axis labels: show max 10 evenly
    const step = Math.max(1, Math.ceil(n / 10));
    const labels = points.filter((_, i) => i % step === 0 || i === n - 1).map(p =>
      `<text x="${p.x}" y="${H + 14}" text-anchor="middle" font-size="9" fill="var(--muted)"
        transform="rotate(-35,${p.x},${H + 14})">${p.lbl.slice(0, 20)}</text>`
    ).join('');
    const area = points.map((p, i) => (i === 0 ? `M${p.x},${H - PAD - BOTTOM + BOTTOM}` : ``) + '').join('');
    viewChart.innerHTML = `${legend}<div class="chart-svg-wrap">
      <svg viewBox="0 0 ${W} ${H + BOTTOM}" preserveAspectRatio="xMidYMid meet" class="chart-svg">
        <polyline points="${polyline}" fill="none" stroke="var(--br)" stroke-width="2" stroke-linejoin="round"/>
        ${dots}
        ${labels}
      </svg>
    </div>`;
  }
}

// ── SORTABLE TABLE ─────────────────────────────────────────────
function sortedRows() {
  if (!sortCol) return lastRows;
  return [...lastRows].sort((a, b) => {
    const av = a[sortCol], bv = b[sortCol];
    const an = Number(av), bn = Number(bv);
    const cmp = Number.isFinite(an) && Number.isFinite(bn)
      ? an - bn
      : String(av ?? '').localeCompare(String(bv ?? ''), 'pt-BR');
    return sortAsc ? cmp : -cmp;
  });
}

function renderTable() {
  if (!lastRows.length) { viewTable.innerHTML = '<div class="qerr">Nenhum resultado.</div>'; return; }

  const rows    = sortedRows();
  const metricCol = lastCols[lastCols.length - 1];
  const metricVals = rows.map(r => Number(r[metricCol]) || 0);
  const maxVal  = Math.max(...metricVals, 1);

  const friendlyHdr = (c, i) => {
    if (appMode === 'conexoes') {
      if (c === 'dim')   return activeCrz?.dims[+refDim.value]?.label    ?? c;
      if (c === 'valor') return activeCrz?.metrics[+refMetric.value]?.label ?? c;
    }
    return c;
  };

  let h = `<table class="dtbl"><thead><tr>`;
  lastCols.forEach((c, i) => {
    const dir  = sortCol === c ? (sortAsc ? ' ↑' : ' ↓') : '';
    const cls  = `th-sort${sortCol === c ? ' th-sort--active' : ''}`;
    h += `<th class="${cls}" data-col="${c}">${friendlyHdr(c, i)}${dir}</th>`;
  });
  h += `</tr></thead><tbody>`;

  rows.forEach(row => {
    h += `<tr>`;
    lastCols.forEach((col, i) => {
      const v    = row[col];
      const disp = v == null ? '—' : String(v);
      if (i === lastCols.length - 1 && maxVal > 0 && Number.isFinite(Number(v))) {
        const pct = Math.round((Number(v) / maxVal) * 100);
        h += `<td class="td-metric"><div class="td-bar-wrap">
          <div class="td-bar" style="width:${pct}%"></div>
          <span>${fmtNum(Number(v))}</span>
        </div></td>`;
      } else {
        h += `<td title="${disp}">${disp}</td>`;
      }
    });
    h += `</tr>`;
  });
  h += `</tbody></table>`;
  viewTable.innerHTML = h;

  viewTable.querySelectorAll('.th-sort').forEach(th => {
    th.addEventListener('click', () => {
      const col = th.dataset.col;
      if (sortCol === col) sortAsc = !sortAsc;
      else { sortCol = col; sortAsc = true; }
      renderTable();
    });
  });
}

