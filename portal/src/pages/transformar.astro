let builderGroupBys = []; // ["table.col", ...] — colunas a mostrar. Viram GROUP BY se houver métricas; SELECT cru caso contrário.
let builderMetrics = []; // [{op:'SUM'|'COUNT'|'AVG'|'COUNT_DISTINCT', col:'table.col'|'*'}]
let builderFilters = []; // [{col, op, val}]
