---
import Base from "../layouts/Base.astro";
import { getDatasets } from "../lib/catalog.js";
import { getRegistry } from "../lib/joins.js";

const base = import.meta.env.BASE_URL;
const HF = "https://huggingface.co/datasets/riabr-dados/riab/resolve/main/cleaned";

// Build BUILDER_CATALOG: every visible table with its dataset metadata
const datasets = getDatasets();
const joinsRegistry = getRegistry();
const tablesByName = Object.fromEntries(joinsRegistry.tables.map((t) => [t.table, t]));

const BUILDER_CATALOG = [];
for (const ds of datasets) {
  const tables = ds.cleaned?.tables ?? [];
  for (const t of tables) {
    const name = typeof t === "string" ? t : t.name;
    const reg = tablesByName[name];
    if (!reg) continue;
    BUILDER_CATALOG.push({
      table: name,
      title: ds.title,
      slug: ds.slug,
      country: ds.source?.country ?? "??",
      source_id: ds.source_id,
      source_label: ds.source?.label ?? ds.source_id ?? "—",
      categoria: ds.categoria ?? [],
      keys: [...new Set((reg.exposes ?? []).map((e) => e.key))],
      key_cols: (reg.exposes ?? []).reduce((acc, e) => {
        (acc[e.key] ??= []).push({ col: e.col, normalize: e.normalize ?? null });
        return acc;
      }, {}),
    });
  }
}

const BUILDER_BRIDGES = joinsRegistry.bridges.map((b) => ({
  tables: b.tables,
  via_keys: b.via_keys,
  top_key: b.top_key,
  weight: b.weight,
}));

const KEY_GLOSSARY = joinsRegistry._meta?.key_glossary ?? {};
const BUILDER_DATA_JSON = JSON.stringify({ catalog: BUILDER_CATALOG, bridges: BUILDER_BRIDGES, keyGlossary: KEY_GLOSSARY });
---

