// SQL keywords reserved by DuckDB that cannot be used as bare aliases
const SQL_RESERVED = new Set([
  'do','in','on','or','as','by','is','at','no','not','if','of','to',
  'and','any','all','asc','desc','from','where','group','order','having',
  'union','join','left','right','outer','inner','cross','natural','using',
  'when','then','else','case','end','null','true','false','select','distinct',
  'limit','offset','create','drop','table','view','with','as','set','into',
  'returning','for','full','some','only','primary','foreign','key','unique',
]);

function aliasBase(table){
  const parts = table.split('_').filter(Boolean);
  if (parts.length === 1) return parts[0].slice(0,3);
  // first letter of each word, min 3 chars to dodge keyword collisions
  const initials = parts.map(p => p[0]).join('');
  return initials.length >= 3 ? initials.slice(0,4) : (initials + parts[parts.length-1].slice(1,2)).slice(0,4);
}

// Generate alias unique in the current trail AND not a SQL reserved word
function aliasFor(table, taken = new Set()){
  let base = aliasBase(table);
  let alias = base;
  let n = 2;
  while (SQL_RESERVED.has(alias.toLowerCase()) || taken.has(alias)) {
    alias = base + n;
    n++;
    if (n > 99) break;
  }
  return alias;
}

