---
import Base from "../layouts/Base.astro";
import DatasetCard from "../components/DatasetCard.astro";
import { getDatasets, getCatalogStats } from "../lib/catalog.js";

const datasets = getDatasets();
const stats = getCatalogStats(datasets);

const COUNTRIES = [
  { code: "", label: `Todos (${datasets.length})` },
  { code: "BR", label: "Brasil" },
  { code: "FR", label: "França" },
  { code: "AR", label: "Argentina" },
  { code: "UK", label: "Reino Unido" },
  { code: "UY", label: "Uruguai" },
  { code: "EU", label: "Europa" },
];

const base = import.meta.env.BASE_URL;
---

<Base title="Repositório Independente do Audiovisual Brasileiro" description="Dados abertos do cinema brasileiro e internacional — ANCINE, CNC, BFI, INCAA, Lumière. Consulte e exporte direto do navegador.">

<!-- ── HERO ──────────────────────────────────────────────────────── -->
<section class="hero">
  <p class="hero-eyebrow">
    <span class="hero-ey__live">atualizado</span>
    <span class="hero-ey__sep"></span>
    <span>{stats.total_datasets} datasets</span>
    <span class="hero-ey__sep"></span>
    <span>{stats.total_paises} países</span>
    <span class="hero-ey__sep"></span>
    <span>{stats.total_fontes} fontes</span>
  </p>
  <h1 class="hero-h">
    <span class="hero-h__l">Repositório</span>
    <span class="hero-h__l">Independente</span>
    <span class="hero-h__l hero-h__l--em">do Audiovisual Brasileiro.</span>
  </h1>
  <div class="hero-deck">
    <p>
      {stats.total_datasets} datasets de fontes oficiais — ANCINE, CNC, BFI, INCAA, ACAU, Lumière, IBGE.
      Consulte, cruze e exporte direto do navegador — sem instalar nada, sem cadastro, sem custo.
    </p>
    <div class="hero-cta">
      <a class="btn-primary" href={`${base}explorar/`}>▶ Explorar dados</a>
      <a class="btn-ghost" href={`${base}datasets/`}>Ver catálogo</a>
    </div>
  </div>
</section>

<!-- ── STATS STRIP ─────────────────────────────────────────────── -->
<div class="statstrip">
  <div class="stat stat--br">
    <div class="stat-v">{stats.total_datasets}</div>
    <div class="stat-l">Datasets</div>
  </div>
  <div class="stat stat--fr">
    <div class="stat-v">{stats.total_paises}</div>
    <div class="stat-l">Países</div>
  </div>
  <div class="stat stat--red">
    <div class="stat-v">+60<small>k</small></div>
    <div class="stat-l">Obras cadastradas</div>
  </div>
  <div class="stat stat--uy">
    <div class="stat-v">{stats.total_fontes}</div>
    <div class="stat-l">Fontes oficiais</div>
  </div>
  <div class="stat stat--uk">
    <div class="stat-v">R$&thinsp;0</div>
    <div class="stat-l">Custo de acesso</div>
  </div>
</div>

<!-- ── DISCOVER ───────────────────────────────────────────────────── -->
<section class="home-section">
  <div class="sec-label">O que você pode descobrir</div>
  <h2 class="sec-title">Perguntas reais.<br/>Dados reais.</h2>
  <p class="sec-sub">Clique para explorar qualquer pergunta no explorador.</p>

  <div class="disc-grid">
    <a href={`${base}explorar/`} class="disc-card disc-card--br">
      <div class="disc-card__glow"></div>
      <div class="disc-card__tag">Brasil · ANCINE</div>
      <div class="disc-card__q">Qual estado brasileiro produz mais filmes — e como isso mudou nos últimos 20 anos?</div>
      <div class="disc-card__detail">61.335 obras cadastradas · 2002–2026</div>
      <span class="disc-card__arrow">→</span>
    </a>
    <a href={`${base}explorar/`} class="disc-card disc-card--br">
      <div class="disc-card__glow"></div>
      <div class="disc-card__tag">Brasil · FSA</div>
      <div class="disc-card__q">Quanto o Fundo Setorial do Audiovisual investiu por tipo de projeto e produtora?</div>
      <div class="disc-card__detail">4.588 contratos FSA · 2008–2023</div>
      <span class="disc-card__arrow">→</span>
    </a>
    <a href={`${base}explorar/`} class="disc-card disc-card--eu">
      <div class="disc-card__glow"></div>
      <div class="disc-card__tag">Europa · Lumiere</div>
      <div class="disc-card__q">Quais filmes brasileiros chegaram à Europa — e em quais países tiveram mais público?</div>
      <div class="disc-card__detail">Dados Lumiere · 37 países europeus</div>
      <span class="disc-card__arrow">→</span>
    </a>
    <a href={`${base}explorar/`} class="disc-card disc-card--fr">
      <div class="disc-card__glow"></div>
      <div class="disc-card__tag">França · CNC</div>
      <div class="disc-card__q">Como o mercado de cinema francês evoluiu nos últimos 10 anos em salas e VOD?</div>
      <div class="disc-card__detail">Dados CNC · frequentação + distribuição</div>
      <span class="disc-card__arrow">→</span>
    </a>
  </div>
</section>

<!-- ── HOW ────────────────────────────────────────────────────────── -->
<section class="home-section home-section--alt">
  <div class="sec-label">Como funciona</div>
  <h2 class="sec-title">Três passos.</h2>
  <p class="sec-sub">Sem cadastro. Sem download obrigatório. Sem servidor.</p>

  <div class="how-grid">
    <div class="how-step">
      <div class="how-step__num">01</div>
      <div class="how-step__title">Escolha um dataset</div>
      <p class="how-step__desc">
        {stats.total_datasets} datasets de fontes oficiais — ANCINE, CNC, BFI, INCAA, ACAU, Lumiere, IBGE —
        organizados e documentados com schema completo de colunas e tipos.
      </p>
      <span class="how-step__tag">{stats.total_datasets} datasets · {stats.total_paises} países</span>
    </div>
    <div class="how-step">
      <div class="how-step__num">02</div>
      <div class="how-step__title">Escreva SQL ou pergunte em português</div>
      <p class="how-step__desc">
        O explorador roda no seu navegador via DuckDB-WASM. Os dados chegam diretamente
        do Hugging Face. Sem servidor, sem espera — e você pode cruzar tabelas de países diferentes.
      </p>
      <span class="how-step__tag">DuckDB · IA em português</span>
    </div>
    <div class="how-step">
      <div class="how-step__num">03</div>
      <div class="how-step__title">Exporte e use onde quiser</div>
      <p class="how-step__desc">
        Baixe CSV com um clique, ou acesse os dados diretamente do Python, R ou DuckDB
        com uma linha de código — via Hugging Face.
      </p>
      <span class="how-step__tag">CSV · Python · R · DuckDB</span>
    </div>
  </div>

  <div style="margin-top: 32px">
    <a class="btn-primary" href={`${base}explorar/`}>Começar agora →</a>
  </div>
</section>

<!-- ── CATALOG ────────────────────────────────────────────────────── -->
<section class="home-section">
  <div class="sec-label">Catálogo completo</div>
  <h2 class="sec-title">{stats.total_datasets} datasets.</h2>
  <p class="sec-sub">Filtre por país ou busque pelo nome.</p>

  <div class="catalog__filters" id="filters" style="display:flex;gap:6px;flex-wrap:wrap;align-items:center;margin-bottom:24px;">
    {COUNTRIES.map((c) => (
      <button class={`chip${c.code === "" ? " chip--active" : ""}`} data-country={c.code}>
        {c.label}
      </button>
    ))}
    <input class="catalog__search" id="search" type="search" placeholder="Buscar dataset..." autocomplete="off" />
  </div>

  <div class="catalog__grid" id="catalog-grid">
    {datasets.map((ds) => (
      <div data-country={ds.source?.country ?? ""} data-tags={(ds.tags ?? []).join(" ")} data-title={ds.title.toLowerCase()}>
        <DatasetCard ds={ds} />
      </div>
    ))}
  </div>
</section>

<!-- ── CODE ──────────────────────────────────────────────────────── -->
<section class="home-section home-section--alt">
  <div class="sec-label">Use no seu código</div>
  <h2 class="sec-title">Uma linha. Dados diretos.</h2>
  <p class="sec-sub">Acesse os Parquets direto do Hugging Face — sem baixar nada.</p>

  <div class="code-tabs-wrap">
    <div class="code-tabs">
      <button class="ctab ctab--active" data-tab="duckdb">DuckDB</button>
      <button class="ctab" data-tab="pandas">pandas</button>
      <button class="ctab" data-tab="r">R</button>
      <button class="ctab" data-tab="cli">CLI</button>
    </div>

    <div class="code-panels">
      <div class="code-panel code-panel--active" id="ctab-duckdb">
        <div class="code-header">
          <span class="code-filename">query.py</span>
        </div>
        <pre class="code-block"><span class="ck">import</span> duckdb

conn <span class="co">=</span> duckdb.<span class="cf">connect</span>()
conn.<span class="cf">sql</span>(<span class="cs">"INSTALL httpfs; LOAD httpfs;"</span>)

conn.<span class="cf">sql</span>(<span class="cs">"""
  SELECT tipo_obra, COUNT(*) AS total
  FROM 'hf://datasets/riabr-dados/riab/cleaned/obras.parquet'
  GROUP BY tipo_obra
  ORDER BY total DESC
"""</span>).<span class="cf">show</span>()</pre>
      </div>
      <div class="code-panel" id="ctab-pandas">
        <div class="code-header">
          <span class="code-filename">analise.py</span>
        </div>
        <pre class="code-block"><span class="ck">import</span> pandas <span class="ck">as</span> pd

df <span class="co">=</span> pd.<span class="cf">read_parquet</span>(
    <span class="cs">"hf://datasets/riabr-dados/riab/cleaned/obras.parquet"</span>
)

top_ufs <span class="co">=</span> (
    df.<span class="cf">groupby</span>(<span class="cs">"uf_requerente"</span>)
      .<span class="cf">size</span>()
      .<span class="cf">sort_values</span>(ascending<span class="co">=</span><span class="ck">False</span>)
      .<span class="cf">head</span>(<span class="cn">10</span>)
)
<span class="cf">print</span>(top_ufs)</pre>
      </div>
      <div class="code-panel" id="ctab-r">
        <div class="code-header">
          <span class="code-filename">analise.R</span>
        </div>
        <pre class="code-block"><span class="cf">library</span>(arrow)
<span class="cf">library</span>(dplyr)

obras <span class="co">&lt;-</span> <span class="cf">read_parquet</span>(
    <span class="cs">"hf://datasets/riabr-dados/riab/cleaned/obras.parquet"</span>
)

obras <span class="co">|&gt;</span>
    <span class="cf">count</span>(tipo_obra, sort <span class="co">=</span> <span class="ck">TRUE</span>) <span class="co">|&gt;</span>
    <span class="cf">head</span>(<span class="cn">10</span>)</pre>
      </div>
      <div class="code-panel" id="ctab-cli">
        <div class="code-header">
          <span class="code-filename">terminal</span>
        </div>
        <pre class="code-block">huggingface-cli download riabr-dados/riab \
    --repo-type dataset \
    --include <span class="cs">"cleaned/*.parquet"</span> \
    --local-dir ./dados</pre>
      </div>
    </div>
  </div>

  <div style="margin-top: 24px">
    <a class="btn-ghost" href={`${base}consulta/`}>Ver guia completo →</a>
  </div>
</section>

</Base>

<script>
  // Catalog filter
  const chips = document.querySelectorAll(".chip[data-country]");
  const cards = document.querySelectorAll("#catalog-grid > div");
  const search = document.getElementById("search") as HTMLInputElement | null;
  let activeCountry = "";

  function applyFilters() {
    const q = search?.value.trim().toLowerCase() ?? "";
    cards.forEach((card) => {
      const el = card as HTMLElement;
      const matchC = activeCountry === "" || el.dataset.country === activeCountry;
      const matchS = q === "" || (el.dataset.title ?? "").includes(q) || (el.dataset.tags ?? "").includes(q);
      el.style.display = matchC && matchS ? "" : "none";
    });
  }
  chips.forEach((chip) => {
    chip.addEventListener("click", () => {
      chips.forEach((c) => c.classList.remove("chip--active"));
      chip.classList.add("chip--active");
      activeCountry = (chip as HTMLElement).dataset.country ?? "";
      applyFilters();
    });
  });
  search?.addEventListener("input", applyFilters);

  // Code tabs
  document.querySelectorAll(".ctab").forEach(tab => {
    tab.addEventListener("click", () => {
      document.querySelectorAll(".ctab").forEach(t => t.classList.remove("ctab--active"));
      document.querySelectorAll(".code-panel").forEach(p => p.classList.remove("code-panel--active"));
      tab.classList.add("ctab--active");
      const name = (tab as HTMLElement).dataset.tab;
      document.getElementById(`ctab-${name}`)?.classList.add("code-panel--active");
    });
  });
</script>

<style>
/* ── HERO ── */
.hero {
  padding: 72px 0 64px;
  border-bottom: 1px solid var(--border);
}

.hero-eyebrow {
  display: flex;
  gap: 14px;
  align-items: center;
  font-family: var(--font-m);
  font-size: 11px;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--dim);
  margin-bottom: 36px;
  flex-wrap: wrap;
  animation: rise .6s ease both;
}
.hero-ey__live {
  color: var(--br);
  display: inline-flex;
  align-items: center;
  gap: 7px;
}
.hero-ey__live::before {
  content: '';
  width: 7px; height: 7px; border-radius: 50%;
  background: var(--br);
  animation: blink 2.2s ease-in-out infinite;
}
.hero-ey__sep { width: 14px; height: 1px; background: var(--border2); flex-shrink: 0; }

.hero-h {
  font-family: var(--font-d);
  font-variation-settings: 'opsz' 96,'wdth' 84,'wght' 700;
  font-size: clamp(60px, 10vw, 148px);
  line-height: .9;
  letter-spacing: -.04em;
  color: var(--text);
  margin-bottom: 40px;
  max-width: 1100px;
}
.hero-h__l {
  display: block;
  animation: rise .9s cubic-bezier(.2,.7,.3,1) backwards;
}
.hero-h__l:nth-child(1) { animation-delay: .05s; }
.hero-h__l:nth-child(2) { animation-delay: .13s; }
.hero-h__l--em {
  color: var(--muted);
  font-style: italic;
  font-size: .8em;
  animation-delay: .22s;
}

.hero-deck {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 40px;
  align-items: end;
  max-width: 960px;
  animation: rise .7s .3s ease both;
}
.hero-deck p {
  font-size: clamp(15px, 1.4vw, 17px);
  color: var(--muted);
  line-height: 1.65;
  font-weight: 300;
}
.hero-cta { display: flex; gap: 10px; flex-wrap: wrap; justify-content: flex-end; }

/* ── STATS STRIP ── */
.statstrip {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  border-bottom: 1px solid var(--border);
}
@media (min-width: 760px) { .statstrip { grid-template-columns: repeat(5, 1fr); } }

.stat {
  padding: 28px 28px 26px;
  border-right: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  position: relative;
  background: var(--bg);
  transition: background .15s;
}
@media (min-width: 760px) { .stat { border-bottom: none; } }
.stat:last-child { border-right: none; }
.stat:hover { background: var(--surface); }

.stat::before {
  content: '';
  position: absolute;
  top: 0; left: 28px;
  width: 32px; height: 3px;
}
.stat--br::before { background: var(--br); }
.stat--fr::before { background: var(--fr); }
.stat--red::before { background: #e8341a; }
.stat--uy::before { background: var(--uy); }
.stat--uk::before { background: var(--uk); }

.stat-v {
  font-family: var(--font-d);
  font-variation-settings: 'opsz' 96,'wdth' 85,'wght' 700;
  font-size: clamp(40px, 5vw, 64px);
  line-height: .95;
  letter-spacing: -.04em;
  color: var(--text);
  font-feature-settings: 'tnum';
  margin-bottom: 6px;
}
.stat-v small { font-size: .5em; letter-spacing: -.02em; margin-left: .05em; color: var(--dim); }
.stat-l {
  font-family: var(--font-m);
  font-size: 10px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--muted);
}

/* ── Animations ── */
@keyframes rise {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes blink {
  0%,100% { opacity: 1; }
  50%      { opacity: .35; }
}

@media (max-width: 760px) {
  .hero-deck { grid-template-columns: 1fr; gap: 24px; }
  .hero-cta { justify-content: flex-start; }
}

/* SECTIONS */
.home-section { padding: 80px 0; border-bottom: 1px solid var(--border); }
.home-section:last-child { border-bottom: none; }
.home-section--alt { background: var(--bg2); }

/* DISCOVER */
.disc-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1px;
  background: var(--border2);
  border: 1px solid var(--border2);
  border-radius: var(--r);
  overflow: hidden;
}
.disc-card {
  background: var(--bg);
  padding: 32px 28px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  position: relative;
  transition: background .2s;
  overflow: hidden;
  text-decoration: none !important;
}
.disc-card:hover { background: var(--surface); }
.disc-card::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 3px;
}
.disc-card--br::before { background: var(--br); }
.disc-card--eu::before { background: var(--eu); }
.disc-card--fr::before { background: var(--fr); }
.disc-card--ar::before { background: var(--ar); }
.disc-card__glow {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity .3s;
  pointer-events: none;
}
.disc-card--br .disc-card__glow { background: radial-gradient(circle at 0% 50%, rgba(0,122,60,.06), transparent 70%); }
.disc-card--eu .disc-card__glow { background: radial-gradient(circle at 0% 50%, rgba(168,85,247,.06), transparent 70%); }
.disc-card--fr .disc-card__glow { background: radial-gradient(circle at 0% 50%, rgba(72,120,232,.06), transparent 70%); }
.disc-card:hover .disc-card__glow { opacity: 1; }
.disc-card__tag { font-family: var(--font-m); font-size: 8px; letter-spacing: .14em; text-transform: uppercase; }
.disc-card--br .disc-card__tag { color: var(--br); }
.disc-card--eu .disc-card__tag { color: var(--eu); }
.disc-card--fr .disc-card__tag { color: var(--fr); }
.disc-card--ar .disc-card__tag { color: var(--ar); }
.disc-card__q { font-size: 16px; font-weight: 500; color: var(--text); line-height: 1.4; }
.disc-card__detail { font-family: var(--font-m); font-size: 10px; color: var(--muted); margin-top: auto; }
.disc-card__arrow { font-size: 12px; color: var(--muted); transition: transform .2s, color .2s; align-self: flex-end; }
.disc-card:hover .disc-card__arrow { transform: translateX(4px); color: var(--text); }

/* HOW */
.how-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border2);
  border: 1px solid var(--border2);
  border-radius: var(--r);
  overflow: hidden;
}
.how-step {
  background: var(--bg2);
  padding: 40px 32px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  transition: background .2s;
}
.how-step:hover { background: var(--surface); }
.how-step__num { font-family: var(--font-d); font-size: 72px; line-height: 1; color: var(--dim); letter-spacing: 1px; }
.how-step__title { font-weight: 600; font-size: 15px; color: var(--text); line-height: 1.3; }
.how-step__desc { font-size: 13px; color: var(--muted); line-height: 1.7; font-weight: 300; }
.how-step__tag { font-family: var(--font-m); font-size: 9px; letter-spacing: .1em; text-transform: uppercase; color: var(--br); margin-top: auto; }

/* CODE TABS */
.code-tabs-wrap { border: 1px solid var(--border2); border-radius: var(--r); overflow: hidden; }
.code-tabs { display: flex; border-bottom: 1px solid var(--border2); background: var(--surface); }
.ctab {
  font-family: var(--font-m);
  font-size: 11px;
  letter-spacing: .04em;
  padding: 12px 20px;
  color: var(--muted);
  cursor: pointer;
  border: none;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  background: none;
  transition: all .15s;
}
.ctab:hover { color: var(--text); }
.ctab--active { color: var(--br); border-bottom-color: var(--br); }
.code-panels { background: var(--bg); }
.code-panel { display: none; }
.code-panel--active { display: block; }
.code-header {
  background: var(--surface);
  padding: 10px 16px;
  border-bottom: 1px solid var(--border2);
}
.code-filename { font-family: var(--font-m); font-size: 10px; color: var(--muted); }
pre.code-block {
  padding: 24px;
  font-family: var(--font-m);
  font-size: 12px;
  line-height: 1.8;
  color: #8888cc;
  overflow-x: auto;
  margin: 0;
}
.ck { color: #c792ea; }
.cf { color: #82aaff; }
.cs { color: #c3e88d; }
.co { color: var(--br); }
.cn { color: #f78c6c; }

@media (max-width: 900px) {
  .disc-grid { grid-template-columns: 1fr; }
  .how-grid { grid-template-columns: 1fr; }
}
</style>
