---
import Base from "../layouts/Base.astro";
import DatasetCard from "../components/DatasetCard.astro";
import { getDatasets, getCatalogStats } from "../lib/catalog.js";

const datasets = getDatasets();
const stats = getCatalogStats(datasets);

const COUNTRIES = [
  { code: "", label: `Todos (${datasets.length})` },
  { code: "BR", label: "Brasil" },
  { code: "FR", label: "França" },
  { code: "AR", label: "Argentina" },
  { code: "UK", label: "Reino Unido" },
  { code: "UY", label: "Uruguai" },
  { code: "EU", label: "Europa" },
];

const SECTIONS = [
  {
    num: "01",
    href: "datasets/",
    label: "Datasets",
    desc: `Catálogo de ${stats.total_datasets} datasets de fontes oficiais de ${stats.total_paises} países — ANCINE, CNC, BFI, INCAA, ACAU, Lumière, IBGE.`,
    tag: `${stats.total_datasets} datasets · ${stats.total_paises} países`,
    featured: true,
  },
  {
    num: "02",
    href: "explorar/",
    label: "▶ Explorar",
    desc: "Consulte qualquer dataset via SQL ou em português natural, direto no navegador — sem instalar nada, sem cadastro.",
    tag: "DuckDB-WASM · IA em português",
    featured: false,
  },
  {
    num: "03",
    href: "transformar/",
    label: "Transformar",
    desc: "Metodologia aberta de integração, limpeza e normalização dos dados.",
    tag: "Scripts reproduzíveis · documentados",
    featured: false,
  },
  {
    num: "04",
    href: "mural/",
    label: "Mural",
    desc: "Análises e trabalhos produzidos com os dados do RIDAB. O debate sobre o audiovisual brasileiro baseado em evidências.",
    tag: "Novo",
    featured: false,
    isNew: true,
  },
  {
    num: "05",
    href: "consulta/",
    label: "Docs",
    desc: "Guia de uso, schema completo de colunas e acesso programático via Python, R ou DuckDB.",
    tag: "CSV · Parquet · API",
    featured: false,
  },
  {
    num: "06",
    href: "sobre/",
    label: "Sobre",
    desc: "Manifesto, princípios e governança do projeto. Por que o RIDAB existe e o que busca.",
    tag: "Manifesto RIDAB 01",
    featured: false,
  },
];

// Country breakdown for chart
const byCountry = [
  { code: "BR", label: "Brasil",       color: "var(--br)", count: datasets.filter(d => d.source?.country === "BR").length },
  { code: "FR", label: "França",       color: "var(--fr)", count: datasets.filter(d => d.source?.country === "FR").length },
  { code: "UK", label: "Reino Unido",  color: "var(--uk)", count: datasets.filter(d => d.source?.country === "UK").length },
  { code: "AR", label: "Argentina",    color: "var(--ar)", count: datasets.filter(d => d.source?.country === "AR").length },
  { code: "EU", label: "Europa",       color: "var(--eu)", count: datasets.filter(d => d.source?.country === "EU").length },
  { code: "UY", label: "Uruguai",      color: "var(--uy)", count: datasets.filter(d => d.source?.country === "UY").length },
].filter(c => c.count > 0).sort((a, b) => b.count - a.count);

const maxCount = Math.max(...byCountry.map(c => c.count));

const base = import.meta.env.BASE_URL;
---

<Base
  title="Repositório Independente do Audiovisual Brasileiro"
  description="Dados abertos do cinema brasileiro e internacional — ANCINE, CNC, BFI, INCAA, Lumière. Consulte e exporte direto do navegador."
>

<!-- ── HERO ──────────────────────────────────────────────────────── -->
<section class="hero">

  <p class="hero-eyebrow">
    <a class="hero-ey__manifesto" href={`${base}sobre/`}>Leia o manifesto →</a>
    <span class="hero-ey__sep"></span>
    <span class="hero-ey__live">atualizado</span>
    <span class="hero-ey__sep"></span>
    <span>{stats.total_datasets} datasets</span>
    <span class="hero-ey__sep"></span>
    <span>{stats.total_paises} países</span>
    <span class="hero-ey__sep"></span>
    <span>{stats.total_fontes} fontes</span>
  </p>

  <div class="hero-split">

    <!-- LEFT: título + desc + CTAs -->
    <div class="hero-left">
      <h1 class="hero-h">
        <span class="hero-h__l">O cinema</span>
        <span class="hero-h__l">brasileiro</span>
        <span class="hero-h__l hero-h__l--em">como dado público.</span>
      </h1>
      <p class="hero-desc">
        {stats.total_datasets} datasets de fontes oficiais — ANCINE, CNC, BFI, INCAA, ACAU, Lumière, IBGE.
        Consulte, cruze e exporte direto do navegador. Sem instalar nada, sem cadastro, sem custo.
      </p>
      <div class="hero-cta">
        <a class="btn-primary" href={`${base}datasets/`}>Ver catálogo →</a>
        <a class="btn-ghost"   href={`${base}explorar/`}>▶ Explorar dados</a>
      </div>
    </div>

    <!-- RIGHT: Como funciona — espelho da nav -->
    <div class="hero-right">
      <div class="hf-label">Como funciona</div>
      <div class="hf-list">
        {SECTIONS.map((s) => (
          <a href={`${base}${s.href}`} class={`hf-item${s.featured ? " hf-item--featured" : ""}${s.isNew ? " hf-item--new" : ""}`}>
            <div class="hf-item__head">
              <span class="hf-item__num">{s.num}</span>
              <span class="hf-item__name">{s.label}</span>
              {s.isNew && <span class="hf-item__badge">novo</span>}
              <span class="hf-item__arrow">→</span>
            </div>
            <p class="hf-item__desc">{s.desc}</p>
            <span class="hf-item__tag">{s.tag}</span>
          </a>
        ))}
      </div>
    </div>

  </div>
</section>

<!-- ── STATS STRIP ─────────────────────────────────────────────── -->
<div class="statstrip">
  <div class="stat stat--br">
    <div class="stat-v">{stats.total_datasets}</div>
    <div class="stat-l">Datasets</div>
  </div>
  <div class="stat stat--fr">
    <div class="stat-v">{stats.total_paises}</div>
    <div class="stat-l">Países</div>
  </div>
  <div class="stat stat--red">
    <div class="stat-v">+60<small>k</small></div>
    <div class="stat-l">Obras cadastradas</div>
  </div>
  <div class="stat stat--uy">
    <div class="stat-v">{stats.total_fontes}</div>
    <div class="stat-l">Fontes oficiais</div>
  </div>
  <div class="stat stat--uk">
    <div class="stat-v">R$&thinsp;0</div>
    <div class="stat-l">Custo de acesso</div>
  </div>
</div>

<!-- ── MURAL ──────────────────────────────────────────────────── -->
<section class="home-section home-section--alt">
  <div class="sec-label">Mural</div>
  <h2 class="sec-title">Dados em uso.</h2>
  <p class="sec-sub">Análises produzidas com os dados do RIDAB.</p>

  <a
    href="https://cainanbaladez-bot.github.io/fomento-audiovisual/politica.html"
    target="_blank" rel="noopener"
    class="mural-card"
  >
    <div class="mural-card__stripe"></div>
    <div class="mural-card__inner">
      <div class="mural-card__meta">
        <span class="mural-num">001</span>
        <span class="mural-tag-pill">Política pública · FSA · Fomento</span>
      </div>
      <h3 class="mural-card__title">Uma política de fomento baseada em evidências</h3>
      <p class="mural-card__desc">
        Análise de 3.968 filmes (2014–2023) avaliando o retorno doméstico e internacional
        de cada modalidade de fomento — FSA e incentivo fiscal.
        Qual metodologia de seleção produz os melhores resultados?
      </p>
      <div class="mural-card__foot">
        <div class="mural-foot__left">
          <span class="mural-author">Cainan Baladez</span>
          <span class="mural-datasets">ANCINE FSA · Bilheteria Consolidada · Lumière</span>
        </div>
        <span class="mural-cta">Ver análise ↗</span>
      </div>
    </div>
  </a>

  <div style="margin-top:24px">
    <a class="btn-ghost" href={`${base}mural/`}>Ver todo o Mural →</a>
  </div>
</section>

<!-- ── CATÁLOGO ───────────────────────────────────────────────── -->
<section class="home-section">
  <div class="sec-label">Catálogo completo</div>
  <h2 class="sec-title">{stats.total_datasets} datasets.</h2>
  <p class="sec-sub">Filtre por país ou busque pelo nome.</p>

  <div class="catalog__filters" id="filters">
    {COUNTRIES.map((c) => (
      <button class={`chip${c.code === "" ? " chip--active" : ""}`} data-country={c.code}>
        {c.label}
      </button>
    ))}
    <input class="catalog__search" id="search" type="search" placeholder="Buscar dataset…" autocomplete="off" />
  </div>

  <div class="catalog__grid" id="catalog-grid">
    {datasets.map((ds) => (
      <div
        data-country={ds.source?.country ?? ""}
        data-tags={(ds.tags ?? []).join(" ")}
        data-title={ds.title.toLowerCase()}
      >
        <DatasetCard ds={ds} />
      </div>
    ))}
  </div>
</section>

<!-- ── CÓDIGO ─────────────────────────────────────────────────── -->
<section class="home-section home-section--alt">
  <div class="sec-label">Use no seu código</div>
  <h2 class="sec-title">Uma linha. Dados diretos.</h2>
  <p class="sec-sub">Acesse os Parquets direto do Hugging Face — sem baixar nada.</p>

  <div class="code-tabs-wrap">
    <div class="code-tabs">
      <button class="ctab ctab--active" data-tab="duckdb">DuckDB</button>
      <button class="ctab" data-tab="pandas">pandas</button>
      <button class="ctab" data-tab="r">R</button>
      <button class="ctab" data-tab="cli">CLI</button>
    </div>
    <div class="code-panels">
      <div class="code-panel code-panel--active" id="ctab-duckdb">
        <div class="code-header"><span class="code-filename">query.py</span></div>
        <pre class="code-block"><span class="ck">import</span> duckdb

conn <span class="co">=</span> duckdb.<span class="cf">connect</span>()
conn.<span class="cf">sql</span>(<span class="cs">"INSTALL httpfs; LOAD httpfs;"</span>)

conn.<span class="cf">sql</span>(<span class="cs">"""
  SELECT tipo_obra, COUNT(*) AS total
  FROM 'hf://datasets/riabr-dados/riab/cleaned/obras.parquet'
  GROUP BY tipo_obra ORDER BY total DESC
"""</span>).<span class="cf">show</span>()</pre>
      </div>
      <div class="code-panel" id="ctab-pandas">
        <div class="code-header"><span class="code-filename">analise.py</span></div>
        <pre class="code-block"><span class="ck">import</span> pandas <span class="ck">as</span> pd

df <span class="co">=</span> pd.<span class="cf">read_parquet</span>(
    <span class="cs">"hf://datasets/riabr-dados/riab/cleaned/obras.parquet"</span>
)
top_ufs <span class="co">=</span> df.<span class="cf">groupby</span>(<span class="cs">"uf_requerente"</span>).<span class="cf">size</span>().<span class="cf">sort_values</span>(ascending<span class="co">=</span><span class="ck">False</span>).<span class="cf">head</span>(<span class="cn">10</span>)
<span class="cf">print</span>(top_ufs)</pre>
      </div>
      <div class="code-panel" id="ctab-r">
        <div class="code-header"><span class="code-filename">analise.R</span></div>
        <pre class="code-block"><span class="cf">library</span>(arrow); <span class="cf">library</span>(dplyr)

obras <span class="co">&lt;-</span> <span class="cf">read_parquet</span>(<span class="cs">"hf://datasets/riabr-dados/riab/cleaned/obras.parquet"</span>)
obras <span class="co">|&gt;</span> <span class="cf">count</span>(tipo_obra, sort <span class="co">=</span> <span class="ck">TRUE</span>) <span class="co">|&gt;</span> <span class="cf">head</span>(<span class="cn">10</span>)</pre>
      </div>
      <div class="code-panel" id="ctab-cli">
        <div class="code-header"><span class="code-filename">terminal</span></div>
        <pre class="code-block">huggingface-cli download riabr-dados/riab \
    --repo-type dataset \
    --include <span class="cs">"cleaned/*.parquet"</span> \
    --local-dir ./dados</pre>
      </div>
    </div>
  </div>
  <div style="margin-top:24px">
    <a class="btn-ghost" href={`${base}consulta/`}>Ver guia completo →</a>
  </div>
</section>

<!-- ── DADOS EM NÚMEROS ───────────────────────────────────────── -->
<section class="home-section viz-section">
  <div class="sec-label">Os dados em números</div>
  <h2 class="sec-title">O que está disponível.</h2>
  <p class="sec-sub">Distribuição do acervo por país de origem e destaques do catálogo.</p>

  <div class="viz-grid">

    <!-- Gráfico: datasets por país -->
    <div class="viz-card">
      <div class="viz-card__title">Datasets por país de origem</div>
      <div class="viz-bar-chart">
        {byCountry.map(c => (
          <div class="vbc-row">
            <span class="vbc-label">{c.label}</span>
            <div class="vbc-track">
              <div
                class="vbc-fill"
                style={`width:${Math.round((c.count / maxCount) * 100)}%;background:${c.color}`}
              ></div>
            </div>
            <span class="vbc-count">{c.count}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Cobertura temporal -->
    <div class="viz-card">
      <div class="viz-card__title">Cobertura temporal</div>
      <div class="viz-timeline">
        <div class="vtl-labels">
          <span>1945</span>
          <span>1970</span>
          <span>1995</span>
          <span>2026</span>
        </div>
        <div class="vtl-track">
          <!-- CNC França: 1945-presente -->
          <div class="vtl-bar vtl-bar--fr" style="left:0%;width:100%" title="França · CNC · 1945–2026"></div>
          <!-- Lumière: 1996-presente -->
          <div class="vtl-bar vtl-bar--eu" style="left:62.4%;width:37.6%" title="Europa · Lumière · 1996–2026"></div>
          <!-- ANCINE: 2002-presente -->
          <div class="vtl-bar vtl-bar--br" style="left:70.1%;width:29.9%" title="Brasil · ANCINE · 2002–2026"></div>
          <!-- FSA: 2008-2023 -->
          <div class="vtl-bar vtl-bar--br2" style="left:78%;width:18.5%" title="Brasil · FSA · 2008–2023"></div>
        </div>
        <div class="vtl-legend">
          <span class="vtl-leg vtl-leg--fr">França · CNC</span>
          <span class="vtl-leg vtl-leg--eu">Europa · Lumière</span>
          <span class="vtl-leg vtl-leg--br">Brasil · ANCINE</span>
          <span class="vtl-leg vtl-leg--br2">Brasil · FSA</span>
        </div>
      </div>
    </div>

    <!-- Destaques do acervo -->
    <div class="viz-card viz-card--highlights">
      <div class="viz-card__title">Destaques do acervo</div>
      <div class="viz-highlights">
        <div class="vh-item">
          <div class="vh-v">61.335</div>
          <div class="vh-l">obras audiovisuais brasileiras registradas</div>
          <div class="vh-src">ANCINE · 2002–2026</div>
        </div>
        <div class="vh-item">
          <div class="vh-v">95<small>mil+</small></div>
          <div class="vh-l">filmes com visa de exibição na França</div>
          <div class="vh-src">CNC · 1945–presente</div>
        </div>
        <div class="vh-item">
          <div class="vh-v">4.588</div>
          <div class="vh-l">contratos de fomento FSA</div>
          <div class="vh-src">ANCINE · 2008–2023</div>
        </div>
        <div class="vh-item">
          <div class="vh-v">37</div>
          <div class="vh-l">países europeus com dados de bilheteria</div>
          <div class="vh-src">Observatório Europeu · Lumière</div>
        </div>
      </div>
    </div>

  </div>

  <div style="margin-top:32px">
    <a class="btn-primary" href={`${base}datasets/`}>Explorar catálogo completo →</a>
  </div>
</section>

</Base>

<script>
  // Catalog filter
  const chips = document.querySelectorAll(".chip[data-country]");
  const cards = document.querySelectorAll("#catalog-grid > div");
  const search = document.getElementById("search") as HTMLInputElement | null;
  let activeCountry = "";

  function applyFilters() {
    const q = search?.value.trim().toLowerCase() ?? "";
    cards.forEach((card) => {
      const el = card as HTMLElement;
      const matchC = activeCountry === "" || el.dataset.country === activeCountry;
      const matchS = q === "" || (el.dataset.title ?? "").includes(q) || (el.dataset.tags ?? "").includes(q);
      el.style.display = matchC && matchS ? "" : "none";
    });
  }
  chips.forEach((chip) => {
    chip.addEventListener("click", () => {
      chips.forEach((c) => c.classList.remove("chip--active"));
      chip.classList.add("chip--active");
      activeCountry = (chip as HTMLElement).dataset.country ?? "";
      applyFilters();
    });
  });
  search?.addEventListener("input", applyFilters);

  // Code tabs
  document.querySelectorAll(".ctab").forEach(tab => {
    tab.addEventListener("click", () => {
      document.querySelectorAll(".ctab").forEach(t => t.classList.remove("ctab--active"));
      document.querySelectorAll(".code-panel").forEach(p => p.classList.remove("code-panel--active"));
      tab.classList.add("ctab--active");
      const name = (tab as HTMLElement).dataset.tab;
      document.getElementById(`ctab-${name}`)?.classList.add("code-panel--active");
    });
  });
</script>

<style>
/* ─── HERO ─────────────────────────────────────────────────────── */
.hero {
  padding: 60px 0 56px;
  border-bottom: 1px solid var(--border);
}

.hero-eyebrow {
  display: flex;
  gap: 14px;
  align-items: center;
  font-family: var(--font-m);
  font-size: 11px;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--dim);
  margin-bottom: 44px;
  flex-wrap: wrap;
  animation: rise .5s ease both;
}
.hero-ey__manifesto {
  color: var(--br);
  font-weight: 500;
  letter-spacing: .06em;
  text-decoration: none;
  transition: opacity .15s;
}
.hero-ey__manifesto:hover { opacity: .7; text-decoration: none; }
.hero-ey__live {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: var(--br);
}
.hero-ey__live::before {
  content: '';
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--br);
  animation: blink 2.4s ease-in-out infinite;
}
.hero-ey__sep { width: 14px; height: 1px; background: var(--border2); flex-shrink: 0; }

/* Split layout */
.hero-split {
  display: grid;
  grid-template-columns: 1fr 400px;
  gap: 64px;
  align-items: start;
}

/* LEFT */
.hero-left { animation: rise .7s .05s ease both; }

.hero-h {
  font-family: var(--font-d);
  font-variation-settings: 'opsz' 96,'wdth' 84,'wght' 700;
  font-size: clamp(54px, 8.5vw, 130px);
  line-height: .88;
  letter-spacing: -.04em;
  color: var(--text);
  margin-bottom: 36px;
}
.hero-h__l { display: block; animation: rise .9s cubic-bezier(.2,.7,.3,1) backwards; }
.hero-h__l:nth-child(1) { animation-delay: .06s; }
.hero-h__l:nth-child(2) { animation-delay: .14s; }
.hero-h__l--em {
  color: var(--muted);
  font-style: italic;
  font-size: .78em;
  animation-delay: .22s;
}

.hero-desc {
  font-size: clamp(13.5px, 1.1vw, 15.5px);
  color: var(--muted);
  line-height: 1.7;
  font-weight: 300;
  max-width: 460px;
  margin-bottom: 32px;
  animation: rise .7s .3s ease both;
}
.hero-cta {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  animation: rise .7s .38s ease both;
}

/* RIGHT: Como funciona */
.hero-right {
  position: sticky;
  top: 72px;
  animation: rise .7s .1s ease both;
}
.hf-label {
  font-family: var(--font-m);
  font-size: 9px;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--dim);
  margin-bottom: 12px;
}
.hf-list {
  border: 1px solid var(--border2);
  border-radius: var(--r);
  overflow: hidden;
}
.hf-item {
  display: flex;
  flex-direction: column;
  gap: 5px;
  padding: 14px 16px;
  border-bottom: 1px solid var(--border);
  text-decoration: none !important;
  transition: background .15s;
  background: var(--surface);
}
.hf-item:last-child { border-bottom: none; }
.hf-item:hover { background: var(--bg2); }
.hf-item--featured {
  background: var(--green-d);
  border-left: 3px solid var(--br);
}
.hf-item--featured:hover { background: rgba(0,122,60,.1); }

.hf-item__head {
  display: flex;
  align-items: center;
  gap: 8px;
}
.hf-item__num {
  font-family: var(--font-m);
  font-size: 8px;
  letter-spacing: .1em;
  color: var(--dim);
  width: 18px;
  flex-shrink: 0;
}
.hf-item__name {
  font-family: var(--font-m);
  font-size: 10px;
  letter-spacing: .06em;
  text-transform: uppercase;
  color: var(--text);
  font-weight: 500;
}
.hf-item--featured .hf-item__name { color: var(--br); }
.hf-item__badge {
  font-family: var(--font-m);
  font-size: 7px;
  letter-spacing: .1em;
  text-transform: uppercase;
  background: var(--uy);
  color: #fff;
  padding: 2px 5px;
  border-radius: 99px;
}
.hf-item__arrow {
  margin-left: auto;
  font-size: 10px;
  color: var(--dim);
  transition: transform .15s, color .15s;
}
.hf-item:hover .hf-item__arrow { transform: translateX(3px); color: var(--text); }
.hf-item__desc {
  padding-left: 26px;
  font-size: 11px;
  color: var(--muted);
  line-height: 1.55;
}
.hf-item__tag {
  padding-left: 26px;
  font-family: var(--font-m);
  font-size: 8.5px;
  letter-spacing: .08em;
  color: var(--dim);
}
.hf-item--featured .hf-item__tag { color: var(--br); }
.hf-item--new .hf-item__tag { color: var(--uy); }

/* ─── STATS ─────────────────────────────────────────────────────── */
.statstrip {
  display: grid;
