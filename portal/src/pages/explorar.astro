---
import Base from "../layouts/Base.astro";

const HF_BASE = "https://huggingface.co/datasets/riabr-dados/riab/resolve/main/cleaned";

const TABLES = [
  {
    group: "Brasil",
    color: "br",
    tables: [
      { id: "obras", label: "Obras", desc: "61 mil obras audiovisuais (ANCINE 2002–2026)" },
      { id: "diretores_obras", label: "Diretores", desc: "Diretores por CPB de obra" },
      { id: "produtores_obras", label: "Produtoras", desc: "Produtoras por CPB de obra" },
      { id: "fomento_fsa", label: "FSA Projetos", desc: "4.5 mil contratos do Fundo Setorial" },
      { id: "renuncia_fiscal", label: "Renúncia Fiscal", desc: "Captação via lei de incentivo" },
      { id: "bilheteria_por_filme_ano", label: "Bilheteria", desc: "Público por filme e ano" },
      { id: "bilheteria_consolidada_br", label: "Bilheteria Histórica", desc: "Top obras brasileiras" },
      { id: "agentes_economicos", label: "Empresas ANCINE", desc: "18 mil agentes registrados" },
      { id: "preco_ingresso", label: "Preço do Ingresso", desc: "Série 2014–2024" },
    ],
  },
  {
    group: "Europa",
    color: "eu",
    tables: [
      { id: "bilheteria_europa", label: "Bilheteria Europa", desc: "Admissões em 37 países (1996–2026)" },
      { id: "vod_europa", label: "VOD Europa", desc: "Catálogo de filmes em plataformas" },
    ],
  },
  {
    group: "Referência",
    color: "ref",
    tables: [
      { id: "deflator_ipca", label: "Deflator IPCA", desc: "Atualização monetária IBGE (base 2024)" },
    ],
  },
];

const parquetMap = Object.fromEntries(
  TABLES.flatMap(g => g.tables.map(t => [t.id, `${HF_BASE}/${t.id}.parquet`]))
);

const FEATURED = ["obras", "bilheteria_por_filme_ano", "fomento_fsa", "agentes_economicos"];

const parquetMapJson = JSON.stringify(parquetMap);
const tablesJson     = JSON.stringify(TABLES);
const featuredJson   = JSON.stringify(FEATURED);
---

<Base title="Explorar Dados" description="Explore todos os datasets do audiovisual brasileiro e internacional sem precisar escrever SQL.">

<div class="exp" id="exp-root">

  <!-- ░░ SIDEBAR ░░ -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-head">
      <span class="sidebar-head__label">Tabelas</span>
      <button class="sidebar-head__toggle" id="sidebar-toggle" title="Recolher">&#8249;</button>
    </div>

    <div class="sidebar-status">
      <span class="sdot" id="ex-dot"></span>
      <span class="sidebar-status__text" id="ex-status">Iniciando…</span>
    </div>

    <div class="sidebar-tables">
      {TABLES.map(g => (
        <div class={`sgroup sgroup--${g.color}`}>
          <div class="sgroup__label">{g.group}</div>
          {g.tables.map(t => (
            <button class="stable" data-table={t.id} title={t.desc}>
              <span class="stable__name">{t.label}</span>
              <span class="stable__desc">{t.desc}</span>
            </button>
          ))}
        </div>
      ))}
    </div>
  </aside>

  <!-- ░░ BUILDER ░░ -->
  <div class="builder" id="builder">

    <!-- Empty: before table selection -->
    <div class="builder-empty" id="builder-empty">
      <div class="bem-eyebrow">RIDAB · EXPLORADOR</div>
      <h2 class="bem-title">Selecione uma<br/>tabela para começar</h2>
      <p class="bem-sub">Escolha na barra lateral ou comece por uma das mais acessadas:</p>
      <div class="bem-shortcuts" id="bem-shortcuts"></div>
    </div>

    <!-- Active: builder steps -->
    <div class="builder-active" id="builder-active" style="display:none">

      <div class="builder-header" id="builder-header">
        <div class="bh-left">
          <span class="bh-table-id" id="bh-table-id"></span>
          <span class="bh-table-desc" id="bh-table-desc"></span>
        </div>
        <button class="bh-sql-toggle" id="btn-sql-toggle">&#60;/&#62; SQL</button>
      </div>

      <!-- SQL mode -->
      <div class="builder-sql" id="builder-sql" style="display:none">
        <div class="sql-hint">SQL gerado automaticamente · edite livremente · Ctrl+Enter para executar</div>
        <textarea class="sql-editor" id="ex-editor" spellcheck="false"></textarea>
        <button class="sql-run-btn" id="btn-run-sql">&#9654; Executar SQL</button>
      </div>

      <!-- ░░ FIELD PANEL ░░ -->
      <div class="fp" id="field-panel">

        <!-- source: campos disponíveis (draggáveis) -->
        <div class="fp-source">
          <div class="fp-source__bar">
            <span class="fp-source__count" id="fp-count">0 campos</span>
            <input class="fp-search" id="fp-search" placeholder="buscar campo…" />
          </div>
          <div class="fp-list" id="fp-list"></div>
        </div>

        <!-- zonas de drop -->
        <div class="fp-zones">

          <div class="fp-zone" id="zone-cols" data-zone="cols">
            <div class="fp-zone__head">
              <span class="fp-zone__label">Colunas</span>
              <button class="fp-zone__btn" id="btn-cols-all">Todas</button>
            </div>
            <div class="fp-zone__body" id="zone-cols-body">
              <span class="fp-zone__empty">arraste campos ou clique em Todas</span>
            </div>
          </div>

          <div class="fp-zone" id="zone-filters" data-zone="filters">
            <div class="fp-zone__head">
              <span class="fp-zone__label">Filtros</span>
              <button class="fp-zone__btn fp-zone__btn--add" id="btn-add-filter">+ filtro</button>
            </div>
            <div class="fp-zone__body" id="zone-filters-body">
              <span class="fp-zone__empty">arraste um campo para filtrar</span>
            </div>
          </div>

          <div class="fp-zone" id="zone-sort" data-zone="sort">
            <div class="fp-zone__head">
              <span class="fp-zone__label">Ordenar por</span>
              <button class="dir-btn" id="btn-dir">&#8593; ASC</button>
            </div>
            <div class="fp-zone__body" id="zone-sort-body">
              <span class="fp-zone__empty">arraste um campo para ordenar</span>
            </div>
          </div>

          <div class="fp-limit">
            <span class="fp-zone__label">Linhas</span>
            <div class="limit-chips">
              <button class="lchip" data-val="50">50</button>
              <button class="lchip lchip--on" data-val="100">100</button>
              <button class="lchip" data-val="500">500</button>
              <button class="lchip" data-val="1000">1 k</button>
              <button class="lchip" data-val="0">Todas</button>
            </div>
          </div>

        </div><!-- /fp-zones -->
      </div><!-- /field-panel -->

      <!-- CTA -->
      <div class="builder-cta">
        <button class="cta-btn" id="btn-run" disabled>
          <span class="cta-btn__icon">&#9654;</span>
          <span class="cta-btn__label">Visualizar dados</span>
        </button>
      </div>

    </div><!-- /builder-active -->
  </div><!-- /builder -->

  <!-- ░░ RESULTS ░░ -->
  <div class="results" id="results-panel">

    <!-- NL bar -->
    <div class="nl-bar">
      <div class="nl-badge">IA GRATUITA</div>
      <textarea class="nl-input" id="nl-input" rows="1"
        placeholder="Pergunte em português — ex: Quais estados produziram mais filmes nos últimos 5 anos?"></textarea>
      <button class="nl-btn" id="btn-gen">&#10022; Gerar</button>
    </div>
    <div class="nl-hint-wrap"><span class="nl-hint" id="nl-hint"></span></div>

    <!-- Result area -->
    <div class="result-area" id="ex-result">
      <!-- Empty state -->
      <div class="result-empty" id="result-empty-state">
        <div class="ree-frame">
          <div class="ree-grid">
            {Array.from({length:16}).map(() => <div class="ree-cell"></div>)}
          </div>
        </div>
        <p class="ree-text">Os dados aparecerão aqui depois que você clicar em<br/><strong>Visualizar dados</strong></p>
      </div>
    </div>

    <!-- Footer -->
    <div class="result-footer" id="ex-foot" style="display:none">
      <span class="rf-count" id="ex-rowcount"></span>
      <span class="rf-time" id="ex-time"></span>
      <button class="rf-csv-btn" id="btn-export">&#8595; Baixar CSV</button>
    </div>

  </div><!-- /results -->

</div><!-- /exp -->

</Base>

<script define:vars={{ parquetMapJson, tablesJson, featuredJson }}>
  window.__RIDAB__ = {
    parquetMap: JSON.parse(parquetMapJson),
    tables:     JSON.parse(tablesJson),
    featured:   JSON.parse(featuredJson),
  };
</script>

<script type="module">
import * as duckdb from "https://cdn.jsdelivr.net/npm/@duckdb/duckdb-wasm@1.29.0/+esm";

const { parquetMap, tables, featured } = window.__RIDAB__;

// ── DOM ────────────────────────────────────────────────────────
const dot             = document.getElementById("ex-dot");
const statusEl        = document.getElementById("ex-status");
const btnRun          = document.getElementById("btn-run");
const btnExport       = document.getElementById("btn-export");
const resultArea      = document.getElementById("ex-result");
const foot            = document.getElementById("ex-foot");
const rowcountEl      = document.getElementById("ex-rowcount");
const timeEl          = document.getElementById("ex-time");
const fpList          = document.getElementById("fp-list");
const fpSearch        = document.getElementById("fp-search");
const fpCount         = document.getElementById("fp-count");
const zoneColsBody    = document.getElementById("zone-cols-body");
const zoneFiltersBody = document.getElementById("zone-filters-body");
const zoneSortBody    = document.getElementById("zone-sort-body");
const btnColsAll      = document.getElementById("btn-cols-all");
const btnDir          = document.getElementById("btn-dir");
const editor          = document.getElementById("ex-editor");
const bhTableId       = document.getElementById("bh-table-id");
const bhTableDesc     = document.getElementById("bh-table-desc");
const nlInput         = document.getElementById("nl-input");
const btnGen          = document.getElementById("btn-gen");
const nlHint          = document.getElementById("nl-hint");

// ── State ──────────────────────────────────────────────────────
let db, conn;
let ready        = false;
let sqlMode      = false;
let currentTable = null;
let columns      = [];
let selectedCols = new Set();
let colsAll      = true;
let filters      = [];
let sortDir      = "ASC";
let sortField    = "";
let limitVal     = 100;
let lastRows = [], lastCols = [];
let autoRunTimer = null;
let filterId     = 0;

// ── INIT DUCKDB ────────────────────────────────────────────────
async function initDuckDB() {
  try {
    statusEl.textContent = "Carregando motor de consultas…";
    const bundles  = duckdb.getJsDelivrBundles();
    const bundle   = await duckdb.selectBundle(bundles);
    const workerUrl = URL.createObjectURL(
      new Blob([`importScripts("${bundle.mainWorker}");`], { type: "text/javascript" })
    );
    db = new duckdb.AsyncDuckDB(new duckdb.ConsoleLogger(), new Worker(workerUrl));
    await db.instantiate(bundle.mainModule, bundle.pthreadWorker);
    conn = await db.connect();
    await conn.query("INSTALL httpfs; LOAD httpfs;");
    await conn.query("SET s3_region='us-east-1';");

    const names = Object.keys(parquetMap);
    statusEl.textContent = `Registrando ${names.length} tabelas…`;
    for (const [name, url] of Object.entries(parquetMap)) {
      await conn.query(`CREATE OR REPLACE VIEW ${name} AS SELECT * FROM '${url}'`);
    }

    dot.className = "sdot sdot--ok";
    statusEl.textContent = `${names.length} tabelas disponíveis`;
    ready = true;
    document.querySelectorAll(".stable").forEach(b => b.classList.add("stable--ready"));

    // Shortcuts
    const sc = document.getElementById("bem-shortcuts");
    if (sc) {
      featured.forEach(id => {
        const meta = tables.flatMap(g => g.tables).find(t => t.id === id);
        if (!meta) return;
        const btn = document.createElement("button");
        btn.className = "bem-shortcut";
        btn.dataset.table = id;
        const grp = tables.find(g => g.tables.some(t => t.id === id));
        btn.innerHTML = `
          <span class="bem-sc__label">${meta.label}</span>
          <span class="bem-sc__desc">${meta.desc}</span>
          <span class="bem-sc__country bem-sc__country--${grp?.color ?? 'ref'}">${grp?.group ?? ''}</span>`;
        btn.addEventListener("click", () => loadTable(id));
        sc.appendChild(btn);
      });
    }
  } catch (e) {
    dot.className = "sdot sdot--err";
    statusEl.textContent = "Erro ao carregar: " + e.message;
  }
}

// ── LOAD TABLE ─────────────────────────────────────────────────
async function loadTable(name) {
  if (!ready) return;
  currentTable = name;
  filters      = [];
  selectedCols = new Set();
  colsAll      = true;
  sortField    = "";

  document.querySelectorAll(".stable").forEach(b =>
    b.classList.toggle("stable--active", b.dataset.table === name)
  );

  document.getElementById("builder-empty").style.display  = "none";
  document.getElementById("builder-active").style.display = "flex";

  const meta = tables.flatMap(g => g.tables).find(t => t.id === name);
  const grp  = tables.find(g => g.tables.some(t => t.id === name));
  bhTableId.textContent   = meta?.label ?? name;
  bhTableId.dataset.color = grp?.color ?? "ref";
  bhTableDesc.textContent = meta?.desc ?? "";

  statusEl.textContent = "Lendo colunas…";
  try {
    const res = await conn.query(`DESCRIBE ${name}`);
    columns = res.toArray().map(r => ({ name: r.column_name, type: r.column_type }));
    renderFields();
    renderColsZone();
    renderSortZone();
    zoneFiltersBody.innerHTML = `<span class="fp-zone__empty">arraste um campo para filtrar</span>`;
    statusEl.textContent = `${columns.length} colunas`;
    btnRun.disabled = false;
    triggerAutoRun();
  } catch(e) {
    statusEl.textContent = "Erro: " + e.message;
  }
}

// ── FIELD LIST ─────────────────────────────────────────────────
function renderFields(query) {
  const q = (query !== undefined ? query : fpSearch.value ?? "").toLowerCase();
  fpList.innerHTML = "";
  fpCount.textContent = `${columns.length} campo${columns.length !== 1 ? "s" : ""}`;
  columns
    .filter(c => !q || c.name.toLowerCase().includes(q))
    .forEach(col => {
      const t = col.type.toUpperCase()
        .replace("VARCHAR","TEXT").replace("INTEGER","INT").replace("BIGINT","INT")
        .replace("DOUBLE","NUM").replace("FLOAT","NUM").split("(")[0].trim();
      const el = document.createElement("div");
      el.className = "fp-item";
      el.draggable = true;
      el.dataset.col = col.name;
      el.innerHTML = `<span class="fp-item__name">${col.name}</span><span class="fp-item__type">${t}</span>`;

      el.addEventListener("dragstart", e => {
        e.dataTransfer.setData("text/plain", col.name);
        e.dataTransfer.effectAllowed = "copy";
        el.classList.add("fp-item--dragging");
      });
      el.addEventListener("dragend", () => el.classList.remove("fp-item--dragging"));

      el.addEventListener("click", () => {
        colsAll = false;
        selectedCols.add(col.name);
        renderColsZone();
        syncAndRun();
      });

      fpList.appendChild(el);
    });
}

// ── DROP ZONES ─────────────────────────────────────────────────
function initDropZones() {
  function setupZone(zoneEl, onDrop) {
    zoneEl.addEventListener("dragover", e => {
      e.preventDefault();
      e.dataTransfer.dropEffect = "copy";
      zoneEl.classList.add("fp-zone--over");
    });
    zoneEl.addEventListener("dragleave", e => {
      if (!zoneEl.contains(e.relatedTarget)) zoneEl.classList.remove("fp-zone--over");
    });
    zoneEl.addEventListener("drop", e => {
      e.preventDefault();
      zoneEl.classList.remove("fp-zone--over");
      const colName = e.dataTransfer.getData("text/plain");
      if (colName) onDrop(colName);
    });
  }

  setupZone(document.getElementById("zone-cols"), colName => {
    colsAll = false;
    selectedCols.add(colName);
    renderColsZone();
    syncAndRun();
  });

  setupZone(document.getElementById("zone-filters"), colName => {
    addFilterForCol(colName);
  });

  setupZone(document.getElementById("zone-sort"), colName => {
    sortField = colName;
    renderSortZone();
    syncAndRun();
  });
}

// ── RENDER ZONES ───────────────────────────────────────────────
function renderColsZone() {
  if (colsAll) {
    zoneColsBody.innerHTML = "";
    const chip = document.createElement("div");
    chip.className = "fchip fchip--all";
    chip.innerHTML = `<span>Todas (${columns.length})</span><button class="fchip__x" title="Selecionar manualmente">&times;</button>`;
    chip.querySelector(".fchip__x").addEventListener("click", () => {
      colsAll = false;
      selectedCols = new Set(columns.map(c => c.name));
      renderColsZone();
      syncAndRun();
    });
    zoneColsBody.appendChild(chip);
  } else if (selectedCols.size === 0) {
    zoneColsBody.innerHTML = `<span class="fp-zone__empty">arraste campos ou clique em Todas</span>`;
  } else {
    zoneColsBody.innerHTML = "";
    [...selectedCols].forEach(colName => {
      const chip = document.createElement("div");
      chip.className = "fchip";
      chip.innerHTML = `<span>${colName}</span><button class="fchip__x" title="Remover">&times;</button>`;
      chip.querySelector(".fchip__x").addEventListener("click", () => {
        selectedCols.delete(colName);
        if (selectedCols.size === 0) colsAll = true;
        renderColsZone();
        syncAndRun();
      });
      zoneColsBody.appendChild(chip);
    });
  }
}

function renderSortZone() {
  if (!sortField) {
    zoneSortBody.innerHTML = `<span class="fp-zone__empty">arraste um campo para ordenar</span>`;
  } else {
    zoneSortBody.innerHTML = "";
    const chip = document.createElement("div");
    chip.className = "fchip";
    chip.innerHTML = `<span>${sortField}</span><button class="fchip__x" title="Remover">&times;</button>`;
    chip.querySelector(".fchip__x").addEventListener("click", () => {
      sortField = "";
      renderSortZone();
      syncAndRun();
    });
    zoneSortBody.appendChild(chip);
  }
}

// ── FILTERS ────────────────────────────────────────────────────
function addFilterForCol(colName) {
  if (!columns.length) return;
  const id = ++filterId;
  filters.push({ id, col: colName || columns[0].name, op: "contains", val: "" });
  renderFilters();
  syncAndRun();
}

function renderFilters() {
  if (!filters.length) {
    zoneFiltersBody.innerHTML = `<span class="fp-zone__empty">arraste um campo para filtrar</span>`;
    return;
  }
  zoneFiltersBody.innerHTML = "";
  filters.forEach((f, idx) => {
    const row = document.createElement("div");
    row.className = "filter-row";
    const noVal = ["null","notnull"].includes(f.op);
    row.innerHTML = `
      <span class="filter-row__num">${String(idx+1).padStart(2,"0")}</span>
      <select class="fsel fsel--col">
        ${columns.map(c=>`<option value="${c.name}"${c.name===f.col?" selected":""}>${c.name}</option>`).join("")}
      </select>
      <select class="fsel fsel--op">
        <option value="contains"${f.op==="contains"?" selected":""}>contém</option>
        <option value="starts"${f.op==="starts"?" selected":""}>começa com</option>
        <option value="="${f.op==="="?" selected":""}>=</option>
        <option value="!="${f.op==="!="?" selected":""}>&ne;</option>
        <option value=">"${f.op===">"?" selected":""}>&gt;</option>
        <option value=">="${f.op===">="?" selected":""}>&ge;</option>
        <option value="<"${f.op==="<"?" selected":""}>&lt;</option>
        <option value="<="${f.op==="<="?" selected":""}>&le;</option>
        <option value="null"${f.op==="null"?" selected":""}>é vazio</option>
        <option value="notnull"${f.op==="notnull"?" selected":""}>não é vazio</option>
      </select>
      <input class="finput" type="text" placeholder="valor…" value="${f.val}"
        ${noVal ? 'disabled style="opacity:.3"' : ""}/>
      <button class="frm" title="Remover">&times;</button>`;

    row.querySelector(".fsel--col").addEventListener("change", e => {
      const fi = filters.find(x=>x.id===f.id); if(fi){ fi.col=e.target.value; syncAndRun(); }
    });
    row.querySelector(".fsel--op").addEventListener("change", e => {
      const fi = filters.find(x=>x.id===f.id);
      if(fi){
        fi.op = e.target.value;
        const inp = row.querySelector(".finput");
        const nv = ["null","notnull"].includes(fi.op);
        inp.disabled = nv; inp.style.opacity = nv ? ".3" : "1";
        syncAndRun();
      }
    });
    row.querySelector(".finput").addEventListener("input", e => {
      const fi = filters.find(x=>x.id===f.id); if(fi){ fi.val=e.target.value; syncAndRun(); }
    });
    row.querySelector(".frm").addEventListener("click", () => {
      filters = filters.filter(x=>x.id!==f.id);
      renderFilters(); syncAndRun();
    });
    zoneFiltersBody.appendChild(row);
  });
}

// ── BUILD SQL ──────────────────────────────────────────────────
function buildSQL() {
  if (!currentTable) return "";
  const cols = colsAll || selectedCols.size === 0 ? "*" : [...selectedCols].join(", ");
  let sql = `SELECT ${cols}\nFROM ${currentTable}`;

  const vf = filters.filter(f => f.col && (["null","notnull"].includes(f.op) || f.val !== ""));
  if (vf.length) {
    const conds = vf.map(f => {
      const v = f.val.replace(/'/g, "''");
      switch(f.op){
        case "contains": return `CAST(${f.col} AS VARCHAR) ILIKE '%${v}%'`;
        case "starts":   return `CAST(${f.col} AS VARCHAR) ILIKE '${v}%'`;
        case "=":        return `CAST(${f.col} AS VARCHAR) = '${v}'`;
        case "!=":       return `CAST(${f.col} AS VARCHAR) != '${v}'`;
        case ">":        return `${f.col} > ${parseFloat(f.val)||0}`;
        case ">=":       return `${f.col} >= ${parseFloat(f.val)||0}`;
        case "<":        return `${f.col} < ${parseFloat(f.val)||0}`;
        case "<=":       return `${f.col} <= ${parseFloat(f.val)||0}`;
        case "null":     return `${f.col} IS NULL`;
        case "notnull":  return `${f.col} IS NOT NULL`;
        default: return null;
      }
    }).filter(Boolean);
    if (conds.length) sql += `\nWHERE ${conds.join("\n  AND ")}`;
  }
  if (sortField) sql += `\nORDER BY ${sortField} ${sortDir}`;
  if (limitVal > 0) sql += `\nLIMIT ${limitVal}`;
  return sql;
}

function syncAndRun() {
  if (sqlMode) return;
  const sql = buildSQL();
  editor.value = sql;
  triggerAutoRun();
}

function triggerAutoRun() {
  clearTimeout(autoRunTimer);
  autoRunTimer = setTimeout(() => runQuery(sqlMode ? editor.value : buildSQL()), 400);
}

// ── RUN QUERY ─────────────────────────────────────────────────
async function runQuery(sql) {
  if (!sql || !conn) return;
  showSkeleton();
  foot.style.display = "none";
  const t0 = performance.now();
  try {
    const res = await conn.query(sql);
    const elapsed = ((performance.now() - t0)/1000).toFixed(2);
    lastCols = res.schema.fields.map(f => f.name);
    lastRows = res.toArray().map(r => lastCols.map(c => r[c]));
    renderTable(lastCols, lastRows, elapsed);
    btnExport.disabled = false;
  } catch(e) {
    resultArea.innerHTML = `<div class="result-error"><span class="result-error__label">ERRO SQL</span>${e.message}</div>`;
  }
}

// ── SKELETON LOADER ────────────────────────────────────────────
function showSkeleton() {
  resultArea.innerHTML = `
    <div class="skeleton">
      <div class="sk-head">
        ${Array.from({length:4}).map(()=>`<div class="sk-cell sk-cell--head"></div>`).join("")}
      </div>
      ${Array.from({length:8}).map((_,i)=>`
        <div class="sk-row" style="animation-delay:${i*0.05}s">
          ${Array.from({length:4}).map(()=>`<div class="sk-cell"></div>`).join("")}
        </div>`).join("")}
    </div>`;
}

// ── RENDER TABLE ───────────────────────────────────────────────
function renderTable(cols, rows, elapsed) {
  if (!rows.length) {
    resultArea.innerHTML = `<div class="result-noresult">Nenhum resultado para esses filtros.</div>`;
    return;
  }
  const MAX = 1000;
  const display = rows.slice(0, MAX);

  const thead = `<thead><tr>${cols.map(c=>`<th><span>${c}</span></th>`).join("")}</tr></thead>`;
  const tbody = `<tbody>${display.map((row,i)=>
    `<tr class="${i%2===1?"tr--alt":""}">${row.map(v=>{
      const s = v==null ? "" : String(v);
      const short = s.length>80 ? s.slice(0,80)+"…" : s;
      return `<td title="${s.replace(/"/g,"&quot;")}">${short}</td>`;
    }).join("")}</tr>`
  ).join("")}</tbody>`;

  resultArea.innerHTML = `<div class="table-wrap"><table class="dtable">${thead}${tbody}</table></div>`;
  rowcountEl.textContent = `${rows.length.toLocaleString("pt-BR")} linhas${rows.length>=MAX?` · exibindo ${MAX}`:""}`;
  timeEl.textContent = elapsed + "s";
  foot.style.display = "flex";
}

// ── CSV EXPORT ─────────────────────────────────────────────────
function exportCSV() {
  if (!lastRows.length) return;
  const esc = v => {
    const s = v==null?"":String(v);
    return s.includes(",")||s.includes('"')||s.includes("\n") ? `"${s.replace(/"/g,'""')}"` : s;
  };
  const csv = [lastCols.map(esc).join(","), ...lastRows.map(r=>r.map(esc).join(","))].join("\n");
  const a = Object.assign(document.createElement("a"),{
    href: URL.createObjectURL(new Blob(["\uFEFF"+csv],{type:"text/csv;charset=utf-8;"})),
    download: `riab-${currentTable||"export"}.csv`
  });
  a.click();
}

// ── GEMINI NL→SQL ──────────────────────────────────────────────
const LS_KEY = "riab_gemini_key";

function getGeminiKey() {
  let k = sessionStorage.getItem(LS_KEY);
  if (!k) {
    k = prompt(
      "Chave gratuita da Google AI Studio:\naistudio.google.com/apikey\n\nSera usada diretamente no seu navegador e fica salva apenas nesta sessao.",""
    );
    if (k) sessionStorage.setItem(LS_KEY, k.trim());
  }
  return k ? k.trim() : null;
}

async function generateSQL() {
  const q = nlInput?.value?.trim();
  if (!q || !conn) return;
  const key = getGeminiKey();
  if (!key) return;
  btnGen.disabled = true;
  nlHint.textContent = "Gerando SQL…";
  const colCtx = currentTable && columns.length
    ? `\nTabela atual: ${currentTable}. Colunas: ${columns.map(c=>`${c.name}(${c.type})`).join(", ")}`
    : "";
  const prompt = `Especialista DuckDB SQL para dados audiovisuais.
Tabelas: ${Object.keys(parquetMap).join(", ")}${colCtx}
REGRAS: Retorne APENAS o SQL. Sem markdown. LIMIT 200 se não for agregação. Use ILIKE para texto.
Pergunta: ${q}`;
  try {
    const res = await fetch(
      `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${key}`,
      { method:"POST", headers:{"Content-Type":"application/json"},
        body: JSON.stringify({contents:[{parts:[{text:prompt}]}],generationConfig:{maxOutputTokens:600,temperature:0.1}}) }
    );
    if (res.status===400||res.status===403){ sessionStorage.removeItem(LS_KEY); nlHint.textContent="Chave inválida."; return; }
    if (!res.ok){ nlHint.textContent=`Erro ${res.status}.`; return; }
    const data = await res.json();
    const sql  = data.candidates?.[0]?.content?.parts?.[0]?.text?.trim()??"";
    if (sql) {
      setSQLMode(true);
      editor.value = sql;
      runQuery(sql);
      nlHint.textContent = "SQL gerado ✓";
    } else {
      nlHint.textContent = "Não foi possível gerar SQL. Reformule a pergunta.";
    }
  } catch(e) {
    nlHint.textContent = "Erro: " + e.message;
  } finally {
    btnGen.disabled = false;
  }
}

// ── SQL MODE TOGGLE ────────────────────────────────────────────
function setSQLMode(on) {
  sqlMode = on;
  document.getElementById("builder-sql").style.display  = on ? "flex" : "none";
  document.getElementById("field-panel").style.display  = on ? "none" : "flex";
  document.getElementById("builder-cta").style.display  = on ? "none" : "block";
  document.getElementById("btn-sql-toggle").classList.toggle("bh-sql-toggle--active", on);
  if (on) { editor.value = buildSQL(); }
}

// ── EVENTS ─────────────────────────────────────────────────────
btnRun.addEventListener("click", () => runQuery(buildSQL()));
btnExport.addEventListener("click", exportCSV);
btnGen.addEventListener("click", generateSQL);

document.getElementById("btn-add-filter").addEventListener("click", () => addFilterForCol(""));
btnColsAll.addEventListener("click", () => {
  colsAll = true;
  selectedCols.clear();
  renderColsZone();
  syncAndRun();
});

fpSearch.addEventListener("input", e => renderFields(e.target.value));

btnDir.addEventListener("click", () => {
  sortDir = sortDir==="ASC"?"DESC":"ASC";
  btnDir.innerHTML = sortDir==="ASC"?"&#8593; ASC":"&#8595; DESC";
  syncAndRun();
});

document.querySelectorAll(".lchip").forEach(chip => {
  chip.addEventListener("click", () => {
    document.querySelectorAll(".lchip").forEach(c => c.classList.remove("lchip--on"));
    chip.classList.add("lchip--on");
    limitVal = parseInt(chip.dataset.val);
    syncAndRun();
  });
});

document.getElementById("btn-sql-toggle").addEventListener("click", () => setSQLMode(!sqlMode));
document.getElementById("btn-run-sql").addEventListener("click", () => runQuery(editor.value));

editor.addEventListener("keydown", e => {
  if ((e.ctrlKey||e.metaKey)&&e.key==="Enter"){ e.preventDefault(); runQuery(editor.value); }
  if (e.key==="Tab"){ e.preventDefault(); const s=editor.selectionStart;
    editor.value=editor.value.substring(0,s)+"  "+editor.value.substring(editor.selectionEnd);
    editor.selectionStart=editor.selectionEnd=s+2; }
});

nlInput.addEventListener("keydown", e => {
  if ((e.ctrlKey||e.metaKey)&&e.key==="Enter"){ e.preventDefault(); generateSQL(); }
});
nlInput.addEventListener("input", () => {
  nlInput.style.height = "auto";
  nlInput.style.height = Math.min(nlInput.scrollHeight, 80) + "px";
});

document.querySelectorAll(".stable").forEach(btn => {
  btn.addEventListener("click", () => loadTable(btn.dataset.table));
});

document.getElementById("sidebar-toggle").addEventListener("click", () => {
  const s   = document.getElementById("sidebar");
  const btn = document.getElementById("sidebar-toggle");
  const c   = s.classList.toggle("sidebar--collapsed");
  btn.innerHTML = c ? "&#8250;" : "&#8249;";
});

initDropZones();
initDuckDB();
</script>

