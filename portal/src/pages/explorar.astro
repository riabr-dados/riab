---
import Base from "../layouts/Base.astro";

const HF_BASE = "https://huggingface.co/datasets/riabr-dados/riab/resolve/main/cleaned";

// Tabelas disponíveis com metadados
const TABLES = [
  {
    group: "Brasil — Registro de Obras",
    color: "br",
    tables: [
      { id: "obras", label: "Obras", desc: "61 mil obras audiovisuais brasileiras (ANCINE 2002–2026)" },
      { id: "diretores_obras", label: "Diretores", desc: "Diretores por CPB de obra" },
      { id: "produtores_obras", label: "Produtores", desc: "Produtoras por CPB de obra" },
    ],
  },
  {
    group: "Brasil — Fomento Público",
    color: "br",
    tables: [
      { id: "fomento_fsa", label: "FSA Projetos", desc: "4.5 mil contratos do Fundo Setorial do Audiovisual" },
      { id: "renuncia_fiscal", label: "Renúncia Fiscal", desc: "Projetos com captação via renúncia fiscal" },
    ],
  },
  {
    group: "Brasil — Mercado",
    color: "br",
    tables: [
      { id: "bilheteria_por_filme_ano", label: "Bilheteria por Filme/Ano", desc: "Público por filme e ano (todos os países)" },
      { id: "bilheteria_consolidada_br", label: "Bilheteria Histórica BR", desc: "Top obras brasileiras histórico" },
      { id: "agentes_economicos", label: "Agentes Econômicos", desc: "Empresas registradas na ANCINE" },
      { id: "preco_ingresso", label: "Preço do Ingresso", desc: "Preço médio do ingresso 2014–2024" },
    ],
  },
  {
    group: "Europa — Lumiere",
    color: "eu",
    tables: [
      { id: "bilheteria_europa", label: "Bilheteria Europa", desc: "Admissões de filmes em 37 países (1996–2026)" },
      { id: "vod_europa", label: "VOD Europa", desc: "Catálogo de filmes em plataformas VOD europeias" },
    ],
  },
  {
    group: "Referência",
    color: "muted",
    tables: [
      { id: "deflator_ipca", label: "Deflator IPCA", desc: "Fator de atualização monetária IBGE (base 2024)" },
    ],
  },
];

// Mapa id → URL do parquet no HF
const parquetMap = Object.fromEntries(
  TABLES.flatMap(g => g.tables.map(t => [t.id, `${HF_BASE}/${t.id}.parquet`]))
);

const parquetMapJson = JSON.stringify(parquetMap);
const tablesJson = JSON.stringify(TABLES);
---

<Base title="Explorar Dados" description="Query builder visual para consultar todos os datasets do RIAB sem escrever SQL.">
<div class="exp-page">

  <!-- Topbar -->
  <div class="exp-topbar">
    <div class="exp-topbar__left">
      <h1 class="exp-title">Explorar Dados</h1>
      <p class="exp-subtitle">Selecione uma tabela na barra lateral e filtre as colunas que precisa.</p>
    </div>
    <div class="exp-topbar__right">
      <div class="exp-status-wrap">
        <span class="ex-dot ex-dot--loading" id="ex-dot"></span>
        <span class="exp-status-text" id="ex-status"></span>
      </div>
      <div class="exp-mode-toggle">
        <button class="mode-btn mode-btn--active" id="btn-mode-visual" title="Modo visual">Visual</button>
        <button class="mode-btn" id="btn-mode-sql" title="Modo SQL avançado">SQL</button>
      </div>
      <button class="ex-btn" id="btn-run" disabled>&#9654; Executar</button>
      <button class="ex-btn ex-btn--outline" id="btn-export" disabled>&#8595; CSV</button>
    </div>
  </div>

  <!-- NL bar (Gemini) -->
  <div class="exp-nl-bar" id="nl-bar">
    <div class="exp-nl-inner">
      <span class="exp-nl-label">&#10022; Pergunte em português (Google Gemini — gratuito)</span>
      <div class="exp-nl-row">
        <textarea
          id="nl-input"
          class="exp-nl-input"
          placeholder="Ex: Quais estados produziram mais filmes nos últimos 5 anos?"
          rows="2"
          spellcheck="true"
        ></textarea>
        <button class="ex-btn exp-nl-btn" id="btn-gen">&#10022; Gerar</button>
      </div>
      <span id="nl-hint" class="exp-nl-hint"></span>
    </div>
  </div>

  <!-- Body -->
  <div class="exp-body">

    <!-- Sidebar -->
    <aside class="exp-sidebar" id="exp-sidebar">
      <div class="exp-sidebar__header">
        <span>Tabelas</span>
        <button class="sidebar-toggle" id="sidebar-toggle" title="Recolher">&#171;</button>
      </div>
      {TABLES.map(g => (
        <div class={`exp-group exp-group--${g.color}`}>
          <div class="exp-group__label">{g.group}</div>
          {g.tables.map(t => (
            <button class="exp-table-btn" data-table={t.id} title={t.desc}>
              <span class="etb-name">{t.label}</span>
              <span class="etb-desc">{t.desc}</span>
            </button>
          ))}
        </div>
      ))}
    </aside>

    <!-- Main -->
    <div class="exp-main" id="exp-main">

      <!-- Empty state -->
      <div class="exp-empty" id="exp-empty">
        <div class="exp-empty__icon">&#128202;</div>
        <h2 class="exp-empty__title">Escolha uma tabela</h2>
        <p class="exp-empty__sub">Clique em qualquer tabela na barra lateral para começar a explorar os dados.</p>
        <div class="exp-empty__tables" id="exp-empty-shortcuts"></div>
      </div>

      <!-- Builder (hidden until table selected) -->
      <div class="exp-builder" id="exp-builder" style="display:none">

        <!-- Cabeçalho da tabela ativa -->
        <div class="exp-builder__header" id="builder-header">
          <div class="builder-header-left">
            <span class="builder-table-tag" id="builder-table-name"></span>
            <span class="builder-table-desc" id="builder-table-desc"></span>
          </div>
          <div class="builder-header-right">
            <label class="builder-opt-label">Linhas
              <select class="builder-select" id="sel-limit">
                <option value="50">50</option>
                <option value="100" selected>100</option>
                <option value="500">500</option>
                <option value="1000">1.000</option>
                <option value="0">Todas</option>
              </select>
            </label>
            <label class="builder-opt-label">Ordenar por
              <select class="builder-select" id="sel-sort"></select>
            </label>
            <button class="builder-dir-btn" id="btn-dir" title="Alternar direção">&#8593; ASC</button>
          </div>
        </div>

        <!-- Visual mode -->
        <div class="exp-visual" id="exp-visual">
          <!-- Columns panel -->
          <div class="exp-cols-panel">
            <div class="exp-cols-header">
              <span class="panel-label">Colunas</span>
              <div class="cols-actions">
                <button class="small-btn" id="btn-all">Todas</button>
                <button class="small-btn" id="btn-none">Nenhuma</button>
                <input type="text" class="cols-search" id="cols-search" placeholder="Filtrar..." />
              </div>
            </div>
            <div class="exp-cols-list" id="exp-cols-list">
              <!-- populated by JS -->
            </div>
          </div>

          <!-- Filters panel -->
          <div class="exp-filters-panel">
            <div class="exp-filters-header">
              <span class="panel-label">Filtros</span>
              <button class="small-btn small-btn--accent" id="btn-add-filter">+ Adicionar</button>
            </div>
            <div class="exp-filters-list" id="exp-filters-list">
              <div class="filters-empty">Nenhum filtro aplicado.</div>
            </div>
          </div>
        </div>

        <!-- SQL mode (hidden by default) -->
        <div class="exp-sql-mode" id="exp-sql-mode" style="display:none">
          <div class="sql-generated-hint">SQL gerado automaticamente · edite livremente</div>
          <textarea class="exp-editor" id="ex-editor" spellcheck="false" rows="10"></textarea>
        </div>

        <!-- Results -->
        <div class="exp-result" id="ex-result">
          <div class="ex-placeholder">Execute uma consulta para ver os dados.</div>
        </div>

        <!-- Footer -->
        <div class="exp-foot" id="ex-foot" style="display:none">
          <span id="ex-rowcount"></span>
          <span id="ex-time"></span>
        </div>

      </div>
    </div>
  </div>
</div>
</Base>

<script define:vars={{ parquetMapJson, tablesJson }}>
  window.__RIAB__ = {
    parquetMap: JSON.parse(parquetMapJson),
    tables: JSON.parse(tablesJson),
  };
</script>

<script type="module">
import * as duckdb from "https://cdn.jsdelivr.net/npm/@duckdb/duckdb-wasm@1.29.0/+esm";

const { parquetMap, tables } = window.__RIAB__;

// ── DOM refs ──────────────────────────────────────────────────
const dot        = document.getElementById("ex-dot");
const statusEl   = document.getElementById("ex-status");
const btnRun     = document.getElementById("btn-run");
const btnExport  = document.getElementById("btn-export");
const result     = document.getElementById("ex-result");
const foot       = document.getElementById("ex-foot");
const rowcountEl = document.getElementById("ex-rowcount");
const timeEl     = document.getElementById("ex-time");
const editor     = document.getElementById("ex-editor");
const selLimit   = document.getElementById("sel-limit");
const selSort    = document.getElementById("sel-sort");
const btnDir     = document.getElementById("btn-dir");
const colsList   = document.getElementById("exp-cols-list");
const filtersList= document.getElementById("exp-filters-list");
const colsSearch = document.getElementById("cols-search");
const builderTableName = document.getElementById("builder-table-name");
const builderTableDesc = document.getElementById("builder-table-desc");

// ── State ─────────────────────────────────────────────────────
let db, conn;
let ready = false;
let mode = "visual"; // "visual" | "sql"
let currentTable = null;
let columns = [];        // [{name, type}]
let selectedCols = new Set();
let filters = [];        // [{id, col, op, val}]
let sortDir = "ASC";
let lastRows = [], lastCols = [];
let autoRunTimer = null;
let filterId = 0;

// ── INIT DUCKDB ───────────────────────────────────────────────
async function initDuckDB() {
  try {
    statusEl.textContent = "Carregando DuckDB…";
    const bundles = duckdb.getJsDelivrBundles();
    const bundle  = await duckdb.selectBundle(bundles);
    const workerUrl = URL.createObjectURL(
      new Blob([`importScripts("${bundle.mainWorker}");`], { type: "text/javascript" })
    );
    const worker = new Worker(workerUrl);
    db = new duckdb.AsyncDuckDB(new duckdb.ConsoleLogger(), worker);
    await db.instantiate(bundle.mainModule, bundle.pthreadWorker);
    conn = await db.connect();

    await conn.query("INSTALL httpfs; LOAD httpfs;");
    await conn.query("SET s3_region='us-east-1';");

    // Registra todas as tabelas como views
    const names = Object.keys(parquetMap);
    for (const [name, url] of Object.entries(parquetMap)) {
      await conn.query(`CREATE OR REPLACE VIEW ${name} AS SELECT * FROM '${url}'`);
    }

    dot.className = "ex-dot ex-dot--ok";
    statusEl.textContent = `${names.length} tabelas prontas`;
    ready = true;
    btnRun.disabled = false;

    // Atalhos na empty state
    const shortcuts = document.getElementById("exp-empty-shortcuts");
    if (shortcuts) {
      const featured = ["obras", "bilheteria_por_filme_ano", "fomento_fsa", "agentes_economicos"];
      featured.forEach(id => {
        const btn = document.createElement("button");
        btn.className = "empty-shortcut";
        btn.dataset.table = id;
        const meta = tables.flatMap(g => g.tables).find(t => t.id === id);
        btn.innerHTML = `<strong>${meta?.label ?? id}</strong><span>${meta?.desc ?? ""}</span>`;
        btn.addEventListener("click", () => loadTable(id));
        shortcuts.appendChild(btn);
      });
    }

    // Ativa botões de tabela
    document.querySelectorAll(".exp-table-btn").forEach(btn => btn.classList.add("etb--ready"));

  } catch (e) {
    dot.className = "ex-dot ex-dot--err";
    statusEl.textContent = "Erro: " + e.message;
  }
}

// ── CARREGAR TABELA ───────────────────────────────────────────
async function loadTable(name) {
  if (!ready) return;
  currentTable = name;
  filters = [];
  selectedCols = new Set();

  // Marca active na sidebar
  document.querySelectorAll(".exp-table-btn").forEach(btn => {
    btn.classList.toggle("etb--active", btn.dataset.table === name);
  });

  // Mostra builder, esconde empty
  document.getElementById("exp-empty").style.display = "none";
  document.getElementById("exp-builder").style.display = "flex";

  // Metadados
  const meta = tables.flatMap(g => g.tables).find(t => t.id === name);
  builderTableName.textContent = meta?.label ?? name;
  builderTableDesc.textContent = meta?.desc ?? "";

  // DESCRIBE para obter colunas
  try {
    statusEl.textContent = "Lendo colunas…";
    const res = await conn.query(`DESCRIBE ${name}`);
    columns = res.toArray().map(r => ({ name: r.column_name, type: r.column_type }));
    columns.forEach(c => selectedCols.add(c.name));

    renderColumns();
    renderFiltersEmpty();
    populateSortSelect();
    statusEl.textContent = `${columns.length} colunas`;
    btnExport.disabled = false;

    triggerAutoRun();
  } catch (e) {
    statusEl.textContent = "Erro ao ler tabela: " + e.message;
  }
}

// ── RENDER COLUNAS ────────────────────────────────────────────
function renderColumns() {
  const search = (colsSearch.value ?? "").toLowerCase();
  colsList.innerHTML = "";
  columns
    .filter(c => !search || c.name.includes(search) || c.type.toLowerCase().includes(search))
    .forEach(col => {
      const checked = selectedCols.has(col.name);
      const div = document.createElement("div");
      div.className = "col-item" + (checked ? " col-item--on" : "");
      div.innerHTML = `
        <label class="col-label">
          <input type="checkbox" class="col-cb" data-col="${col.name}" ${checked ? "checked" : ""} />
          <span class="col-name">${col.name}</span>
          <span class="col-type">${col.type}</span>
        </label>`;
      div.querySelector("input").addEventListener("change", e => {
        if (e.target.checked) selectedCols.add(col.name);
        else selectedCols.delete(col.name);
        div.classList.toggle("col-item--on", e.target.checked);
        syncSQLAndRun();
      });
      colsList.appendChild(div);
    });
}

function populateSortSelect() {
  selSort.innerHTML = `<option value="">— nenhum —</option>` +
    columns.map(c => `<option value="${c.name}">${c.name}</option>`).join("");
}

// ── RENDER FILTROS ────────────────────────────────────────────
function renderFiltersEmpty() {
  filtersList.innerHTML = `<div class="filters-empty">Nenhum filtro aplicado.</div>`;
}

function addFilter() {
  if (!columns.length) return;
  const id = ++filterId;
  filters.push({ id, col: columns[0].name, op: "contains", val: "" });
  renderAllFilters();
}

function renderAllFilters() {
  if (!filters.length) { renderFiltersEmpty(); return; }
  filtersList.innerHTML = "";
  filters.forEach(f => {
    const row = document.createElement("div");
    row.className = "filter-row";
    row.dataset.id = f.id;
    row.innerHTML = `
      <select class="filter-col" title="Coluna">
        ${columns.map(c => `<option value="${c.name}" ${c.name===f.col?"selected":""}>${c.name}</option>`).join("")}
      </select>
      <select class="filter-op" title="Operador">
        <option value="contains" ${f.op==="contains"?"selected":""}>contém</option>
        <option value="starts"   ${f.op==="starts"?"selected":""}>começa com</option>
        <option value="="        ${f.op==="="?"selected":""}>=</option>
        <option value="!="       ${f.op==="!="?"selected":""}>&ne;</option>
        <option value=">"        ${f.op===">"?"selected":""}>&gt;</option>
        <option value=">="       ${f.op===">="?"selected":""}>&ge;</option>
        <option value="<"        ${f.op==="<"?"selected":""}>&lt;</option>
        <option value="<="       ${f.op==="<="?"selected":""}>&le;</option>
        <option value="null"     ${f.op==="null"?"selected":""}>é vazio</option>
        <option value="notnull"  ${f.op==="notnull"?"selected":""}>não é vazio</option>
      </select>
      <input class="filter-val" type="text" placeholder="valor" value="${f.val}" ${["null","notnull"].includes(f.op) ? "disabled style='opacity:.4'" : ""} />
      <button class="filter-rm" title="Remover">&times;</button>`;

    row.querySelector(".filter-col").addEventListener("change", e => {
      const fi = filters.find(x => x.id === f.id);
      if (fi) { fi.col = e.target.value; syncSQLAndRun(); }
    });
    row.querySelector(".filter-op").addEventListener("change", e => {
      const fi = filters.find(x => x.id === f.id);
      if (fi) {
        fi.op = e.target.value;
        const valInput = row.querySelector(".filter-val");
        const noVal = ["null","notnull"].includes(fi.op);
        valInput.disabled = noVal;
        valInput.style.opacity = noVal ? ".4" : "1";
        syncSQLAndRun();
      }
    });
    row.querySelector(".filter-val").addEventListener("input", e => {
      const fi = filters.find(x => x.id === f.id);
      if (fi) { fi.val = e.target.value; syncSQLAndRun(); }
    });
    row.querySelector(".filter-rm").addEventListener("click", () => {
      filters = filters.filter(x => x.id !== f.id);
      renderAllFilters();
      syncSQLAndRun();
    });

    filtersList.appendChild(row);
  });
}

// ── BUILD SQL ─────────────────────────────────────────────────
function buildSQL() {
  if (!currentTable) return "";
  const cols = selectedCols.size > 0 && selectedCols.size < columns.length
    ? [...selectedCols].join(", ")
    : "*";
  let sql = `SELECT ${cols}\nFROM ${currentTable}`;

  const validF = filters.filter(f => f.col && (["null","notnull"].includes(f.op) || f.val !== ""));
  if (validF.length) {
    const conds = validF.map(f => {
      const v = f.val.replace(/'/g, "''");
      switch (f.op) {
        case "contains": return `CAST(${f.col} AS VARCHAR) ILIKE '%${v}%'`;
        case "starts":   return `CAST(${f.col} AS VARCHAR) ILIKE '${v}%'`;
        case "=":        return `CAST(${f.col} AS VARCHAR) = '${v}'`;
        case "!=":       return `CAST(${f.col} AS VARCHAR) != '${v}'`;
        case ">":        return `${f.col} > ${parseFloat(f.val)||0}`;
        case ">=":       return `${f.col} >= ${parseFloat(f.val)||0}`;
        case "<":        return `${f.col} < ${parseFloat(f.val)||0}`;
        case "<=":       return `${f.col} <= ${parseFloat(f.val)||0}`;
        case "null":     return `${f.col} IS NULL`;
        case "notnull":  return `${f.col} IS NOT NULL`;
        default: return null;
      }
    }).filter(Boolean);
    if (conds.length) sql += `\nWHERE ${conds.join("\n  AND ")}`;
  }

  const sort = selSort.value;
  if (sort) sql += `\nORDER BY ${sort} ${sortDir}`;

  const lim = parseInt(selLimit.value);
  if (lim > 0) sql += `\nLIMIT ${lim}`;

  return sql;
}

function syncSQLAndRun() {
  const sql = buildSQL();
  editor.value = sql;
  triggerAutoRun();
}

function triggerAutoRun() {
  clearTimeout(autoRunTimer);
  autoRunTimer = setTimeout(() => runQuery(buildSQL()), 350);
}

// ── EXECUTAR QUERY ────────────────────────────────────────────
async function runQuery(sql) {
  if (!sql || !conn) return;
  result.innerHTML = `<div class="ex-placeholder ex-loading">Buscando dados…</div>`;
  foot.style.display = "none";
  btnRun.disabled = true;
  const t0 = performance.now();
  try {
    const res = await conn.query(sql);
    const elapsed = ((performance.now() - t0) / 1000).toFixed(2);
    lastCols = res.schema.fields.map(f => f.name);
    lastRows = res.toArray().map(r => lastCols.map(c => r[c]));
    renderTable(lastCols, lastRows, elapsed);
    btnExport.disabled = false;
  } catch (e) {
    result.innerHTML = `<div class="ex-error">${e.message}</div>`;
  } finally {
    btnRun.disabled = false;
  }
}

// ── RENDERIZAR TABELA ─────────────────────────────────────────
function renderTable(cols, rows, elapsed) {
  if (!rows.length) {
    result.innerHTML = `<div class="ex-placeholder">Nenhum resultado encontrado.</div>`;
    return;
  }
  const MAX = 1000;
  const display = rows.slice(0, MAX);
  const thead = `<thead><tr>${cols.map(c => `<th>${c}</th>`).join("")}</tr></thead>`;
  const tbody = `<tbody>${display.map(row =>
    `<tr>${row.map(v => {
      const s = v == null ? "" : String(v);
      return `<td title="${s.replace(/"/g, "&quot;")}">${s.length > 80 ? s.slice(0, 80) + "…" : s}</td>`;
    }).join("")}</tr>`
  ).join("")}</tbody>`;
  result.innerHTML = `<div class="ex-table-wrap"><table class="ex-table">${thead}${tbody}</table></div>`;
  rowcountEl.textContent = `${rows.length.toLocaleString("pt-BR")} linhas${rows.length >= MAX ? ` (máx ${MAX})` : ""}`;
  timeEl.textContent = elapsed + "s";
  foot.style.display = "flex";
}

// ── EXPORT CSV ────────────────────────────────────────────────
function exportCSV() {
  if (!lastRows.length) return;
  const esc = v => {
    const s = v == null ? "" : String(v);
    return s.includes(",") || s.includes('"') || s.includes("\n")
      ? `"${s.replace(/"/g, '""')}"` : s;
  };
  const lines = [lastCols.map(esc).join(","), ...lastRows.map(r => r.map(esc).join(","))];
  const blob = new Blob(["\uFEFF" + lines.join("\n")], { type: "text/csv;charset=utf-8;" });
  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  a.download = `riab-${currentTable || "export"}.csv`;
  a.click();
}

// ── LINGUAGEM NATURAL → SQL (Gemini) ──────────────────────────
const LS_KEY = "riab_gemini_key";
const nlInput = document.getElementById("nl-input");
const btnGen  = document.getElementById("btn-gen");
const nlHint  = document.getElementById("nl-hint");

function getGeminiKey() {
  let key = localStorage.getItem(LS_KEY);
  if (!key) {
    key = prompt(
      "Para usar perguntas em português, informe sua chave da Google AI Studio.\n" +
      "É gratuita em: aistudio.google.com/apikey\n" +
      "Fica salva só no seu navegador.",
      ""
    );
    if (key) localStorage.setItem(LS_KEY, key.trim());
  }
  return key ? key.trim() : null;
}

async function generateSQL() {
  const question = nlInput?.value?.trim();
  if (!question || !conn) return;
  const apiKey = getGeminiKey();
  if (!apiKey) return;

  btnGen.disabled = true;
  nlHint.textContent = "Gerando…";

  const tableList = Object.keys(parquetMap).join(", ");
  const colContext = currentTable
    ? `\nTabela ativa: ${currentTable}. Colunas: ${columns.map(c => `${c.name} (${c.type})`).join(", ")}`
    : "";
  const prompt = `Você é especialista em DuckDB SQL para dados audiovisuais.
Tabelas disponíveis: ${tableList}${colContext}

REGRAS:
1. Retorne APENAS o SQL — sem markdown, sem explicação, sem backticks
2. Nomes de tabela e coluna em snake_case exatos
3. Inclua LIMIT 200 se não for agregação
4. Use ILIKE para texto, funções DuckDB nativas

Pergunta: ${question}`;

  try {
    const res = await fetch(
      `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${apiKey}`,
      {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          contents: [{ parts: [{ text: prompt }] }],
          generationConfig: { maxOutputTokens: 600, temperature: 0.1 },
        }),
      }
    );
    if (res.status === 400 || res.status === 403) {
      localStorage.removeItem(LS_KEY);
      nlHint.textContent = "Chave inválida. Tente novamente.";
      return;
    }
    if (!res.ok) { nlHint.textContent = `Erro ${res.status}.`; return; }
    const data = await res.json();
    const sql = data.candidates?.[0]?.content?.parts?.[0]?.text?.trim() ?? "";
    if (sql) {
      // Muda para modo SQL e coloca a query
      setMode("sql");
      editor.value = sql;
      runQuery(sql);
      nlHint.textContent = "SQL gerado ✓";
    } else {
      nlHint.textContent = "Não foi possível gerar SQL.";
    }
  } catch (e) {
    nlHint.textContent = "Erro: " + e.message;
  } finally {
    btnGen.disabled = false;
  }
}

// ── MODO VISUAL / SQL ─────────────────────────────────────────
function setMode(m) {
  mode = m;
  document.getElementById("exp-visual").style.display = m === "visual" ? "flex" : "none";
  document.getElementById("exp-sql-mode").style.display = m === "sql" ? "flex" : "none";
  document.getElementById("btn-mode-visual").classList.toggle("mode-btn--active", m === "visual");
  document.getElementById("btn-mode-sql").classList.toggle("mode-btn--active", m === "sql");
  if (m === "sql") editor.value = buildSQL();
}

// ── EVENTOS ───────────────────────────────────────────────────
btnRun.addEventListener("click", () => {
  const sql = mode === "sql" ? editor.value : buildSQL();
  runQuery(sql);
});
btnExport.addEventListener("click", exportCSV);

document.getElementById("btn-mode-visual").addEventListener("click", () => setMode("visual"));
document.getElementById("btn-mode-sql").addEventListener("click", () => setMode("sql"));

selSort.addEventListener("change", syncSQLAndRun);
selLimit.addEventListener("change", syncSQLAndRun);

btnDir.addEventListener("click", () => {
  sortDir = sortDir === "ASC" ? "DESC" : "ASC";
  btnDir.textContent = (sortDir === "ASC" ? "\u2191 ASC" : "\u2193 DESC");
  syncSQLAndRun();
});

document.getElementById("btn-add-filter").addEventListener("click", addFilter);
document.getElementById("btn-all").addEventListener("click", () => {
  columns.forEach(c => selectedCols.add(c.name));
  renderColumns();
  syncSQLAndRun();
});
document.getElementById("btn-none").addEventListener("click", () => {
  selectedCols.clear();
  renderColumns();
  syncSQLAndRun();
});
colsSearch.addEventListener("input", renderColumns);

editor.addEventListener("keydown", e => {
  if ((e.ctrlKey || e.metaKey) && e.key === "Enter") { e.preventDefault(); runQuery(editor.value); }
  if (e.key === "Tab") {
    e.preventDefault();
    const s = editor.selectionStart;
    editor.value = editor.value.substring(0, s) + "  " + editor.value.substring(editor.selectionEnd);
    editor.selectionStart = editor.selectionEnd = s + 2;
  }
});

btnGen.addEventListener("click", generateSQL);
nlInput.addEventListener("keydown", e => {
  if ((e.ctrlKey || e.metaKey) && e.key === "Enter") { e.preventDefault(); generateSQL(); }
});

// Clicks na sidebar
document.querySelectorAll(".exp-table-btn").forEach(btn => {
  btn.addEventListener("click", () => loadTable(btn.dataset.table));
});

// Sidebar toggle
document.getElementById("sidebar-toggle")?.addEventListener("click", () => {
  const sidebar = document.getElementById("exp-sidebar");
  const btn = document.getElementById("sidebar-toggle");
  const c = sidebar.classList.toggle("exp-sidebar--collapsed");
  btn.innerHTML = c ? "&#187;" : "&#171;";
});

initDuckDB();
</script>

