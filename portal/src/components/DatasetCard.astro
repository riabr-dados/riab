---
const { ds } = Astro.props;
const base = import.meta.env.BASE_URL;

const COUNTRY_LABEL = {
  BR: "Brasil",
  FR: "França",
  AR: "Argentina",
  UK: "Reino Unido",
  UY: "Uruguai",
  EU: "Europa",
};

const CATEGORIA_LABEL = {
  bilheteria: "Bilheteria",
  salas_exibicao: "Salas & Exibição",
  producao_obras: "Produção & Obras",
  fomento: "Fomento",
  emprego_economia: "Emprego & Economia",
  distribuicao: "Distribuição",
  vod_streaming: "VoD & Streaming",
  tv_audiencia: "TV & Audiência",
  diversidade: "Diversidade",
  internacional: "Internacional",
  fontes_metadados: "Fontes & Metadados",
};

const PROCEDENCIA_LABEL = {
  pda: "Plano de Dados Abertos",
  oca: "OCA / ANCINE",
  ancine: "ANCINE",
  ibge: "IBGE",
  mdic: "Comex Stat / MDIC",
  composto: "Composto (multi-fonte)",
  cnc: "CNC",
  bfi: "BFI",
  incaa: "INCAA",
  acau: "ACAU",
  lumiere: "Lumiere",
};

// Sub-fonte (só pra PDA): detalhe do sistema/portal onde está o dado
const SUBFONTE_LABEL = {
  ancine_pda: "Lista PDA",
  oca: "OCA",
  sadis: "SADIS",
  fsa: "FSA",
  embrafilme: "Embrafilme",
};

const country = ds.source?.country ?? "";
const countryLabel = COUNTRY_LABEL[country] ?? country;

function fmtBytes(b) {
  if (!b) return "";
  if (b < 1024) return `${b} B`;
  if (b < 1048576) return `${Math.round(b / 1024)} KB`;
  return `${(b / 1048576).toFixed(1)} MB`;
}

const totalBytes = ds.raw?.size_bytes ?? 0;
const formats = [ds.raw?.format?.toUpperCase()].filter(Boolean).join(", ");
const tables = ds.cleaned?.tables ?? [];
const categorias = Array.isArray(ds.categoria) ? ds.categoria : (ds.categoria ? [ds.categoria] : []);
const procedencia = ds.procedencia ?? null;
const procedenciaLabel = procedencia ? PROCEDENCIA_LABEL[procedencia] ?? procedencia : null;
const subfonte = ds.subfonte ?? null;
const subfonteLabel = subfonte ? SUBFONTE_LABEL[subfonte] ?? subfonte : null;

const dataCats = categorias.join(" ");
---

<a
  class={`dcard dcard--${country}`}
  href={`${base}datasets/${ds.slug}/`}
  data-country={country}
  data-procedencia={procedencia ?? ""}
  data-subfonte={subfonte ?? ""}
  data-categorias={dataCats}
>
  <div class="dcard__top">
    <span class="dcard__inst">{ds.source?.name?.split(" - ")[0] ?? ds.source_id}</span>
    <span class={`dcard__status dcard__status--${ds.status}`}>{ds.status}</span>
  </div>
  <div class="dcard__title">{ds.title}</div>
  <div class="dcard__desc">{ds.description}</div>

  {(categorias.length > 0 || procedencia) && (
    <div class="dcard__chips">
      {procedencia && (
        <span class={`dcard__proc dcard__proc--${procedencia}`} title={procedenciaLabel}>
          {procedenciaLabel}
          {subfonteLabel && <span class="dcard__proc-sub">· {subfonteLabel}</span>}
        </span>
      )}
      {categorias.map((c) => (
        <span class="dcard__cat">{CATEGORIA_LABEL[c] ?? c}</span>
      ))}
    </div>
  )}

  <div class="dcard__meta">
    <span class="dcard__tag dcard__tag--country">{countryLabel}</span>
    {formats && <span class="dcard__tag">{formats}</span>}
    {totalBytes > 0 && <span class="dcard__tag">{fmtBytes(totalBytes)}</span>}
    {ds.raw?.files > 1 && <span class="dcard__tag">{ds.raw.files} arquivos</span>}
    {ds.coverage && <span class="dcard__tag">{ds.coverage}</span>}
    {tables.length > 0 && <span class="dcard__tag dcard__tag--cleaned">Parquet disponivel</span>}
  </div>
</a>
